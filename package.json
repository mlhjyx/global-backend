{
  "name": "global-backend",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "api:dev": "pnpm --filter @global/api start:dev",
    "api:build": "pnpm --filter @global/api build",
    "infra:up": "docker compose -p global up -d",
    "infra:down": "docker compose -p global down",
    "infra:up:legacy": "docker compose -p global-backend up -d",
    "infra:down:legacy": "docker compose -p global-backend down",
    "worktree:new": "node scripts/create-codex-worktree.mjs",
    "docs:verify": "node scripts/verify-docs.mjs",
    "contracts:lint": "pnpm --filter @global/contracts lint",
    "contracts:docs": "pnpm --filter @global/contracts docs",
    "contracts:mock": "pnpm --filter @global/contracts mock",
    "contracts:gen": "pnpm --filter @global/contracts gen",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "nx": "^23.1.0",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.65.0"
  }
}
