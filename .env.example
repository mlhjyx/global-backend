# ── API ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL (docker compose) ──────────────────────
DATABASE_URL=postgresql://global:global@localhost:5432/global_dev

# ── Redis (docker compose) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ── Temporal ─────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ── Model aggregation gateway (中转站: new-api / one-api / LiteLLM) ──
# 模型接入/各厂商 key/路由/额度都在中转站 UI 里统一管理；app 只调它一个端点。
MODEL_GATEWAY_URL=http://localhost:3001/v1
MODEL_GATEWAY_KEY=            # 中转站里创建的访问令牌
MODEL_DEFAULT_MODEL=deepseek-chat
