{
  "name": "@global/contracts",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "spectral lint openapi/openapi.json",
    "bundle": "redocly bundle openapi/openapi.json -o dist/openapi.bundled.yaml",
    "docs": "redocly build-docs openapi/openapi.json -o dist/docs.html",
    "mock": "prism mock openapi/openapi.json -p 4010",
    "gen": "openapi-typescript openapi/openapi.json -o src/generated/api.ts"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.0",
    "@stoplight/prism-cli": "^5.16.0",
    "@stoplight/spectral-cli": "^6.16.2",
    "openapi-typescript": "^7.4.0"
  }
}
