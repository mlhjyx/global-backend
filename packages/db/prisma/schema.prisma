// Global backend — schema.
// Multi-tenant: every workspace-scoped table carries workspace_id and is guarded
// by PostgreSQL RLS (ADR-001). Identity/users/permissions are owned by the
// external SaaS platform — NOT modeled here. `workspace` is only a tenant anchor
// whose id comes from the platform's token (JIT-provisioned on first write).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenancy & infrastructure ──────────────────────────────────────────────

model Workspace {
  id        String   @id @db.Uuid // = tenant id from the external platform's token
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companyProfiles CompanyProfile[]
  outboxEvents    OutboxEvent[]

  @@map("workspace")
}

/// AI 调用追踪（PRD 9.10）：每次 ModelGateway 调用一行 — task/model/延迟/tokens/结果。
model AiTrace {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  task          String // AI Task id（如 icp.design）
  op            String // generateText | generateStructured | embed
  provider      String
  model         String
  status        String // OK | ERROR
  errorMessage  String?  @map("error_message")
  latencyMs     Int      @map("latency_ms")
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  costUsd       Float?   @map("cost_usd")
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([workspaceId, task])
  @@map("ai_trace")
}

/// 用量/成本账本（PRD 8.19 / 11.7 AI & Operations 域）：先记 AI tokens，
/// P3 起 Provider 调用成本也入此账（resourceType 区分）。
model UsageLedger {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  resourceType String   @map("resource_type") // ai_tokens | provider_call | ...
  quantity     Float
  costUsd      Float?   @map("cost_usd")
  refType      String?  @map("ref_type") // ai_trace | raw_source_record | ...
  refId        String?  @map("ref_id")
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([workspaceId, resourceType])
  @@map("usage_ledger")
}

/// 幂等键（PRD 11.16）：POST 携带 Idempotency-Key 时，同 key 重放返回首个结果。
model IdempotencyKey {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  key         String
  endpoint    String
  response    Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, endpoint, key])
  @@index([workspaceId])
  @@map("idempotency_key")
}

/// Transactional Outbox (ADR-009). Domain writes append events in the same tx;
/// a relay publishes unpublished rows at-least-once.
model OutboxEvent {
  id                    BigInt    @id @default(autoincrement())
  eventId               String    @unique @default(uuid()) @map("event_id") @db.Uuid
  workspaceId           String    @map("workspace_id") @db.Uuid
  eventType             String    @map("event_type")
  schemaVersion         Int       @default(1) @map("schema_version")
  aggregateType         String    @map("aggregate_type")
  aggregateId           String    @map("aggregate_id")
  producer              String    @default("global-backend") // Envelope 11.10
  correlationId         String?   @map("correlation_id")
  causationId           String?   @map("causation_id")
  privacyClassification String    @default("CONFIDENTIAL") @map("privacy_classification")
  payload               Json
  occurredAt            DateTime  @default(now()) @map("occurred_at")
  publishedAt           DateTime? @map("published_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([publishedAt])
  @@index([workspaceId])
  @@map("outbox_event")
}

// ── Company & Knowledge (企业理解, PRD 7.2) ────────────────────────────────

/// DRAFT → ENRICHING →（理解完成）REVIEW →（审批达完整度阈值或人工确认）ACTIVE
/// 5.2.7：零审批不得 ACTIVE —— 未确认的关键信息不能进入对外使用。
enum CompanyStatus {
  DRAFT
  ENRICHING
  REVIEW
  ACTIVE

  @@map("company_status")
}

/// Claim lifecycle (PRD 11.9): INGESTED → EXTRACTED → NEEDS_REVIEW → APPROVED → EXPIRED/REVOKED
enum ClaimStatus {
  INGESTED
  EXTRACTED
  NEEDS_REVIEW
  APPROVED
  EXPIRED
  REVOKED

  @@map("claim_status")
}

model CompanyProfile {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  name        String
  website     String?
  status      CompanyStatus @default(DRAFT)
  industry    String? // 画像回填（KNW-002 / 5.2.3）
  summary     String? // 一段话企业简介（抽取，随 Claim 审批修正）
  /// 官网上确定性抽取（正则，非 LLM）的公开联系方式/社媒，逐条带来源页 URL：
  /// [{ type: 'email'|'phone'|'social', value, sourceUrl }] — Buyer Trust 原料（PRD 7.15）
  publicContacts Json?      @map("public_contacts")
  version     Int           @default(1) // optimistic lock (PRD 11.16)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  offerings Offering[]
  sources   KnowledgeSource[]
  claims    Claim[]
  icps      IcpDefinition[]

  @@index([workspaceId])
  @@map("company_profile")
}

model Offering {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  description String?
  attributes  Json? // MOQ / 交期 / 参数 / 认证 等结构化属性
  sourceUrl   String?  @map("source_url") // 溯源：该产品信息来自哪个页面
  evidence    String? // 来源页原文片段
  confidence  Float?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name]) // 同一企业下按名称幂等 upsert（重跑理解不产生重复）
  @@index([workspaceId])
  @@index([companyId])
  @@map("offering")
}

model KnowledgeSource {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  type        String // website | pdf | docx | pptx | manual ...
  uri         String?
  status      String   @default("INGESTED") // 摄取生命周期
  ingestKey   String?  @map("ingest_key") // 幂等：workflow runId + 页 URL，重试不重复写
  createdAt   DateTime @default(now()) @map("created_at")

  company   CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  claims    Claim[]
  citations Citation[]

  @@unique([companyId, ingestKey])
  @@index([workspaceId])
  @@index([companyId])
  @@map("knowledge_source")
}

model Claim {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @map("workspace_id") @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  sourceId    String?     @map("source_id") @db.Uuid
  type        String // capability | certification | case | param | value_prop ...
  statement   String
  status      ClaimStatus @default(EXTRACTED)
  confidence  Float?
  validUntil  DateTime?   @map("valid_until")
  version     Int         @default(1)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  company  CompanyProfile   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source   KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  evidence Evidence[]

  @@index([workspaceId])
  @@index([companyId])
  @@map("claim")
}

model Evidence {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  claimId     String    @map("claim_id") @db.Uuid
  sourceUrl   String?   @map("source_url")
  snippet     String?
  confidence  Float?
  fetchedAt   DateTime? @map("fetched_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([claimId])
  @@map("evidence")
}

/// 知识冲突（KNW-004）：不同来源对同一事实不一致时不得静默覆盖 ——
/// 生成冲突记录供人工裁决，发 KnowledgeConflictDetected 事件。
model KnowledgeConflict {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  claimAId    String    @map("claim_a_id") @db.Uuid
  claimBId    String    @map("claim_b_id") @db.Uuid
  claimType   String    @map("claim_type")
  status      String    @default("OPEN") // OPEN | RESOLVED
  resolvedBy  String?   @map("resolved_by")
  resolution  String? // kept_a | kept_b
  createdAt   DateTime  @default(now()) @map("created_at")
  resolvedAt  DateTime? @map("resolved_at")

  @@index([workspaceId])
  @@index([companyId])
  @@map("knowledge_conflict")
}

model Citation {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  sourceId    String   @map("source_id") @db.Uuid
  locator     String? // page / section
  createdAt   DateTime @default(now()) @map("created_at")

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("citation")
}

// ── Global Business Data Hub & 客户发现 (PRD 7.4 / 第8部分 / 5.5) ──────────

// ── 规范词表归一（平台级参考数据，无 RLS）──────────────────────────────────
// 行业主键=ISIC Rev.4；国家主键=ISO 3166-1 alpha-2；产品维=HS。混合归一：
// 确定性种子命中 → 未命中冷路径 LLM（enum 约束）→ 沉淀为别名。详见
// docs/backend/vocab-taxonomy.md。Wikidata QID / OSM 标签降级为 downstream 发现标识。

model CanonicalTaxonomy {
  id          String   @id @default(uuid()) @db.Uuid
  kind        String // industry | country | product
  scheme      String // ISIC | ISO3166_1 | HS
  code        String // ISIC 叶码 / ISO alpha-2 / HS6
  parentCode  String?  @map("parent_code") // 层级（ISIC 自引用）
  labelEn     String   @map("label_en")
  labels      Json? // { zh, de, native, ... } 多语言规范名
  crosswalks  Json? // { nace:[...], naics:[...], gb4754:[...] } 官方对照
  wikidataQid String?  @map("wikidata_qid") // downstream 发现标识（供 wikidata adapter）
  osmTags     Json?    @map("osm_tags") // [{k,v}] downstream（供 osm adapter）
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([kind, code])
  @@index([kind])
  @@map("canonical_taxonomy")
}

model TermAlias {
  id        String   @id @default(uuid()) @db.Uuid
  term      String // 归一化词（NFC + 小写）
  kind      String // industry | country | product
  code      String // 指向 CanonicalTaxonomy.code
  source    String   @default("seed") // seed | llm | manual
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([kind, term])
  @@index([kind, term])
  @@map("term_alias")
}

/// Provider 注册表（平台级，非租户数据 → 无 RLS）。七类 Provider（PRD 7.4.7）。
/// 第一版只有 sandbox 实现；真源签约后加行即可，适配器按 key 挂接。
model DataProvider {
  id               String   @id @default(uuid()) @db.Uuid
  key              String   @unique // 'sandbox' | 'tendata' | 'apollo' ...
  class            String // trade_data | b2b_company_person | company_registry | contact_discovery | email_verification | public_intelligence | industry_data
  status           String   @default("ENABLED") // ENABLED | DISABLED（Kill Switch 执行点）
  costPerCallCents Int      @default(0) @map("cost_per_call_cents")
  config           Json?
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("data_provider")
}

/// Source Registry（DAT-011 / PRD 7.4.11）：公开采集只允许访问已批准的来源。
/// 平台级治理表（非租户数据，无 RLS）。爬取前逐域名检查。
model SourcePolicy {
  id             String    @id @default(uuid()) @db.Uuid
  domain         String    @unique // 如 hannovermesse.de；'*' 不允许
  sourceType     String    @map("source_type") // official_website | trade_fair | association | gov_registry | news | jobs | tender | search_engine
  accessMode     String    @default("crawl") @map("access_mode") // crawl | api
  allowedPaths   Json?     @map("allowed_paths") // string[] 前缀；null=全站
  disallowedPaths Json?    @map("disallowed_paths")
  robotsStatus   String    @default("UNREVIEWED") @map("robots_status") // ALLOWS | RESTRICTS | UNREVIEWED
  termsStatus    String    @default("UNREVIEWED") @map("terms_status") // REVIEWED_OK | REVIEWED_RESTRICTED | UNREVIEWED
  personalData   Boolean   @default(false) @map("personal_data") // 是否可能含个人数据（限制用途）
  allowedPurpose Json?     @map("allowed_purpose") // ['discovery','enrichment']
  crawlDelayMs   Int       @default(2000) @map("crawl_delay_ms")
  retentionDays  Int       @default(365) @map("retention_days")
  reviewStatus   String    @default("APPROVED") @map("review_status") // APPROVED | SUSPENDED
  owner          String    @default("backend")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("source_policy")
}

/// 采集与监控层（Acquisition & Monitoring，源无关）。展会/名录/官网/注册处等**任一数据源**
/// 都注册为一个 monitored_source，统一走「抓取 → 清洗 → 快照落库 → diff 增量更新」。
/// 平台级共享参考数据（无 RLS，像 data_provider/canonical_taxonomy）：一个源抓一次服务所有租户。
/// 行业不写死——靠 sectorTags 打标，按 ICP 行业选源。
model MonitoredSource {
  id          String    @id @default(uuid()) @db.Uuid
  providerKey String    @map("provider_key") // 用哪个采集适配器：trade_fair | directory | public_web | ...
  sourceKey   String    @unique @map("source_key") // 人类可读唯一键，如 'trade_fair:euroblech-2026'
  label       String
  config      Json // 源特定配置（展会 Algolia cfg / 名录 URL / 查询参数…）
  sectorTags  Json?     @map("sector_tags") // string[] 行业标签（归一到 ISIC 词表），按 ICP 选源；不硬编码行业
  region      String?
  seriesKey   String?   @map("series_key") // 跨届/跨次分组（如展会系列 'euroblech'），做纵向关联
  status      String    @default("ACTIVE") // ACTIVE | PAUSED | ARCHIVED（Kill-Switch）
  cadence     Json?     // 抓取节奏 { kind:'fixed'|'adaptive', everyMs?, state? }
  lastFetchAt DateTime? @map("last_fetch_at")
  nextFetchAt DateTime? @map("next_fetch_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  fetches  SourceFetch[]
  entities SourceEntity[]
  changes  SourceEntityChange[]

  @@index([providerKey, status])
  @@index([nextFetchAt])
  @@map("monitored_source")
}

/// 一次采集（一个 monitored_source 的一次抓取），带增量统计审计。
model SourceFetch {
  id            String    @id @default(uuid()) @db.Uuid
  sourceId      String    @map("source_id") @db.Uuid
  status        String    @default("RUNNING") // RUNNING | DONE | PARTIAL | FAILED
  total         Int       @default(0) // 本次抓到的记录数
  added         Int       @default(0)
  updated       Int       @default(0)
  removed       Int       @default(0)
  unchanged     Int       @default(0)
  costCents     Int       @default(0) @map("cost_cents")
  parserVersion String?   @map("parser_version")
  error         String?
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")

  source  MonitoredSource      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  changes SourceEntityChange[]

  @@index([sourceId])
  @@map("source_fetch")
}

/// 一个源里的一条已清洗、去重、持久化的实体（公司/联系人）+ 快照指纹 + 生命周期。
/// 增量更新的锚：按 (source, externalId) upsert，contentHash 判是否变化，缺席判退出。
model SourceEntity {
  id          String    @id @default(uuid()) @db.Uuid
  sourceId    String    @map("source_id") @db.Uuid
  externalId  String    @map("external_id") // 源侧稳定 id（如 organisationGuid / 域名）
  entityKind  String    @default("company") @map("entity_kind") // company | contact
  name        String
  domain      String?
  country     String?
  cleaned     Json // 清洗后的结构化字段（email/phone/products/stand/hiring…，命名空间化）
  contentHash String    @map("content_hash") // 清洗后内容指纹，diff 用
  firstSeenAt DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  withdrawnAt DateTime? @map("withdrawn_at") // 非空=已从源退出（连续缺席判定）
  missCount   Int       @default(0) @map("miss_count") // 连续缺席次数（防单次抓取失败误杀）
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  source MonitoredSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalId])
  @@index([domain])
  @@index([sourceId, withdrawnAt])
  @@map("source_entity")
}

/// 增量变更事件（=获客时机信号）：新增/退出/字段变化，供下游触达编排消费。
model SourceEntityChange {
  id         String   @id @default(uuid()) @db.Uuid
  sourceId   String   @map("source_id") @db.Uuid
  fetchId    String?  @map("fetch_id") @db.Uuid
  externalId String   @map("external_id")
  changeType String   @map("change_type") // ADDED | REMOVED | UPDATED | PRODUCTS_CHANGED | CONTACT_CHANGED
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")

  source MonitoredSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  fetch  SourceFetch?    @relation(fields: [fetchId], references: [id], onDelete: SetNull)

  @@index([sourceId, changeType])
  @@index([createdAt])
  @@map("source_entity_change")
}

/// 一次发现执行（对应一个 READY 的查询计划）。
model DiscoveryRun {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  planId      String    @map("plan_id") @db.Uuid
  icpId       String    @map("icp_id") @db.Uuid
  status      String    @default("RUNNING") // RUNNING | DONE | PARTIAL | FAILED
  stats       Json? // 每源计数/成本/去重结果
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  rawRecords RawSourceRecord[]

  @@index([workspaceId])
  @@index([planId])
  @@map("discovery_run")
}

/// Raw Zone（PRD 8.7）：Provider 原始返回原样落地，永不直接进领域层（ADR-017）。
model RawSourceRecord {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  runId       String   @map("run_id") @db.Uuid
  providerKey String   @map("provider_key")
  sourceClass String   @map("source_class")
  externalId  String?  @map("external_id") // Provider 侧 id（幂等去重）
  payload     Json
  // 公开采集留痕（PRD 8.11）：来源 URL、抓取时间、内容指纹、解析版本
  sourceUrl   String?  @map("source_url")
  fetchedAt   DateTime? @map("fetched_at")
  contentHash String?  @map("content_hash")
  parserVersion String? @map("parser_version")
  costCents   Int      @default(0) @map("cost_cents")
  createdAt   DateTime @default(now()) @map("created_at")

  run DiscoveryRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, providerKey, externalId])
  @@index([workspaceId])
  @@map("raw_source_record")
}

/// Canonical 公司（PRD 8.8/8.9）：跨源归一后的目标客户公司。
/// 字段值的来源/许可/置信度在 field_evidence —— canonical 只是「当前最优视图」。
model CanonicalCompany {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  name          String
  domain        String?
  country       String?
  region        String?
  industry      String?
  employeeCount Int?     @map("employee_count")
  revenueUsd    Float?   @map("revenue_usd")
  attributes    Json? // 其余归一属性（certifications/keywords/tech/end_markets...）
  status        String   @default("NEW") // NEW | ENRICHED | SUPPRESSED
  // ICP 资格门（发现评测驱动）：match | weak | mismatch | null(未判)。
  // 四门判定：材质/角色(竞品)/工艺子集/商业模式。绑定证据在 fit_reasons。
  fitVerdict    String?  @map("fit_verdict")
  fitReasons    Json?    @map("fit_reasons")
  dedupeKey     String   @map("dedupe_key") // 身份解析键：域名 或 name+country 规范化
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  contacts CanonicalContact[]

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId])
  @@map("canonical_company")
}

/// Canonical 联系人（PRD 8.9 个人分层：按需、最小化、可验证）。
model CanonicalContact {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  fullName    String   @map("full_name")
  title       String?
  seniority   String? // c_level | vp | director | manager | staff
  department  String?
  dedupeKey   String   @map("dedupe_key")
  createdAt   DateTime @default(now()) @map("created_at")

  company       CanonicalCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactPoints ContactPoint[]

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId])
  @@index([companyId])
  @@map("canonical_contact")
}

/// 联系方式（PRD 7.4/8.9）：带验证状态生命周期，发送前必须 VALID。
model ContactPoint {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  contactId   String    @map("contact_id") @db.Uuid
  type        String // email | phone | linkedin
  value       String
  status      String    @default("UNVERIFIED") // UNVERIFIED | VALID | RISKY | INVALID
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  contact CanonicalContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, type, value])
  @@index([workspaceId])
  @@map("contact_point")
}

/// 身份解析连接（PRD 8.8）：canonical 实体 ↔ raw 记录，可审计可回溯。
model IdentityLink {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  canonicalType String   @map("canonical_type") // company | contact
  canonicalId   String   @map("canonical_id") @db.Uuid
  rawRecordId   String   @map("raw_record_id") @db.Uuid
  matchRule     String   @map("match_rule") // domain_exact | name_country | provider_id
  confidence    Float    @default(1)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([canonicalId])
  @@map("identity_link")
}

/// 字段级 Evidence（PRD 7.4.9 / 8.10）：canonical 字段不只存最终值 ——
/// 每个字段的每个来源值都留痕：来源/时间/置信度/许可/允许动作。
model FieldEvidence {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  entityType     String   @map("entity_type") // company | contact
  entityId       String   @map("entity_id") @db.Uuid
  field          String
  value          Json
  providerKey    String   @map("provider_key")
  rawRecordId    String?  @map("raw_record_id") @db.Uuid
  confidence     Float?
  license        String   @default("sandbox") // sandbox | licensed | public | byo
  allowedActions Json?    @map("allowed_actions") // ['display','match','outreach']
  fetchedAt      DateTime @default(now()) @map("fetched_at")

  @@index([workspaceId])
  @@index([workspaceId, entityType, entityId])
  @@map("field_evidence")
}

/// Suppression（PRD 7.4 / 12.6）：禁联名单，任何对外动作前的第一道检查。
model SuppressionRecord {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  type        String // email | domain | company_name
  value       String
  reason      String? // unsubscribe | bounce | complaint | manual | legal
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, type, value])
  @@index([workspaceId])
  @@map("suppression_record")
}

// ── Lead & 验证评分 (PRD 7.5 LED-006..009 / 5.6) ───────────────────────────

/// Lead 状态机（PRD 11.9）：DISCOVERED → ENRICHING → REVIEW →
/// QUALIFIED/REJECTED/SUPPRESSED → CONTACTED → CONVERTED
enum LeadStatus {
  DISCOVERED
  ENRICHING
  REVIEW
  QUALIFIED
  REJECTED
  SUPPRESSED
  CONTACTED
  CONVERTED

  @@map("lead_status")
}

/// Lead = 「这家公司 × 这个 ICP」的可跟进机会。评分是确定性计算
/// （规则引擎 + 数据质量），AI 只在上游提议规则 —— 分数可复算可审计。
model Lead {
  id                 String     @id @default(uuid()) @db.Uuid
  workspaceId        String     @map("workspace_id") @db.Uuid
  icpId              String     @map("icp_id") @db.Uuid
  canonicalCompanyId String     @map("canonical_company_id") @db.Uuid
  status             LeadStatus @default(DISCOVERED)
  /// 四队列（LED-008）：recommended | needs_review | rejected | suppressed
  queue              String     @default("needs_review")
  totalScore         Float?     @map("total_score")
  /// 六维分（LED-006）：{fit, role, intent, dataQuality, reachability, engagement}
  scores             Json?
  /// 评分依据：规则逐条评估结果 + 各维输入（审计/申诉用）
  scoreDetail        Json?      @map("score_detail")
  version            Int        @default(1)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  decisions LeadDecision[]

  @@unique([workspaceId, icpId, canonicalCompanyId])
  @@index([workspaceId])
  @@index([workspaceId, queue])
  @@map("lead")
}

/// 人工裁决（LED-009）：接受/拒绝 + 原因，回流做质量反馈。
model LeadDecision {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  leadId      String   @map("lead_id") @db.Uuid
  action      String // accept | reject
  reason      String?
  decidedBy   String   @map("decided_by") // 外部平台 user id（来自 token）
  createdAt   DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([leadId])
  @@map("lead_decision")
}

// ── ICP & Buying Committee (理想客户画像, PRD 7.5 / 5.4) ────────────────────

/// ICP lifecycle (PRD 11.9): DRAFT → HYPOTHESIS → VALIDATING → ACTIVE → SUPERSEDED → ARCHIVED
enum IcpStatus {
  DRAFT
  HYPOTHESIS
  VALIDATING
  ACTIVE
  SUPERSEDED
  ARCHIVED

  @@map("icp_status")
}

model IcpDefinition {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String    @map("workspace_id") @db.Uuid
  companyId         String    @map("company_id") @db.Uuid // the seller company this ICP is for
  name              String
  status            IcpStatus @default(DRAFT)
  companyAttributes Json?     @map("company_attributes") // industry / size / geo / tech ...
  painPoints        Json?     @map("pain_points") // string[]
  triggerSignals    Json?     @map("trigger_signals") // string[] 采购触发信号
  exclusions        Json? // string[] 排除条件（优先于正向评分）
  valueProps        Json?     @map("value_props") // string[]
  targetMarkets     Json?     @map("target_markets") // string[]
  version           Int       @default(1)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company    CompanyProfile        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  personas   Persona[]
  roles      BuyingCommitteeRole[]
  rules      QualificationRule[]
  backtests  IcpBacktest[]
  queryPlans DiscoveryQueryPlan[]

  @@index([workspaceId])
  @@index([companyId])
  @@map("icp_definition")
}

/// 结构化验证规则（LED-003）：机器可评估，是 ICP 从「描述」变「可执行」的桥。
/// EXCLUSION 永远优先于正向评分（PRD 7.5）。
enum RuleKind {
  MUST_HAVE
  NICE_TO_HAVE
  EXCLUSION

  @@map("rule_kind")
}

model QualificationRule {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  icpId       String   @map("icp_id") @db.Uuid
  kind        RuleKind
  field       String // canonical 属性名：industry/region/country/employee_count/certifications/keywords/tech ...
  operator    String // eq | neq | in | not_in | gte | lte | contains | not_contains | matches
  value       Json // 操作数（标量或数组）
  weight      Float    @default(1) // NICE_TO_HAVE 计分权重
  rationale   String? // 该规则的依据（来自 AI 生成或人工），保持推断透明
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("qualification_rule")
}

/// ICP 样例回测（LED-004）：用已知客户/非客户样例验证规则命中，
/// 是 HYPOTHESIS → VALIDATING → ACTIVE 的数据依据。
model IcpBacktest {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  icpId       String   @map("icp_id") @db.Uuid
  samples     Json // [{name, domain?, attributes, expected: 'match'|'exclude'}]
  results     Json // 逐样例 {verdict, ruleOutcomes[], score}
  metrics     Json // {matchHitRate, excludeCatchRate, unknownFieldRate, recommendation}
  createdAt   DateTime @default(now()) @map("created_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("icp_backtest")
}

/// 多源查询计划（LED-005）：把 ICP 翻译成各数据源的可执行查询（Discover 的输入）。
model DiscoveryQueryPlan {
  id                 String   @id @default(uuid()) @db.Uuid
  workspaceId        String   @map("workspace_id") @db.Uuid
  icpId              String   @map("icp_id") @db.Uuid
  status             String   @default("DRAFT") // DRAFT | READY | EXECUTED
  queries            Json // [{source, sourceClass, filters, keywords, rationale, priority}]
  estimatedVolume    Int?     @map("estimated_volume")
  estimatedCostCents Int?     @map("estimated_cost_cents")
  version            Int      @default(1)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("discovery_query_plan")
}

model Persona {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  icpId       String   @map("icp_id") @db.Uuid
  title       String // 角色/职位名
  goals       Json? // string[]
  painPoints  Json?    @map("pain_points") // string[]
  createdAt   DateTime @default(now()) @map("created_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("persona")
}

model BuyingCommitteeRole {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  icpId       String   @map("icp_id") @db.Uuid
  role        String // decision_maker | influencer | user | technical | finance | procurement
  title       String? // 典型职位
  concerns    Json? // string[] 关注点/异议
  createdAt   DateTime @default(now()) @map("created_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("buying_committee_role")
}
