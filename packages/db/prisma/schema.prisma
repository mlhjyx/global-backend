// Global backend — schema.
// Multi-tenant: every workspace-scoped table carries workspace_id and is guarded
// by PostgreSQL RLS (ADR-001). Identity/users/permissions are owned by the
// external SaaS platform — NOT modeled here. `workspace` is only a tenant anchor
// whose id comes from the platform's token (JIT-provisioned on first write).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenancy & infrastructure ──────────────────────────────────────────────

model Workspace {
  id        String   @id @db.Uuid // = tenant id from the external platform's token
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companyProfiles  CompanyProfile[]
  outboxEvents     OutboxEvent[]
  outboxDeliveries OutboxDelivery[]

  @@map("workspace")
}

/// AI 调用追踪（PRD 9.10）：每次 ModelGateway 调用一行 — task/model/延迟/tokens/结果。
model AiTrace {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  task          String // AI Task id（如 icp.design）
  op            String // generateText | generateStructured | embed
  provider      String
  model         String
  status        String // OK | ERROR
  errorMessage  String?  @map("error_message")
  latencyMs     Int      @map("latency_ms")
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  costUsd       Float?   @map("cost_usd")
  correlationId String?  @map("correlation_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([workspaceId, task])
  @@map("ai_trace")
}

/// 用量/成本账本（PRD 8.19 / 11.7 AI & Operations 域）：先记 AI tokens，
/// P3 起 Provider 调用成本也入此账（resourceType 区分）。
model UsageLedger {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  resourceType String   @map("resource_type") // ai_tokens | provider_call | ...
  quantity     Float
  costUsd      Float?   @map("cost_usd")
  refType      String?  @map("ref_type") // ai_trace | raw_source_record | ...
  refId        String?  @map("ref_id")
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([workspaceId, resourceType])
  @@map("usage_ledger")
}

/// 幂等键（PRD 11.16）：POST 携带 Idempotency-Key 时，同 key 重放返回首个结果。
model IdempotencyKey {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  key         String
  endpoint    String
  response    Json
  requestHash String?  @map("request_hash") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, endpoint, key])
  @@index([workspaceId])
  @@map("idempotency_key")
}

/// Transactional Outbox (ADR-009). Domain writes append events in the same tx;
/// a relay publishes unpublished rows at-least-once.
model OutboxEvent {
  id                    BigInt    @id @default(autoincrement())
  eventId               String    @unique @default(uuid()) @map("event_id") @db.Uuid
  workspaceId           String    @map("workspace_id") @db.Uuid
  eventType             String    @map("event_type")
  schemaVersion         Int       @default(1) @map("schema_version")
  aggregateType         String    @map("aggregate_type")
  aggregateId           String    @map("aggregate_id")
  producer              String    @default("global-backend") // Envelope 11.10
  correlationId         String?   @map("correlation_id")
  causationId           String?   @map("causation_id")
  privacyClassification String    @default("CONFIDENTIAL") @map("privacy_classification")
  payload               Json
  occurredAt            DateTime  @default(now()) @map("occurred_at")
  publishedAt           DateTime? @map("published_at")
  /// 无注册 handler 的事件停靠位（收口③）：不假发布、不毒化轮询。人工/后续版本处置。
  parkedAt              DateTime? @map("parked_at")

  workspace  Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries OutboxDelivery[]

  @@index([publishedAt])
  @@index([workspaceId])
  @@map("outbox_event")
}

/// 外部集成事件按 sink 的交付账本（收口③）。outbox_event.publishedAt 语义 = 「已路由进交付层」；
/// 消费侧真值（送达/ACK/死信）在本表。pull sink（saas）用 ACK API；webhook sink 用重试+退避+DLQ。
model OutboxDelivery {
  id            BigInt    @id @default(autoincrement())
  workspaceId   String    @map("workspace_id") @db.Uuid
  eventId       String    @map("event_id") @db.Uuid
  sink          String // 'saas'（拉模式） | 'webhook'（推模式，env 启用）
  status        String    @default("PENDING") // PENDING | ACKED | DEAD
  attempts      Int       @default(0) // webhook 推送尝试数（pull sink 恒 0）
  lastError     String?   @map("last_error")
  nextAttemptAt DateTime? @map("next_attempt_at") // webhook 退避调度；pull sink null
  deliveredAt   DateTime? @map("delivered_at")
  ackedAt       DateTime? @map("acked_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  event     OutboxEvent @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([eventId, sink])
  @@index([workspaceId, sink, status])
  @@index([sink, status, nextAttemptAt]) // webhook 派送循环扫描
  @@index([workspaceId, sink, id]) // GET /events 游标翻页（账本 id 序 = 路由可见序）
  @@map("outbox_delivery")
}

// ── Company & Knowledge (企业理解, PRD 7.2) ────────────────────────────────

/// DRAFT → ENRICHING →（理解完成）REVIEW →（审批达完整度阈值或人工确认）ACTIVE
/// 5.2.7：零审批不得 ACTIVE —— 未确认的关键信息不能进入对外使用。
enum CompanyStatus {
  DRAFT
  ENRICHING
  REVIEW
  ACTIVE

  @@map("company_status")
}

/// Claim lifecycle (PRD 11.9): INGESTED → EXTRACTED → NEEDS_REVIEW → APPROVED → EXPIRED/REVOKED
enum ClaimStatus {
  INGESTED
  EXTRACTED
  NEEDS_REVIEW
  APPROVED
  EXPIRED
  REVOKED

  @@map("claim_status")
}

model CompanyProfile {
  id             String        @id @default(uuid()) @db.Uuid
  workspaceId    String        @map("workspace_id") @db.Uuid
  name           String
  website        String?
  status         CompanyStatus @default(DRAFT)
  industry       String? // 画像回填（KNW-002 / 5.2.3）
  summary        String? // 一段话企业简介（抽取，随 Claim 审批修正）
  /// 官网上确定性抽取（正则，非 LLM）的公开联系方式/社媒，逐条带来源页 URL：
  /// [{ type: 'email'|'phone'|'social', value, sourceUrl }] — Buyer Trust 原料（PRD 7.15）
  publicContacts Json?         @map("public_contacts")
  version        Int           @default(1) // optimistic lock (PRD 11.16)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  offerings Offering[]
  sources   KnowledgeSource[]
  claims    Claim[]
  icps      IcpDefinition[]

  @@index([workspaceId])
  @@map("company_profile")
}

model Offering {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  description String?
  attributes  Json? // MOQ / 交期 / 参数 / 认证 等结构化属性
  sourceUrl   String?  @map("source_url") // 溯源：该产品信息来自哪个页面
  evidence    String? // 来源页原文片段
  confidence  Float?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name]) // 同一企业下按名称幂等 upsert（重跑理解不产生重复）
  @@index([workspaceId])
  @@index([companyId])
  @@map("offering")
}

model KnowledgeSource {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  type        String // website | pdf | docx | pptx | manual ...
  uri         String?
  status      String   @default("INGESTED") // 摄取生命周期
  ingestKey   String?  @map("ingest_key") // 幂等：workflow runId + 页 URL，重试不重复写
  createdAt   DateTime @default(now()) @map("created_at")

  company   CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  claims    Claim[]
  citations Citation[]

  @@unique([companyId, ingestKey])
  @@index([workspaceId])
  @@index([companyId])
  @@map("knowledge_source")
}

model Claim {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @map("workspace_id") @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  sourceId    String?     @map("source_id") @db.Uuid
  type        String // capability | certification | case | param | value_prop ...
  statement   String
  status      ClaimStatus @default(EXTRACTED)
  confidence  Float?
  validUntil  DateTime?   @map("valid_until")
  version     Int         @default(1)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  company  CompanyProfile   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source   KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  evidence Evidence[]

  @@index([workspaceId])
  @@index([companyId])
  @@map("claim")
}

model Evidence {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  claimId     String    @map("claim_id") @db.Uuid
  sourceUrl   String?   @map("source_url")
  snippet     String?
  confidence  Float?
  fetchedAt   DateTime? @map("fetched_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([claimId])
  @@map("evidence")
}

/// 知识冲突（KNW-004）：不同来源对同一事实不一致时不得静默覆盖 ——
/// 生成冲突记录供人工裁决，发 KnowledgeConflictDetected 事件。
model KnowledgeConflict {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  claimAId    String    @map("claim_a_id") @db.Uuid
  claimBId    String    @map("claim_b_id") @db.Uuid
  claimType   String    @map("claim_type")
  status      String    @default("OPEN") // OPEN | RESOLVED
  resolvedBy  String?   @map("resolved_by")
  resolution  String? // kept_a | kept_b
  createdAt   DateTime  @default(now()) @map("created_at")
  resolvedAt  DateTime? @map("resolved_at")

  @@index([workspaceId])
  @@index([companyId])
  @@map("knowledge_conflict")
}

model Citation {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  sourceId    String   @map("source_id") @db.Uuid
  locator     String? // page / section
  createdAt   DateTime @default(now()) @map("created_at")

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("citation")
}

// ── Global Business Data Hub & 客户发现 (PRD 7.4 / 第8部分 / 5.5) ──────────

// ── 规范词表归一（平台级参考数据，无 RLS）──────────────────────────────────
// 行业主键=ISIC Rev.4；国家主键=ISO 3166-1 alpha-2；产品维=HS。混合归一：
// 确定性种子命中 → 未命中冷路径 LLM（enum 约束）→ 沉淀为别名。详见
// docs/backend/vocab-taxonomy.md。Wikidata QID / OSM 标签降级为 downstream 发现标识。

model CanonicalTaxonomy {
  id          String   @id @default(uuid()) @db.Uuid
  kind        String // industry | country | product
  scheme      String // ISIC | ISO3166_1 | HS
  code        String // ISIC 叶码 / ISO alpha-2 / HS6
  parentCode  String?  @map("parent_code") // 层级（ISIC 自引用）
  labelEn     String   @map("label_en")
  labels      Json? // { zh, de, native, ... } 多语言规范名
  crosswalks  Json? // { nace:[...], naics:[...], gb4754:[...] } 官方对照
  wikidataQid String?  @map("wikidata_qid") // downstream 发现标识（供 wikidata adapter）
  osmTags     Json?    @map("osm_tags") // [{k,v}] downstream（供 osm adapter）
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([kind, code])
  @@index([kind])
  @@map("canonical_taxonomy")
}

model TermAlias {
  id        String   @id @default(uuid()) @db.Uuid
  term      String // 归一化词（NFC + 小写）
  kind      String // industry | country | product
  code      String // 指向 CanonicalTaxonomy.code
  source    String   @default("seed") // seed | llm | manual
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([kind, term])
  @@index([kind, term])
  @@map("term_alias")
}

/// Provider 注册表（平台级，非租户数据 → 无 RLS）。七类 Provider（PRD 7.4.7）。
/// 第一版只有 sandbox 实现；真源签约后加行即可，适配器按 key 挂接。
model DataProvider {
  id               String   @id @default(uuid()) @db.Uuid
  key              String   @unique // 'sandbox' | 'tendata' | 'apollo' ...
  class            String // trade_data | b2b_company_person | company_registry | contact_discovery | email_verification | public_intelligence | industry_data
  status           String   @default("ENABLED") // ENABLED | DISABLED（Kill Switch 执行点）
  costPerCallCents Int      @default(0) @map("cost_per_call_cents")
  config           Json?
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("data_provider")
}

/// Source Registry（DAT-011 / PRD 7.4.11）：公开采集只允许访问已批准的来源。
/// 平台级治理表（非租户数据，无 RLS）。爬取前逐域名检查。
model SourcePolicy {
  id              String   @id @default(uuid()) @db.Uuid
  domain          String   @unique // 如 hannovermesse.de；'*' 不允许
  sourceType      String   @map("source_type") // official_website | trade_fair | association | gov_registry | news | jobs | tender | search_engine
  accessMode      String   @default("crawl") @map("access_mode") // crawl | api
  allowedPaths    Json?    @map("allowed_paths") // string[] 前缀；null=全站
  disallowedPaths Json?    @map("disallowed_paths")
  robotsStatus    String   @default("UNREVIEWED") @map("robots_status") // ALLOWS | RESTRICTS | UNREVIEWED
  termsStatus     String   @default("UNREVIEWED") @map("terms_status") // REVIEWED_OK | REVIEWED_RESTRICTED | UNREVIEWED
  personalData    Boolean  @default(false) @map("personal_data") // 是否可能含个人数据（限制用途）
  allowedPurpose  Json?    @map("allowed_purpose") // ['discovery','enrichment']
  crawlDelayMs    Int      @default(2000) @map("crawl_delay_ms")
  retentionDays   Int      @default(365) @map("retention_days")
  reviewStatus    String   @default("APPROVED") @map("review_status") // APPROVED | SUSPENDED
  owner           String   @default("backend")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("source_policy")
}

/// 采集与监控层（Acquisition & Monitoring，源无关）。展会/名录/官网/注册处等**任一数据源**
/// 都注册为一个 monitored_source，统一走「抓取 → 清洗 → 快照落库 → diff 增量更新」。
/// 平台级共享参考数据（无 RLS，像 data_provider/canonical_taxonomy）：一个源抓一次服务所有租户。
/// 行业不写死——靠 sectorTags 打标，按 ICP 行业选源。
model MonitoredSource {
  id          String    @id @default(uuid()) @db.Uuid
  providerKey String    @map("provider_key") // 用哪个采集适配器：trade_fair | directory | public_web | ...
  sourceKey   String    @unique @map("source_key") // 人类可读唯一键，如 'trade_fair:euroblech-2026'
  label       String
  config      Json // 源特定配置（展会 Algolia cfg / 名录 URL / 查询参数…）
  sectorTags  Json?     @map("sector_tags") // string[] 行业标签（归一到 ISIC 词表），按 ICP 选源；不硬编码行业
  region      String?
  seriesKey   String?   @map("series_key") // 跨届/跨次分组（如展会系列 'euroblech'），做纵向关联
  status      String    @default("ACTIVE") // ACTIVE | PAUSED | ARCHIVED（Kill-Switch）
  cadence     Json? // 抓取节奏 { kind:'fixed'|'adaptive', everyMs?, state? }
  lastFetchAt DateTime? @map("last_fetch_at")
  nextFetchAt DateTime? @map("next_fetch_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  fetches  SourceFetch[]
  entities SourceEntity[]
  changes  SourceEntityChange[]

  @@index([providerKey, status])
  @@index([nextFetchAt])
  @@map("monitored_source")
}

/// 一次采集（一个 monitored_source 的一次抓取），带增量统计审计。
model SourceFetch {
  id            String    @id @default(uuid()) @db.Uuid
  sourceId      String    @map("source_id") @db.Uuid
  status        String    @default("RUNNING") // RUNNING | DONE | PARTIAL | FAILED
  total         Int       @default(0) // 本次抓到的记录数
  added         Int       @default(0)
  updated       Int       @default(0)
  removed       Int       @default(0)
  unchanged     Int       @default(0)
  costCents     Int       @default(0) @map("cost_cents")
  parserVersion String?   @map("parser_version")
  error         String?
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")

  source  MonitoredSource      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  changes SourceEntityChange[]

  @@index([sourceId])
  @@map("source_fetch")
}

/// 一个源里的一条已清洗、去重、持久化的实体（公司/联系人）+ 快照指纹 + 生命周期。
/// 增量更新的锚：按 (source, externalId) upsert，contentHash 判是否变化，缺席判退出。
model SourceEntity {
  id          String    @id @default(uuid()) @db.Uuid
  sourceId    String    @map("source_id") @db.Uuid
  externalId  String    @map("external_id") // 源侧稳定 id（如 organisationGuid / 域名）
  entityKind  String    @default("company") @map("entity_kind") // company | contact
  name        String
  domain      String?
  country     String?
  cleaned     Json // 清洗后的结构化字段（email/phone/products/stand/hiring…，命名空间化）
  contentHash String    @map("content_hash") // 清洗后内容指纹，diff 用
  firstSeenAt DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  withdrawnAt DateTime? @map("withdrawn_at") // 非空=已从源退出（连续缺席判定）
  missCount   Int       @default(0) @map("miss_count") // 连续缺席次数（防单次抓取失败误杀）
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  source MonitoredSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalId])
  @@index([domain])
  @@index([sourceId, withdrawnAt])
  @@map("source_entity")
}

/// 增量变更事件（=获客时机信号）：新增/退出/字段变化，供下游触达编排消费。
model SourceEntityChange {
  id         String   @id @default(uuid()) @db.Uuid
  sourceId   String   @map("source_id") @db.Uuid
  fetchId    String?  @map("fetch_id") @db.Uuid
  externalId String   @map("external_id")
  changeType String   @map("change_type") // ADDED | REMOVED | UPDATED | PRODUCTS_CHANGED | CONTACT_CHANGED
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")

  source MonitoredSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  fetch  SourceFetch?    @relation(fields: [fetchId], references: [id], onDelete: SetNull)

  @@index([sourceId, changeType])
  @@index([createdAt])
  @@map("source_entity_change")
}

/// 一等买家信号（收口⑤，ADR-006）：全局公开源（TED/openFDA）的需求/时机事实，**平台级采一次服务所有租户**
///（无 RLS，同 monitored_source 惯例）。🔴 零个人数据红线：payload 只存绿字段白名单（signal-mappers 强制 +
/// 单测断言），具名个人（TED buyer-email / FDA contact/us_agent / 个体户自然人申请人）在摄取层即拒。
/// `attributes.intent.*` 自此降为本表的**租户投影**（可复算）；状态机 ACTIVE → EXPIRED | REVOKED
///（DETECTED 为保留态，官方 API 源摄取即 ACTIVE；EXPIRED 由 sweep 按 expiresAt 翻转，REVOKED 供合规撤回）。
model SourceSignal {
  id             String    @id @default(uuid()) @db.Uuid
  providerKey    String    @map("provider_key") // ted | openfda
  signalType     String    @map("signal_type") // TENDER_PUBLISHED | FDA_CLEARANCE
  externalId     String    @map("external_id") // 源侧稳定 id（TED publication-number / FDA k_number）——无 id 的记录摄取层跳过
  subjectName    String    @map("subject_name") // 主体组织名（买方/申请人，法人 🟢）
  subjectCountry String    @map("subject_country") // alpha-2（无国别的记录摄取层跳过，防跨国同名误并）
  subjectKey     String    @map("subject_key") // companyIdentity({name,country}).dedupeKey——与租户 canonical 同规范化，投影按此匹配
  taxonomyKeys   Json      @map("taxonomy_keys") // 带 scheme 前缀的分类键（'cpv:42122000' / 'fda:LLZ'），投影按 ICP 码交集过滤
  strength       Float // 信号基准强度（0..1，评分侧再按新近度衰减）
  occurredAt     DateTime  @map("occurred_at") // 事件时间（招标发布日/清关决定日）——双时间轴之一，backtest 用
  observedAt     DateTime  @map("observed_at") // 摄取时间——双时间轴之二
  payload        Json // 绿字段白名单载荷（TED: cpv/notice；FDA: product_code/k_number/device）
  license        String // 实值 'CC BY 4.0'（TED，对齐既有 field_evidence 行）| 'CC0-1.0'（FDA，SPDX）；统一 SPDX 随收口⑥ 权利词表（租户投影侧履行署名义务）
  jurisdiction   String? // 'EU' | 'US'
  status         String    @default("ACTIVE") @map("status") // ACTIVE | EXPIRED | REVOKED
  expiresAt      DateTime  @map("expires_at") // = occurredAt + 类型 TTL（招标 90d / 清关 365d，env 可调）
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // 摄取幂等锚（同记录跨 sweep 复现不重复行）。含 subjectKey 的已知取舍（复审记档）：源侧买方名
  // 规范化漂移会产生同 externalId 双行、30d 投影窗内同招标在两个 dedupeKey 上各计一次——名漂移低频、
  // 窗口自愈、不同 dedupeKey 在租户体系本就是不同主体；根治（同 externalId 旧行标 EXPIRED）留后续。
  @@unique([providerKey, externalId, signalType, subjectKey])
  @@index([providerKey, signalType, status, occurredAt])
  @@index([subjectKey])
  @@index([status, expiresAt])
  @@map("source_signal")
}

// ── 制裁名单筛查（Qualify 第五门，出口管制合规硬门）────────────────────────────
// 设计：docs/roadmap/sanctions-screening-design.md。落地 ADR-010「制裁名单筛查作 qualify 第五门」。
// 镜像采集层 + qualify 门两套模式（非 intent 管线）。sanctions_source/sanctions_entity 为平台级
// 参考数据（无 RLS，同 data_provider/monitored_source；owner 连接写、app_user 只读 GRANT SELECT）；
// sanctions_screening_result 是租户级筛查结果（RLS）。Phase 1 仅公司/实体，Individual 摄取层剔除。

/// 制裁名单源注册（平台级，无 RLS）。每个官方名单一行：OFAC SDN / OFAC Consolidated / EU FSF。
/// status=Kill-Switch（DISABLED→不筛查、不路由；真测绿后 ops 翻 ENABLED）；刷新审计列。
model SanctionsSource {
  id              String    @id @default(uuid()) @db.Uuid
  key             String    @unique // ofac_sdn | ofac_consolidated | eu_fsf
  label           String
  url             String
  format          String // ofac_sdn_xml | eu_fsf_xml
  license         String // 'Public Domain (U.S. Government Work)' | 'CC BY 4.0' ...
  status          String    @default("DISABLED") // ENABLED | DISABLED（Kill-Switch）
  publishDate     DateTime? @map("publish_date") // 名单侧发布日（=listVersion 锚）
  recordCount     Int?      @map("record_count") // 本源 Entity 落库条数
  lastRefreshedAt DateTime? @map("last_refreshed_at")
  lastFetchStatus String?   @map("last_fetch_status") // DONE | PARTIAL | FAILED
  config          Json? // 源特定（EU token 在 url；OFAC User-Agent）
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  entities SanctionsEntity[]

  @@map("sanctions_source")
}

/// 一条被制裁的**实体**（Phase 1 仅 sdnType=Entity；Individual 摄取层结构性剔除，天然满足个人隔离红线）。
/// 平台级参考数据（无 RLS）。normalizedName（normForMatch 归一）供进程内索引召回匹配。
model SanctionsEntity {
  id             String    @id @default(uuid()) @db.Uuid
  sourceId       String    @map("source_id") @db.Uuid
  externalId     String    @map("external_id") // 源侧稳定 id（OFAC uid / EU logicalId）
  primaryName    String    @map("primary_name")
  normalizedName String    @map("normalized_name") // normForMatch(primaryName)，索引召回用
  country        String? // 主地址国别 alpha-2（佐证，非硬键）
  programs       Json // string[] 制裁项目/regime（'CUBA' …）
  aliases        Json // [{ name, normalizedName, quality:'strong'|'weak' }]——弱别名不 originate 命中
  rawFeatures    Json?     @map("raw_features") // 仅绿字段（地址国别/机构 ID），🔴 无 person PII
  listVersion    String    @map("list_version") // 名单版本（=publishDate ISO），审计/backtest 用
  contentHash    String    @map("content_hash") // diff 用
  firstSeenAt    DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt     DateTime  @default(now()) @map("last_seen_at")
  withdrawnAt    DateTime? @map("withdrawn_at") // 非空=已从名单移除
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  source SanctionsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalId])
  @@index([normalizedName])
  @@index([sourceId, withdrawnAt])
  @@map("sanctions_entity")
}

/// 一次公司筛查结果（**租户级，RLS**）：clear 或 potential_match（命中）+ 人工复核状态机。
/// 命中 → Lead.queue='sanctions_hold' + decide(accept) 硬拦。审计件只留名单/条目 ref/版本/分数（非个人传记）。
/// 无 Prisma 关系（同 field_evidence 惯例，按 canonicalCompanyId 存），workspace RLS 隔离。
model SanctionsScreeningResult {
  id                 String   @id @default(uuid()) @db.Uuid
  workspaceId        String   @map("workspace_id") @db.Uuid
  canonicalCompanyId String   @map("canonical_company_id") @db.Uuid
  screenedName       String   @map("screened_name") // 被筛的公司名
  status             String // clear | potential_match
  matches            Json // [{ sourceKey, externalId, listVersion, matchedName, aliasQuality, score, entityCountry }]
  topScore           Float?   @map("top_score")
  reviewState        String   @default("open") @map("review_state") // open | cleared_false_positive | confirmed_true_hit
  reviewedBy         String?  @map("reviewed_by")
  reviewNote         String?  @map("review_note")
  listVersions       Json     @map("list_versions") // { ofac_sdn:'2026-07-13', … } 本次筛覆盖的名单版本
  screenedAt         DateTime @default(now()) @map("screened_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // 一公司一结果（复审 M1）：并发多 ICP qualify 对同公司 find-then-create 会产双行 + 「最新」非确定 →
  // 人工清白可能被 open 兄弟行遮蔽。唯一键 → upsert 原子收敛。
  @@unique([workspaceId, canonicalCompanyId])
  @@index([workspaceId, reviewState])
  @@map("sanctions_screening_result")
}

/// 待办3 · 专利发明人缓存（scale-safe #89 fast-follow）。平台级共享、**无 workspace_id、无 RLS**（镜像 source_signal）。
/// 机制：一次共享大扫（Job User 只读）把「近5年·独家申请人·仅 name」的 assignee→inventor 拉回本表 →
///       逐公司发现时只读本表（零 BQ 字节）。一行 = 一个 (assignee 归一名, 公司国别, 发明人名)。
/// 🔴 inventorName **列级加密**落盘（pii-crypto，收口⑥地基）——门前 PII 缓冲最小化。seed DISABLED，ENABLE 待 LIA 拍板。
model PatentInventorCache {
  id              String   @id @default(uuid()) @db.Uuid
  assigneeNameRaw String   @map("assignee_name_raw") // 谐调申请人原名逐字（供 provider pickBestByName ≥0.9 精判 + 证据）
  assigneeNorm    String   @map("assignee_norm") // normForMatch(raw)——与 provider/canonical 同规范化，检索键
  assigneeCountry String   @default("") @map("assignee_country") // 🔴 公司 alpha-2 小写 或 ''（未知）——护栏③/T1，进唯一键令 DE/US 同名分两行
  inventorName    String   @map("inventor_name") // 🔴 仅 name（护栏⑥，绝无 residence/国籍/country_code）；🔴 pii-crypto 确定性加密落盘
  inventorNameKey String   @default("") @map("inventor_name_key") // 🔴 归一人名的**不可逆盲索引**（blindContactKey(normalizePersonName)）——供 Art.17 擦除按人名 O(1) 命中且不泄明文；跨名格式（"Surname, Given"↔"Given Surname"）收敛
  windowFromYear  Int      @map("window_from_year") // 护栏④ 该行覆盖窗口（刷新按滚动窗裁旧行）
  windowToYear    Int      @map("window_to_year")
  license         String   @default("CC-BY-4.0") @map("license") // 护栏⑦ 派生溯源（provider 仍从常量注入 field_evidence.license）
  refreshedAt     DateTime @default(now()) @map("refreshed_at")
  expiresAt       DateTime @map("expires_at") // TTL（默认 180d，env）→ 改名/退源行自然清理 + GDPR 存储限制
  createdAt       DateTime @default(now()) @map("created_at")

  // 幂等去重键（country 未知存 '' 而非 NULL，令唯一键成立）。inventorName 确定性加密 → 密文相等性 → 唯一键仍幂等。
  @@unique([assigneeNorm, assigneeCountry, inventorName])
  @@index([assigneeNorm])
  @@index([expiresAt])
  @@index([inventorNameKey]) // Art.17 擦除按人名盲键 O(1) 命中
  @@map("patent_inventor_cache")
}

/// 专利缓存攒集队列（驱动**条件触发**刷新 + 冷启动预热）。平台级、无 RLS。空队列 → 刷新整轮跳过（零 BQ 成本）。
model PatentLookupRequest {
  id               String    @id @default(uuid()) @db.Uuid
  assigneeNorm     String    @map("assignee_norm")
  country          String    @default("") @map("country") // alpha-2 或 ''
  anchor           String    @map("anchor") // assigneeLikeAnchor 产物（%TOKEN%）——刷新 SQL 的 LIKE 谓词
  sampleName       String    @map("sample_name") // 触发时公司原名（诊断/证据）
  status           String    @default("PENDING") @map("status") // PENDING | CACHED | EMPTY
  firstRequestedAt DateTime  @default(now()) @map("first_requested_at")
  lastRequestedAt  DateTime  @default(now()) @map("last_requested_at")
  refreshedAt      DateTime? @map("refreshed_at")
  nextRefreshAt    DateTime? @map("next_refresh_at") // 过期后可再刷（TTL 到期重排）

  @@unique([assigneeNorm, country])
  @@index([status, nextRefreshAt])
  @@map("patent_lookup_request")
}

/// 专利缓存刷新审计（quota 观测/告警：bytesScanned 超阈可告警）。平台级、无 RLS。
model PatentCacheRefreshAudit {
  id           String    @id @default(uuid()) @db.Uuid
  startedAt    DateTime  @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  anchorCount  Int       @default(0) @map("anchor_count")
  rowCount     Int       @default(0) @map("row_count")
  bytesScanned BigInt?   @map("bytes_scanned")
  status       String    @default("RUNNING") @map("status") // RUNNING | OK | SKIPPED_EMPTY | SKIPPED_NOSCAN | DENIED | DISABLED | FAILED
  detail       String?   @map("detail")

  @@index([startedAt])
  @@map("patent_cache_refresh_audit")
}

/// 🔴 Art.17 擦除墓碑（scale-safe #89 fast-follow · Codex PR #93 P2-5）：按发明人**盲键**（不可逆，无明文名）
/// 持久记录已擦除主体，令周更刷新 upsert 前跳过——防 DSR 完成后同一 assignee 从 BigQuery 再拉回被擦除人 PII
/// 重物化（擦除即删当前缓存行只是一次性，刷新不查任何禁扫集则 Art.17 不持久）。平台级共享表（无 RLS，镜像 patent_inventor_cache）。
/// 🔴 墓碑本身即 PII 最小化：只存不可逆盲键 inventor_name_key（= inventorBlindKey 形），绝无明文名。
model PatentInventorTombstone {
  id              String   @id @default(uuid()) @db.Uuid
  inventorNameKey String   @unique @map("inventor_name_key") // 🔴 盲键（blindContactKey(foldedPersonNameKey)），与 patent_inventor_cache.inventor_name_key 同规范
  erasedAt        DateTime @default(now()) @map("erased_at")

  @@map("patent_inventor_tombstone")
}

/// ingest-once 账本（收口⑤验收：同一外部源同一时间窗**跨 workspace 只拉取一次**）。
/// 拉取键 = (providerKey, queryFingerprint, windowKey)：指纹=规范化查询参数哈希（码/国别排序去重、
/// 键序无关），窗口=对齐的时间桶（默认 6h，env SIGNAL_INGEST_WINDOW_MS）。同键已有 OK 行 → 跳过外部拉取；
/// ERROR 行可重试覆盖。querySpec 存规范化参数原文（审计 + 复算）。
model SignalIngest {
  id               String   @id @default(uuid()) @db.Uuid
  providerKey      String   @map("provider_key") // ted | openfda
  queryFingerprint String   @map("query_fingerprint") // sha256(canonical query params)
  windowKey        String   @map("window_key") // 时间桶键（如 '2026-07-11T06:00:00.000Z'）
  querySpec        Json     @map("query_spec") // 规范化查询参数（cpvCodes/countries/sinceDays…）
  recordsFetched   Int      @default(0) @map("records_fetched") // 外部 API 返回的原始记录数
  signalsUpserted  Int      @default(0) @map("signals_upserted") // 落进 source_signal 的行数（含更新）
  status           String   @default("OK") // OK | ERROR
  error            String?
  fetchedAt        DateTime @default(now()) @map("fetched_at")

  @@unique([providerKey, queryFingerprint, windowKey])
  @@index([fetchedAt])
  @@map("signal_ingest")
}

/// 一次发现执行（对应一个 READY 的查询计划）。
model DiscoveryRun {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  planId      String    @map("plan_id") @db.Uuid
  icpId       String    @map("icp_id") @db.Uuid
  status      String    @default("RUNNING") // RUNNING | DONE | PARTIAL | FAILED
  stats       Json? // 每源计数/成本/去重结果
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  rawRecords RawSourceRecord[]

  @@index([workspaceId])
  @@index([planId])
  @@map("discovery_run")
}

/// Raw Zone（PRD 8.7）：Provider 原始返回原样落地，永不直接进领域层（ADR-017）。
model RawSourceRecord {
  id            String    @id @default(uuid()) @db.Uuid
  workspaceId   String    @map("workspace_id") @db.Uuid
  runId         String    @map("run_id") @db.Uuid
  providerKey   String    @map("provider_key")
  sourceClass   String    @map("source_class")
  externalId    String?   @map("external_id") // Provider 侧 id（幂等去重）
  payload       Json
  // 公开采集留痕（PRD 8.11）：来源 URL、抓取时间、内容指纹、解析版本
  sourceUrl     String?   @map("source_url")
  fetchedAt     DateTime? @map("fetched_at")
  contentHash   String?   @map("content_hash")
  parserVersion String?   @map("parser_version")
  costCents     Int       @default(0) @map("cost_cents")
  createdAt     DateTime  @default(now()) @map("created_at")

  run DiscoveryRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, providerKey, externalId])
  @@index([workspaceId])
  @@map("raw_source_record")
}

/// Canonical 公司（PRD 8.8/8.9）：跨源归一后的目标客户公司。
/// 字段值的来源/许可/置信度在 field_evidence —— canonical 只是「当前最优视图」。
model CanonicalCompany {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  name          String
  domain        String?
  country       String?
  region        String?
  industry      String?
  employeeCount Int?     @map("employee_count")
  revenueUsd    Float?   @map("revenue_usd")
  attributes    Json? // 其余归一属性（certifications/keywords/tech/end_markets...）
  status        String   @default("NEW") // NEW | ENRICHED | SUPPRESSED
  // ICP 资格门判定（fit_verdict/fit_reasons）已迁到 Lead —— Fit 语义是「某公司 × 某 ICP」，
  // 挂在公司级会让同 workspace 后判的 ICP 读到/覆盖前判 ICP 的判定。见 Lead.fitVerdict。
  dedupeKey     String   @map("dedupe_key") // 身份解析键：域名 或 name+country 规范化
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // 存量对账下游阶段的「处理水位」（null=从未处理）。各阶段处理后**无论命中与否**写时间戳，
  // 让「已处理且未过冷却期」的行离开当批过滤集 → id 游标真正吞噬存量，预算位次后的公司不再被永久饿死。
  // 详见 backlog.eligibility.ts / backlog.activities.ts。冷却期到后自然重新入选（信号刷新/富集复核）。
  lastEnrichedAt              DateTime? @map("last_enriched_at") // 快事实富集（GLEIF/Wikidata）
  lastSignalAt                DateTime? @map("last_signal_at") // 信号富集（digital_footprint/structured_harvest）
  lastWatchAt                 DateTime? @map("last_watch_at") // web_watch 监控注册
  contactDiscoveryAttemptedAt DateTime? @map("contact_discovery_attempted_at") // 联系人发现尝试
  emailGuessAttemptedAt       DateTime? @map("email_guess_attempted_at") // 决策人邮箱猜测尝试（选项 B P0.4）

  contacts CanonicalContact[]
  leads    Lead[]

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId])
  // 下游阶段收缩集扫描：workspace + 水位列 null/过期范围（防 900+ 行 seq-scan）。
  // fit=match 现由 `leads: { some: { fitVerdict:'match' } }` 关联子查询过滤（fit 退出本表索引）。
  @@index([workspaceId, lastEnrichedAt])
  @@index([workspaceId, lastSignalAt])
  @@index([workspaceId, lastWatchAt])
  @@index([workspaceId, contactDiscoveryAttemptedAt])
  @@index([workspaceId, emailGuessAttemptedAt])
  @@map("canonical_company")
}

/// Canonical 联系人（PRD 8.9 个人分层：按需、最小化、可验证）。
model CanonicalContact {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  fullName    String   @map("full_name")
  title       String?
  seniority   String? // c_level | vp | director | manager | staff
  department  String?
  dedupeKey   String   @map("dedupe_key")
  createdAt   DateTime @default(now()) @map("created_at")

  company       CanonicalCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactPoints ContactPoint[]

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId])
  @@index([companyId])
  @@map("canonical_contact")
}

/// 联系方式（PRD 7.4/8.9）：带验证状态生命周期，发送前必须 VALID。
model ContactPoint {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  contactId   String    @map("contact_id") @db.Uuid
  type        String // email | phone | linkedin
  value       String
  status      String    @default("UNVERIFIED") // UNVERIFIED | VALID | RISKY | INVALID
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  contact CanonicalContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, type, value])
  @@index([workspaceId])
  @@map("contact_point")
}

/// 身份解析连接（PRD 8.8）：canonical 实体 ↔ raw 记录，可审计可回溯。
model IdentityLink {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  canonicalType String   @map("canonical_type") // company | contact
  canonicalId   String   @map("canonical_id") @db.Uuid
  rawRecordId   String   @map("raw_record_id") @db.Uuid
  matchRule     String   @map("match_rule") // domain_exact | name_country | provider_id
  confidence    Float    @default(1)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([canonicalId])
  @@map("identity_link")
}

/// 字段级 Evidence（PRD 7.4.9 / 8.10）：canonical 字段不只存最终值 ——
/// 每个字段的每个来源值都留痕：来源/时间/置信度/许可/允许动作。
model FieldEvidence {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  entityType     String   @map("entity_type") // company | contact
  entityId       String   @map("entity_id") @db.Uuid
  field          String
  value          Json
  providerKey    String   @map("provider_key")
  rawRecordId    String?  @map("raw_record_id") @db.Uuid
  confidence     Float?
  license        String   @default("sandbox") // sandbox | licensed | public | byo
  allowedActions Json?    @map("allowed_actions") // ['display','match','outreach']
  dataClass      String   @default("green") @map("data_class") // green（公司事实）| amber（职能邮箱 ePrivacy）| red（具名个人 GDPR Art.4）——收口⑥：替代 value JSON 里的 personal_data 代码纪律，可查询/可索引；喂 DataRightsService
  fetchedAt      DateTime @default(now()) @map("fetched_at")

  @@index([workspaceId])
  @@index([workspaceId, entityType, entityId])
  @@map("field_evidence")
}

/// Suppression（PRD 7.4 / 12.6）：禁联名单，任何对外动作前的第一道检查。
model SuppressionRecord {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  type        String // email | domain | company_name
  value       String
  reason      String? // unsubscribe | bounce | complaint | manual | legal
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([workspaceId, type, value])
  @@index([workspaceId])
  @@map("suppression_record")
}

// ── 存储侧合规（收口⑥ · ADR-010 COMPLIANCE-SCORING / ADR-003 PII-rights zone） ──

/// jurisdiction_policy（收口⑥）：DataRightsService.evaluate() 的规则数据行（含 PIPL 法域对）。
/// 平台级治理表（非租户数据，无 RLS），随 API 启动 seed（同 source_policy/data_provider）。
/// 规则 = (主体法域 × 处理地法域 × 数据分级 × 动作) → effect；'*' = 通配，最具体优先匹配。
model JurisdictionPolicy {
  id                    String   @id @default(uuid()) @db.Uuid
  subjectJurisdiction   String   @map("subject_jurisdiction") // EU | UK | US | CN | OTHER | *（数据主体法域）
  processorJurisdiction String   @map("processor_jurisdiction") // 同上；'*' = 任意处理地
  dataClass             String   @map("data_class") // green | amber | red | *
  action                String // STORE | AI_PROCESS | DERIVE | RETAIN | EXPORT | OUTREACH | VIEW | *
  effect                String // ALLOW | ALLOW_WITH_BASIS | REQUIRE_APPROVAL | DENY
  requiresLawfulBasis   Boolean  @default(false) @map("requires_lawful_basis")
  article14Required     Boolean  @default(false) @map("article14_required")
  retentionDays         Int?     @map("retention_days") // 该组合的保留期上限（RETAIN 判定用）
  ruleVersion           String   @default("v1") @map("rule_version")
  note                  String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([subjectJurisdiction, processorJurisdiction, dataClass, action, ruleVersion])
  @@map("jurisdiction_policy")
}

/// policy_decision_log（收口⑥）：DataRightsService 每次判定留痕。租户 RLS，**append-only**
///（migration REVOKE UPDATE,DELETE FROM app_user——审计不可篡改，DB 层保证非代码纪律）。
/// 🔴 内容最小化：只存 subjectId 引用 + dataClass，**绝不嵌人名/邮箱明文**。
model PolicyDecisionLog {
  id                    String   @id @default(uuid()) @db.Uuid
  workspaceId           String   @map("workspace_id") @db.Uuid
  action                String
  dataClass             String   @map("data_class")
  subjectJurisdiction   String   @map("subject_jurisdiction")
  processorJurisdiction String   @map("processor_jurisdiction")
  effect                String // ALLOW | ALLOW_WITH_BASIS | REQUIRE_APPROVAL | DENY
  allowed               Boolean
  reason                String
  ruleId                String?  @map("rule_id")
  ruleVersion           String   @map("rule_version")
  article14Required     Boolean  @default(false) @map("article14_required")
  subjectType           String?  @map("subject_type") // contact | company（引用类别，非 PII）
  subjectId             String?  @map("subject_id") @db.Uuid // 主体行 id 引用（非人名明文）
  lawfulBasisRef        String?  @map("lawful_basis_ref") // LIA/工单引用（非明文）
  actorId               String?  @map("actor_id") // 发起动作的操作者 id
  correlationId         String?  @map("correlation_id")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([workspaceId, action])
  @@map("policy_decision_log")
}

/// lia_record（收口⑥）：一等 Legitimate Interest Assessment（GDPR Art.6(1)(f) balancing test）。
/// 租户 RLS（版本化，撤回=status WITHDRAWN）。承接 platform-top-level-design §11「LIA 记录」。
model LiaRecord {
  id            String    @id @default(uuid()) @db.Uuid
  workspaceId   String    @map("workspace_id") @db.Uuid
  scope         String // 适用范围：workspace | company | contact
  scopeRef      String?   @map("scope_ref") @db.Uuid // 具体主体 id（scope 非 workspace 时）
  basis         String // legitimate_interest | consent | contract | legal_obligation
  purpose       String // 处理目的陈述
  necessityNote String?   @map("necessity_note") // 必要性论证
  balancingNote String?   @map("balancing_note") // 利益权衡结论（对数据主体影响）
  ref           String? // 外部 LIA 文档/工单引用
  recordedBy    String    @map("recorded_by") // 断言人
  version       String    @default("v1")
  status        String    @default("ACTIVE") // ACTIVE | WITHDRAWN | SUPERSEDED
  effectiveAt   DateTime  @default(now()) @map("effective_at")
  withdrawnAt   DateTime? @map("withdrawn_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([workspaceId, scope])
  @@map("lia_record")
}

/// article14_notice（收口⑥）：GDPR Art.14 间接收集透明义务记录（获取后 1 个月内 / 首次接触时告知）。
/// 租户 RLS。obligation 判定由 DataRightsService 产出，履行状态在此追踪。
model Article14Notice {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  subjectType  String    @map("subject_type") // contact
  subjectId    String    @map("subject_id") @db.Uuid // 主体行 id 引用（非人名明文）
  jurisdiction String // 主体法域（EU | UK …）
  obligation   String    @default("REQUIRED") // REQUIRED | EXEMPT（豁免：本人已知/不成比例努力 Art.14(5)）
  dueAt        DateTime  @map("due_at") // 履行截止（获取时间 + 1 个月）
  status       String    @default("PENDING") // PENDING | FULFILLED | EXEMPTED | WITHDRAWN
  fulfilledAt  DateTime? @map("fulfilled_at")
  channel      String? // 履行渠道（email | first_contact …）
  note         String?
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([workspaceId, subjectId])
  @@map("article14_notice")
}

/// deletion_request（收口⑥ PR-B，GDPR Art.17 删除编排）：DSR 删除请求状态机。租户 RLS，
/// 全 CRUD（状态转移需 UPDATE）。RECEIVED → FROZEN → ERASING → COMPLETED | FAILED。
/// subjectId = 主体行 id 引用（canonical_contact.id 或 canonical_company.id）——非人名明文。
model DeletionRequest {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  subjectType String    @map("subject_type") // contact | company
  subjectId   String    @map("subject_id") @db.Uuid
  status      String    @default("RECEIVED") // RECEIVED | FROZEN | ERASING | COMPLETED | FAILED
  requestedBy String    @map("requested_by") // 发起者（token user id，非 PII）
  requestRef  String?   @map("request_ref") // 工单/LIA/请求来源引用（可审计，非明文 PII）
  reason      String? // erasure | objection | legal | manual
  // 擦除阶段（eraseSubject 同 tx）持久化的真实计数（🔴 只计数无 PII）。completeDeletion 从此读取，
  // 使「擦除已提交但 complete 后续失败 → 人工重跑（located 重算为空）」仍能写出忠实回执，不伪造 0。
  stats       Json?
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  receipt DeletionReceipt?

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, subjectType, subjectId])
  // 「同主体至多一条在途请求」的部分唯一索引（WHERE status IN active）由 migration 裸 SQL 维护
  // （Prisma 尚不支持部分唯一索引）——DB 层防 createRequest find-then-create 并发竞态产生重复请求/回执。
  @@map("deletion_request")
}

/// deletion_receipt（收口⑥ PR-B）：删除完成证明。租户 RLS，**append-only**（migration
/// REVOKE UPDATE,DELETE FROM app_user——擦除问责证据不可篡改，GDPR Art.5(2)；DB 层保证非代码纪律）。
/// 🔴 内容最小化：只存**计数** + 主体 id 引用，绝不嵌人名/邮箱明文。
model DeletionReceipt {
  id                    String   @id @default(uuid()) @db.Uuid
  workspaceId           String   @map("workspace_id") @db.Uuid
  deletionRequestId     String   @unique @map("deletion_request_id") @db.Uuid
  subjectType           String   @map("subject_type")
  subjectId             String   @map("subject_id") @db.Uuid
  contactsErased        Int      @default(0) @map("contacts_erased")
  contactPointsErased   Int      @default(0) @map("contact_points_erased")
  fieldEvidenceErased   Int      @default(0) @map("field_evidence_erased")
  signalsRevoked        Int      @default(0) @map("signals_revoked")
  companiesSuppressed   Int      @default(0) @map("companies_suppressed")
  leadsRescoreRequested Int      @default(0) @map("leads_rescore_requested")
  patentCacheErased     Int      @default(0) @map("patent_cache_erased") // 平台专利发明人缓存按盲键命中删的行数（Art.17 扫描面审计，scale-safe #89）
  ruleVersion           String   @map("rule_version")
  createdAt             DateTime @default(now()) @map("created_at")

  // onDelete: Restrict——回执在则父 deletion_request 不可删（防级联删绕过 receipt 的 append-only：
  // PG 级联删以属主身份执行、绕过子表 REVOKE DELETE）。回执成为其父的「锚」，问责证据不可被删父带走。
  request DeletionRequest @relation(fields: [deletionRequestId], references: [id], onDelete: Restrict)

  @@index([workspaceId])
  @@map("deletion_receipt")
}

// ── Lead & 验证评分 (PRD 7.5 LED-006..009 / 5.6) ───────────────────────────

/// Lead 状态机（PRD 11.9）：DISCOVERED → ENRICHING → REVIEW →
/// QUALIFIED/REJECTED/SUPPRESSED → CONTACTED → CONVERTED
enum LeadStatus {
  DISCOVERED
  ENRICHING
  REVIEW
  QUALIFIED
  REJECTED
  SUPPRESSED
  CONTACTED
  CONVERTED

  @@map("lead_status")
}

/// Lead = 「这家公司 × 这个 ICP」的可跟进机会。评分是确定性计算
/// （规则引擎 + 数据质量），AI 只在上游提议规则 —— 分数可复算可审计。
model Lead {
  id                 String     @id @default(uuid()) @db.Uuid
  workspaceId        String     @map("workspace_id") @db.Uuid
  icpId              String     @map("icp_id") @db.Uuid
  canonicalCompanyId String     @map("canonical_company_id") @db.Uuid
  status             LeadStatus @default(DISCOVERED)
  /// ICP 资格门（LLM 四门）判定：match | weak | mismatch | null(未判)。
  /// 语义 = 「这家公司 × 这个 ICP」的 Fit —— 从 CanonicalCompany 迁来，随 (workspace, icp, company)
  /// 唯一键独立存储，同 workspace 多 ICP 互不覆盖。判定由 qualifyFit* 写；评分阶段只读、不覆盖。
  fitVerdict         String?    @map("fit_verdict")
  /// 四门判定绑定证据（材质/角色(竞品)/工艺子集/商业模式 + reasons）。
  fitReasons         Json?      @map("fit_reasons")
  /// 四队列（LED-008）：recommended | needs_review | rejected | suppressed
  queue              String     @default("needs_review")
  totalScore         Float?     @map("total_score")
  /// 六维分（LED-006）：{fit, role, intent, dataQuality, reachability, engagement}
  scores             Json?
  /// 评分依据：规则逐条评估结果 + 各维输入（审计/申诉用）
  scoreDetail        Json?      @map("score_detail")
  version            Int        @default(1)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  canonicalCompany CanonicalCompany @relation(fields: [canonicalCompanyId], references: [id], onDelete: Cascade)
  decisions        LeadDecision[]

  @@unique([workspaceId, icpId, canonicalCompanyId])
  @@index([workspaceId])
  @@index([workspaceId, queue])
  // 下游阶段按「本 ICP 的 match」关联过滤 canonical（leads.some）+ qualify 查询「已判 Lead」。
  @@index([workspaceId, icpId, fitVerdict])
  @@map("lead")
}

/// 人工裁决（LED-009）：接受/拒绝 + 原因，回流做质量反馈。
model LeadDecision {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  leadId      String   @map("lead_id") @db.Uuid
  action      String // accept | reject
  reason      String?
  decidedBy   String   @map("decided_by") // 外部平台 user id（来自 token）
  createdAt   DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([leadId])
  @@map("lead_decision")
}

// ── ICP & Buying Committee (理想客户画像, PRD 7.5 / 5.4) ────────────────────

/// ICP lifecycle (PRD 11.9): DRAFT → HYPOTHESIS → VALIDATING → ACTIVE → SUPERSEDED → ARCHIVED
enum IcpStatus {
  DRAFT
  HYPOTHESIS
  VALIDATING
  ACTIVE
  SUPERSEDED
  ARCHIVED

  @@map("icp_status")
}

model IcpDefinition {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String    @map("workspace_id") @db.Uuid
  companyId         String    @map("company_id") @db.Uuid // the seller company this ICP is for
  name              String
  status            IcpStatus @default(DRAFT)
  companyAttributes Json?     @map("company_attributes") // industry / size / geo / tech ...
  painPoints        Json?     @map("pain_points") // string[]
  triggerSignals    Json?     @map("trigger_signals") // string[] 采购触发信号
  exclusions        Json? // string[] 排除条件（优先于正向评分）
  valueProps        Json?     @map("value_props") // string[]
  targetMarkets     Json?     @map("target_markets") // string[]
  version           Int       @default(1)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company    CompanyProfile        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  personas   Persona[]
  roles      BuyingCommitteeRole[]
  rules      QualificationRule[]
  backtests  IcpBacktest[]
  queryPlans DiscoveryQueryPlan[]

  @@index([workspaceId])
  @@index([companyId])
  @@map("icp_definition")
}

/// 结构化验证规则（LED-003）：机器可评估，是 ICP 从「描述」变「可执行」的桥。
/// EXCLUSION 永远优先于正向评分（PRD 7.5）。
enum RuleKind {
  MUST_HAVE
  NICE_TO_HAVE
  EXCLUSION

  @@map("rule_kind")
}

model QualificationRule {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  icpId       String   @map("icp_id") @db.Uuid
  kind        RuleKind
  field       String // canonical 属性名：industry/region/country/employee_count/certifications/keywords/tech ...
  operator    String // eq | neq | in | not_in | gte | lte | contains | not_contains | matches
  value       Json // 操作数（标量或数组）
  weight      Float    @default(1) // NICE_TO_HAVE 计分权重
  rationale   String? // 该规则的依据（来自 AI 生成或人工），保持推断透明
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("qualification_rule")
}

/// ICP 样例回测（LED-004）：用已知客户/非客户样例验证规则命中，
/// 是 HYPOTHESIS → VALIDATING → ACTIVE 的数据依据。
model IcpBacktest {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  icpId       String   @map("icp_id") @db.Uuid
  samples     Json // [{name, domain?, attributes, expected: 'match'|'exclude'}]
  results     Json // 逐样例 {verdict, ruleOutcomes[], score}
  metrics     Json // {matchHitRate, excludeCatchRate, unknownFieldRate, recommendation}
  createdAt   DateTime @default(now()) @map("created_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("icp_backtest")
}

/// 多源查询计划（LED-005）：把 ICP 翻译成各数据源的可执行查询（Discover 的输入）。
model DiscoveryQueryPlan {
  id                 String   @id @default(uuid()) @db.Uuid
  workspaceId        String   @map("workspace_id") @db.Uuid
  icpId              String   @map("icp_id") @db.Uuid
  status             String   @default("DRAFT") // DRAFT | READY | EXECUTED
  queries            Json // [{source, sourceClass, filters, keywords, rationale, priority}]
  estimatedVolume    Int?     @map("estimated_volume")
  estimatedCostCents Int?     @map("estimated_cost_cents")
  version            Int      @default(1)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("discovery_query_plan")
}

model Persona {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  icpId       String   @map("icp_id") @db.Uuid
  title       String // 角色/职位名
  goals       Json? // string[]
  painPoints  Json?    @map("pain_points") // string[]
  createdAt   DateTime @default(now()) @map("created_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("persona")
}

model BuyingCommitteeRole {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  icpId       String   @map("icp_id") @db.Uuid
  role        String // decision_maker | influencer | user | technical | finance | procurement
  title       String? // 典型职位
  concerns    Json? // string[] 关注点/异议
  createdAt   DateTime @default(now()) @map("created_at")

  icp IcpDefinition @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([icpId])
  @@map("buying_committee_role")
}

// ── Site builder（独立站建设，docs/site-builder/02 §2）───────────────────────
// 全部 workspace_id + RLS。brand_profile 随 M1（精装修 P1）、inquiry 随 M2 落表。

/// 站点：每 workspace 可多站（v1 业务限 1 站）。slug 全局唯一（承载预览子域）。
model Site {
  id               String   @id @default(uuid()) @db.Uuid
  workspaceId      String   @map("workspace_id") @db.Uuid
  name             String // 站点名（默认=公司英文名）
  slug             String // 预览子域 slug（随机不可枚举，06 §7）
  mode             String   @default("builder") // builder | diagnosis(M3)
  status           String   @default("draft") // draft | building | ready | published
  stylePreset      String?  @map("style_preset")
  locales          Json     @default("[\"en\"]") // string[]，BCP-47
  activeVersionId  String?  @map("active_version_id") @db.Uuid // 指针式发布/回滚（05 §4）
  intake           Json // 注册引导 6 项原始提交（01 §2）
  profile          Json? // 建站向导五组（companyProfile/trustAssets/onlineAssets/brand/contact）
  profileVersionId String   @default(dbgenerated("gen_random_uuid()")) @map("profile_version_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  versions                SiteVersion[]
  buildRuns               SiteBuildRun[]
  assets                  Asset[]
  documents               KbDocument[]
  brandProfiles           BrandProfile[]
  evidenceSourceSnapshots SiteEvidenceSourceSnapshot[]

  @@unique([slug])
  @@unique([id, workspaceId], map: "site_id_workspace_id_key")
  @@index([workspaceId])
  @@map("site")
}

/// 站点版本：spec=SiteSpec（04 契约），回滚=切 site.active_version_id 指针。
model SiteVersion {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  siteId      String   @map("site_id") @db.Uuid
  version     Int // 站内递增
  source      String   @default("build") // demo_v0 | build | manual
  spec        Json // SiteSpec（结构+textKey；文案在 CopyBundle 内嵌 per-locale）
  specVersion String   @map("spec_version") // 契约 semver（04 §8 迁移）
  artifactKey String?  @map("artifact_key") // 对象存储构建产物前缀
  buildStatus String   @default("pending") @map("build_status") // pending | building | succeeded | failed
  buildRunId  String?  @map("build_run_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, version])
  @@index([workspaceId])
  @@map("site_version")
}

/// 一次生成管线运行（demo v0 或精装修），进度/成本/错误供前端轮询与 SSE。
model SiteBuildRun {
  id                 String    @id @default(uuid()) @db.Uuid
  workspaceId        String    @map("workspace_id") @db.Uuid
  siteId             String    @map("site_id") @db.Uuid
  kind               String    @default("demo_v0") // demo_v0 | refurbish(M1)
  scope              Json? // { scope: site|page|section, targetId?, options? }
  status             String    @default("queued") // queued | running | succeeded | failed | cancelled
  phase              String? // P1_understanding … P5_publish（02 §4）
  progress           Float     @default(0)
  steps              Json? // 步骤明细 [{key,status,at}]
  costSummary        Json?     @map("cost_summary") // 预算 reserve-settle 汇总
  temporalWorkflowId String?   @map("temporal_workflow_id")
  temporalRunId      String?   @map("temporal_run_id")
  error              String?
  startedAt          DateTime? @map("started_at")
  finishedAt         DateTime? @map("finished_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  site Site @relation(fields: [siteId, workspaceId], references: [id, workspaceId], onDelete: Cascade, onUpdate: NoAction)
  stepRecords SiteBuildStep[]

  @@unique([id, workspaceId])
  @@index([workspaceId, siteId])
  @@map("site_build_run")
}

/// Build progress source of truth. SiteBuildRun.steps is the bounded public read model.
model SiteBuildStep {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  buildRunId  String    @map("build_run_id") @db.Uuid
  key         String
  itemKey     String    @default("") @map("item_key")
  attempt     Int       @default(1)
  status      String // queued | running | done | degraded | failed | skipped | aborted
  phase       String
  progress    Float
  degraded    Boolean   @default(false)
  errorCode   String?   @map("error_code")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  buildRun SiteBuildRun @relation(fields: [buildRunId, workspaceId], references: [id, workspaceId], onDelete: Cascade, onUpdate: NoAction)

  @@unique([buildRunId, key, itemKey, attempt])
  @@index([workspaceId, buildRunId])
  @@map("site_build_step")
}

/// 素材：presign→PUT 直传→commit 三步（07 §3）。active object_key 由部分唯一索引守护。
model Asset {
  id                   String    @id @default(uuid()) @db.Uuid
  workspaceId          String    @map("workspace_id") @db.Uuid
  siteId               String    @map("site_id") @db.Uuid
  kind                 String // logo | product_image | factory_image | cert | doc | video | generated
  filename             String // 原始文件名（展示用，不参与 key）
  mime                 String
  sizeBytes            Int       @map("size_bytes")
  objectKey            String    @map("object_key") // staging 或 ws/{workspace}/{site}/{kind}/{content_hash}.{ext}
  contentHash          String?   @map("content_hash") // sha256，commit 校验后回填
  derivedKeys          Json?     @map("derived_keys") // 多尺寸 webp/avif 等派生产物
  processingStatus     String    @default("pending_upload") @map("processing_status") // pending_upload | committing | queued | processing | ready | failed | failed_retryable | rejected | duplicate | deleted
  processingAttempt    Int       @default(0) @map("processing_attempt")
  leaseToken           String?   @map("lease_token") @db.Uuid // 每次 commit 认领的新 fencing token
  leaseUntil           DateTime? @map("lease_until")
  retryAt              DateTime? @map("retry_at")
  processingErrorCode  String?   @map("processing_error_code")
  deletedAt            DateTime? @map("deleted_at") // tombstone；canonical 清理由 MF-0 scanner 后的消费者执行
  cleanupEventId       String?   @map("cleanup_event_id") @db.Uuid // 部分唯一索引见 MF0-B migration
  cleanupCompletedAt   DateTime? @map("cleanup_completed_at") // canonical 对象与冻结 variants 均确认删除后的 durable settle；staging 完成态由 Temporal execution 记录
  cleanupLegacyUnbound Boolean   @default(false) @map("cleanup_legacy_unbound") // migration 前 tombstone 隔离标记；新写不得置 true
  meta                 Json? // 尺寸/EXIF 已剥离标记/来源等
  error                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  site        Site           @relation(fields: [siteId, workspaceId], references: [id, workspaceId], onDelete: Cascade, onUpdate: Cascade, map: "asset_site_workspace_fkey")
  kbDocuments KbDocument[]
  variants    AssetVariant[]

  @@unique([id, workspaceId, siteId], map: "asset_id_workspace_id_site_id_key")
  // active object_key 的唯一性由 migration 中 WHERE deleted_at IS NULL 的部分唯一索引保证。
  @@index([objectKey], map: "asset_object_key_lookup_idx")
  @@index([workspaceId, siteId, kind])
  @@index([workspaceId, processingStatus, retryAt])
  @@map("asset")
}

/// MF-0 可发布派生物：每行是一个确定性 recipe 的单一物化输出。
/// Asset 是逻辑素材/原件；derivedKeys 仅是由本表投影的短期兼容视图。
model AssetVariant {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  siteId          String   @map("site_id") @db.Uuid
  assetId         String   @map("asset_id") @db.Uuid
  variantType     String   @map("variant_type") // hero | card | thumb | logo；后续媒体角色可扩展
  mime            String
  width           Int?
  height          Int?
  durationMs      Int?     @map("duration_ms")
  bitrateKbps     Int?     @map("bitrate_kbps")
  sizeBytes       Int?     @map("size_bytes")
  objectKey       String   @map("object_key")
  contentHash     String?  @map("content_hash") // ready 时必填，sha256 lowercase hex
  pipelineVersion String   @map("pipeline_version")
  recipeHash      String   @map("recipe_hash") // 单个输出 recipe 的 sha256
  sourceVariantId String?  @map("source_variant_id") @db.Uuid
  status          String   @default("processing") // processing | ready | failed
  error           String?
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  asset           Asset          @relation(fields: [assetId, workspaceId, siteId], references: [id, workspaceId, siteId], onDelete: Cascade, onUpdate: Cascade, map: "asset_variant_asset_scope_fkey")
  sourceVariant   AssetVariant?  @relation("AssetVariantSource", fields: [sourceVariantId, workspaceId, siteId, assetId], references: [id, workspaceId, siteId, assetId], onDelete: NoAction, onUpdate: NoAction, map: "asset_variant_source_scope_fkey")
  derivedVariants AssetVariant[] @relation("AssetVariantSource")

  @@unique([assetId, recipeHash], map: "asset_variant_asset_id_recipe_hash_key")
  @@unique([objectKey], map: "asset_variant_object_key_key")
  @@unique([id, workspaceId, siteId, assetId], map: "asset_variant_id_workspace_site_asset_key")
  @@index([workspaceId, siteId, assetId, status], map: "asset_variant_workspace_site_asset_status_idx")
  @@index([sourceVariantId], map: "asset_variant_source_variant_id_idx")
  @@map("asset_variant")
}

/// 知识库文档（02 §12）：Docling 解析 → 结构感知切块 → 向量化。删除=chunk 级联（分租户护栏②）。
model KbDocument {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  siteId      String   @map("site_id") @db.Uuid
  assetId     String?  @unique(map: "kb_document_asset_id_key") @map("asset_id") @db.Uuid // upload 来源对应素材
  source      String // intake | wizard | upload | storefront | web_research
  title       String
  lang        String?
  status      String   @default("queued") // queued | parsing | chunking | embedding | ready | failed
  parsedMeta  Json?    @map("parsed_meta") // Docling 结构摘要（页/表格/标题树）
  chunkCount  Int      @default(0) @map("chunk_count")
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site   Site      @relation(fields: [siteId, workspaceId], references: [id, workspaceId], onDelete: Cascade, onUpdate: Cascade, map: "kb_document_site_workspace_fkey")
  asset  Asset?    @relation(fields: [assetId, workspaceId, siteId], references: [id, workspaceId, siteId], onDelete: Cascade, onUpdate: Cascade, map: "kb_document_asset_scope_fkey")
  chunks KbChunk[]

  @@unique([id, workspaceId], map: "kb_document_id_workspace_id_key")
  @@index([workspaceId, siteId])
  @@map("kb_document")
}

/// 知识库切块：embedding vector(1024)=BGE-M3（D14）；行上记模型+版本，换模型按版本重嵌不混空间。
model KbChunk {
  id           String                       @id @default(uuid()) @db.Uuid
  workspaceId  String                       @map("workspace_id") @db.Uuid
  documentId   String                       @map("document_id") @db.Uuid
  seq          Int
  text         String
  meta         Json? // 章节路径/页码/表格标记（结构感知切块产物）
  embedModel   String                       @map("embed_model") // bge-m3
  embedVersion String                       @map("embed_version") // 模型版本标签
  embedding    Unsupported("vector(1024)")?
  createdAt    DateTime                     @default(now()) @map("created_at")

  document KbDocument @relation(fields: [documentId, workspaceId], references: [id, workspaceId], onDelete: Cascade, onUpdate: Cascade, map: "kb_chunk_document_workspace_fkey")

  @@unique([documentId, seq])
  @@index([workspaceId])
  @@map("kb_chunk")
}

/// P1 理解产物（09 §2.1，M1）：品牌事实/语调/术语，版本化追加不覆盖。
/// 🔴 v1 factSheet 保留 inline citation；v2 每项由 EvidenceRefV2 + 不可变关系行精确绑定冻结 source/hash/quote。
model BrandProfile {
  id                    String   @id @default(uuid()) @db.Uuid
  workspaceId           String   @map("workspace_id") @db.Uuid
  siteId                String   @map("site_id") @db.Uuid
  version               Int // 站内递增（brandProfile 每次重跑追加新版本）
  valueProps            Json?    @map("value_props")
  tone                  Json?
  glossary              Json?
  keywords              Json?
  differentiators       Json?
  competitors           Json?
  factSheet             Json?    @map("fact_sheet")
  gaps                  Json? // 待补资料清单 → GET /sites/{id}/kb/status
  researchDegraded      Boolean  @default(false) @map("research_degraded") // web 研究失败仅 KB 出 Brief
  evidenceSchemaVersion Int      @default(1) @map("evidence_schema_version") // 1=legacy inline citation; 2=EvidenceRef frozen provenance
  createdAt             DateTime @default(now()) @map("created_at")

  site         Site                      @relation(fields: [siteId, workspaceId], references: [id, workspaceId], onDelete: Cascade, onUpdate: NoAction, map: "brand_profile_site_workspace_fkey")
  evidenceRefs BrandProfileEvidenceRef[]

  @@unique([siteId, version])
  @@unique([id, workspaceId, siteId], map: "brand_profile_id_workspace_site_key")
  @@index([workspaceId])
  @@map("brand_profile")
}

/// Evidence 2.0 immutable model-visible corpus, scrubbed and bounded before hashing.
model SiteEvidenceSourceSnapshot {
  id                   String    @id @default(uuid()) @db.Uuid
  workspaceId          String    @map("workspace_id") @db.Uuid
  siteId               String    @map("site_id") @db.Uuid
  sourceKey            String    @map("source_key")
  sourceType           String    @map("source_type") // intake | upload | storefront | web_research
  sourceRole           String    @map("source_role") // fact_candidate | research_hint
  hashAlgorithm        String    @default("sha256") @map("hash_algorithm")
  contentHash          String    @map("content_hash") // frozen snapshot_text SHA-256
  upstreamContentHash  String?   @map("upstream_content_hash") // object/crawl/chunk upstream hash, never substituted for content_hash
  normalizationVersion String    @map("normalization_version")
  snapshotText         String    @map("snapshot_text")
  displayUrl           String?   @map("display_url")
  fetchedAt            DateTime? @map("fetched_at")
  provenance           Json
  dedupeKey            String    @map("dedupe_key")
  createdAt            DateTime  @default(now()) @map("created_at")

  site         Site                      @relation(fields: [siteId, workspaceId], references: [id, workspaceId], onDelete: Cascade, onUpdate: NoAction, map: "site_evidence_source_snapshot_site_scope_fkey")
  evidenceRefs BrandProfileEvidenceRef[]

  @@unique([siteId, dedupeKey], map: "site_evidence_source_snapshot_site_dedupe_key")
  @@unique([id, workspaceId, siteId, contentHash], map: "site_evidence_source_snapshot_scope_hash_key")
  @@index([workspaceId, siteId, sourceType], map: "site_evidence_source_snapshot_workspace_site_type_idx")
  @@map("site_evidence_source_snapshot")
}

/// Fact-level immutable binding from a BrandProfile v2 fact to its exact frozen source quote.
model BrandProfileEvidenceRef {
  id                String   @id @default(uuid()) @db.Uuid
  workspaceId       String   @map("workspace_id") @db.Uuid
  siteId            String   @map("site_id") @db.Uuid
  brandProfileId    String   @map("brand_profile_id") @db.Uuid
  factIndex         Int      @map("fact_index")
  factKey           String   @map("fact_key")
  sourceSnapshotId  String   @map("source_snapshot_id") @db.Uuid
  sourceContentHash String   @map("source_content_hash")
  quote             String
  quoteStart        Int      @map("quote_start")
  quoteEnd          Int      @map("quote_end")
  quotePrefix       String?  @map("quote_prefix")
  quoteSuffix       String?  @map("quote_suffix")
  createdAt         DateTime @default(now()) @map("created_at")

  brandProfile   BrandProfile               @relation(fields: [brandProfileId, workspaceId, siteId], references: [id, workspaceId, siteId], onDelete: Cascade, onUpdate: NoAction, map: "brand_profile_evidence_ref_profile_scope_fkey")
  sourceSnapshot SiteEvidenceSourceSnapshot @relation(fields: [sourceSnapshotId, workspaceId, siteId, sourceContentHash], references: [id, workspaceId, siteId, contentHash], onDelete: NoAction, onUpdate: NoAction, map: "brand_profile_evidence_ref_source_scope_hash_fkey")

  @@unique([brandProfileId, factIndex], map: "brand_profile_evidence_ref_profile_fact_key")
  @@index([workspaceId, siteId, sourceSnapshotId], map: "brand_profile_evidence_ref_workspace_site_source_idx")
  @@map("brand_profile_evidence_ref")
}
