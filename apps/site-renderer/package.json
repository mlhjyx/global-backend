{
  "name": "@global/site-renderer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "SiteSpec(04 契约) -> 静态站渲染器：Astro 构建，主题 token 驱动，组件封闭枚举",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "test": "vitest run",
    "test:visual": "playwright test && node scripts/verify-component-qualification-visuals.mjs && node scripts/verify-m1eb-golden-visuals.mjs",
    "test:visual:update": "playwright test --update-snapshots && COMPONENT_QUALIFICATION_UPDATE_SNAPSHOTS=1 node scripts/verify-component-qualification-visuals.mjs && M1EB_GOLDEN_UPDATE_SNAPSHOTS=1 node scripts/verify-m1eb-golden-visuals.mjs"
  },
  "dependencies": {
    "@fontsource/bricolage-grotesque": "^5.2.0",
    "@fontsource/noto-sans": "5.3.0",
    "@fontsource/noto-sans-arabic": "5.3.0",
    "@fontsource-variable/archivo": "^5.2.0",
    "@fontsource-variable/inter": "^5.2.0",
    "@fontsource/fraunces": "^5.2.0",
    "@fontsource/urbanist": "^5.2.0",
    "@fontsource/jetbrains-mono": "^5.2.0",
    "@fontsource/instrument-serif": "^5.2.0",
    "@global/contracts": "workspace:*",
    "astro": "^5.7.0",
    "remixicon": "^4.6.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "vitest": "^4.1.10"
  }
}
