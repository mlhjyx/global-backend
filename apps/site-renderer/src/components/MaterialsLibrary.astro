---
import { createRequire } from 'node:module';
import ControlledAssetPicture from './ControlledAssetPicture.astro';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Paper { no: string | number; nameKey: string; weightKey: string; noteKey: string; asset?: { assetId: string; altKey?: string; variantUrl?: string } }
interface Props { eyebrowKey:string; titleKey:string; titleAccentKey:string; introKey:string; items:Paper[]; ctaPrimaryLabelKey:string; ctaPrimaryPageId?:string; ctaSecondaryLabelKey:string; ctaSecondaryPageId?:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; alt?:boolean; locale:string; defaultLocale:string; instanceId:string; pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { eyebrowKey,titleKey,titleAccentKey,introKey,items,ctaPrimaryLabelKey,ctaPrimaryPageId='contact',ctaSecondaryLabelKey,ctaSecondaryPageId='contact',variant='technical-grid',t,alt,locale,defaultLocale,instanceId,pagePathById={} }=Astro.props;
const content={eyebrow:t(eyebrowKey),title:t(titleKey),accent:t(titleAccentKey),intro:t(introKey),items:items.map((item)=>({no:String(item.no),name:t(item.nameKey),weight:t(item.weightKey),note:t(item.noteKey),alt:item.asset?.altKey?t(item.asset.altKey):t(item.nameKey)})),primaryCta:t(ctaPrimaryLabelKey),secondaryCta:t(ctaSecondaryLabelKey)};
assertQualifiedComponentContentBudget('MaterialsLibrary',content);
const headingId=`${instanceId}-materials-library-heading`;
const primaryHref=localeQualifiedPageHref(ctaPrimaryPageId,pagePathById,locale,defaultLocale);
const secondaryHref=localeQualifiedPageHref(ctaSecondaryPageId,pagePathById,locale,defaultLocale);
---
<section class:list={['block','materials-library',`materials-library--${variant}`,{alt}]} data-component="MaterialsLibrary" data-variant={variant} aria-labelledby={headingId}><div class="container"><header class="head"><div><span class="eyebrow">{content.eyebrow}</span><h2 id={headingId}>{content.title} <em>{content.accent}</em></h2></div><p>{content.intro}</p></header><ul class="grid">{items.map((item,index)=><li><article class="paper"><div class="media">{item.asset?<ControlledAssetPicture assetId={item.asset.assetId} variantUrl={item.asset.variantUrl} alt={content.items[index]!.alt} width={800} height={640}/>:<span class="fallback" aria-hidden="true">{content.items[index]!.no}</span>}</div><div class="meta"><h3>{content.items[index]!.name}</h3><p class="weight">{content.items[index]!.weight}</p><p>{content.items[index]!.note}</p></div></article></li>)}</ul><div class="ctas"><a class="primary" href={primaryHref}>{content.primaryCta}<i class="ri-arrow-right-line" aria-hidden="true"></i></a><a class="secondary" href={secondaryHref}>{content.secondaryCta}<i class="ri-arrow-right-line" aria-hidden="true"></i></a></div></div></section>
<style>.materials-library--technical-grid{background-image:linear-gradient(color-mix(in srgb,var(--c-border) 35%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.head{display:grid;gap:1.25rem;margin-bottom:2rem}.head h2{margin-top:.6rem;font-size:clamp(2rem,4vw,3.4rem)}.head h2 em{font-style:normal;color:var(--c-accent)}.eyebrow,.weight{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--c-on-surface-muted)}.head>p{max-width:38rem;color:var(--c-on-surface-muted)}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,15rem),1fr));gap:1rem;list-style:none;margin:0;padding:0}.paper{height:100%;border:1px solid var(--c-border);background:var(--c-surface)}.media{aspect-ratio:5/4;display:grid;place-items:center;overflow:hidden;background:var(--c-surface-alt)}.media picture,.media img{display:block;width:100%;height:100%;object-fit:cover}.fallback{font-family:var(--font-heading);font-size:1.5rem;color:var(--c-primary)}.meta{padding:1rem}.meta h3{font-size:1.1rem}.meta p:last-child{margin-top:.6rem;font-size:.9rem;color:var(--c-on-surface-muted)}.ctas{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:2rem}.ctas a{display:inline-flex;align-items:center;gap:.4rem;min-height:2.75rem;padding:.5rem .9rem}.primary{background:var(--c-primary);color:var(--c-on-primary)}.secondary{border:1px solid var(--c-border)}.materials-library--quiet{background:var(--c-surface-alt)}@media(min-width:768px){.head{grid-template-columns:1.3fr 1fr;align-items:end}}</style>
