---
import { createRequire } from 'node:module';
interface Item { cat:string; titleKey:string; descKey:string; readTime:string }
interface Props { eyebrowKey:string; titleKey:string; titleLine2Key:string; introKey:string; items:Item[]; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; alt?:boolean; instanceId:string }
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');
const {eyebrowKey,titleKey,titleLine2Key,introKey,items,variant='technical-grid',t,alt,instanceId}=Astro.props;const eyebrow=t(eyebrowKey),title=t(titleKey),titleLine2=t(titleLine2Key),intro=t(introKey);const articles=items.map((item)=>({category:item.cat,title:t(item.titleKey),description:t(item.descKey),readTime:item.readTime}));assertQualifiedComponentContentBudget('ArticleGrid',{eyebrow,title,titleLine2,intro,articles});const headingId=`${instanceId}-article-grid-heading`;
---
<section class:list={['block','article-grid',`article-grid--${variant}`,{alt}]} data-component="ArticleGrid" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><span class="eyebrow">{eyebrow}</span><h2 id={headingId}>{title}<br />{titleLine2}</h2><p class="muted">{intro}</p></header><div class="grid">{articles.map((article)=><article><p class="category">{article.category}</p><h3>{article.title}</h3><p class="muted">{article.description}</p><p class="time">{article.readTime}</p></article>)}</div></div></section>
<style>header{display:grid;gap:1rem;margin-bottom:2.5rem}h2{font-size:clamp(2rem,5vw,3.5rem);line-height:1.1}.grid{display:grid;grid-template-columns:1fr;gap:1.25rem}@media(min-width:640px){.grid{grid-template-columns:repeat(2,1fr)}}@media(min-width:1024px){.grid{grid-template-columns:repeat(3,1fr)}}.grid article{padding:1.5rem;border:1px solid var(--c-border);border-radius:var(--radius-lg);background:var(--c-surface)}.article-grid--technical-grid article{background:linear-gradient(var(--c-surface-alt) 1px,transparent 1px),linear-gradient(90deg,var(--c-surface-alt) 1px,transparent 1px),var(--c-surface);background-size:1rem 1rem}.category,.time{font-size:.75rem;text-transform:uppercase;letter-spacing:.12em;color:var(--c-on-surface-muted)}h3{margin-top:1rem;font-size:1.2rem}.muted{margin-top:.75rem}.time{margin-top:1.25rem}</style>
