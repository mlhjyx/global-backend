---
import { createRequire } from 'node:module';
import ControlledAssetPicture from './ControlledAssetPicture.astro';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface GalleryItem {assetId:string;altKey?:string;variantUrl?:string} interface Props {eyebrowKey:string;titleKey:string;titleAccentKey:string;allLabelKey?:string;allPageId?:string;itemCount?:number;items?:GalleryItem[];variant?:'technical-grid'|'quiet';t:(key:string)=>string;alt?:boolean;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string>}
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {eyebrowKey,titleKey,titleAccentKey,allLabelKey,allPageId='gallery',itemCount=4,items,variant='technical-grid',t,alt,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;const records=items?.length?items:Array.from({length:itemCount},(_,index)=>({assetId:`fallback-${index+1}`}));const content={eyebrow:t(eyebrowKey),title:t(titleKey),accent:t(titleAccentKey),cta:allLabelKey?t(allLabelKey):undefined,items:records.map((item)=>({alt:item.altKey?t(item.altKey):item.assetId}))};assertQualifiedComponentContentBudget('PhotoGallery',content);const headingId=`${instanceId}-photo-gallery-heading`;const allHref=content.cta?localeQualifiedPageHref(allPageId,pagePathById,locale,defaultLocale):undefined;
---
<section class:list={['block','photo-gallery',`photo-gallery--${variant}`,{alt}]} data-component="PhotoGallery" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><div><p class="eyebrow">{content.eyebrow}</p><h2 id={headingId}>{content.title} <em>{content.accent}</em></h2></div>{allHref&&<a href={allHref}>{content.cta}<span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a>}</header><ul class="grid">{records.map((item,index)=><li class:list={{tall:index===1}}><figure>{item.assetId.startsWith('fallback-')?<span class="fallback" aria-hidden="true">{String(index+1).padStart(2,'0')}</span>:<ControlledAssetPicture assetId={item.assetId} variantUrl={item.variantUrl} alt={content.items[index]!.alt} width={960} height={720}/>}<figcaption>{content.items[index]!.alt}</figcaption></figure></li>)}</ul></div></section>
<style>.photo-gallery--technical-grid{background-image:linear-gradient(color-mix(in srgb,var(--c-border) 27%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{display:flex;justify-content:space-between;align-items:end;gap:1rem;flex-wrap:wrap;margin-bottom:2rem}.eyebrow{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{margin-top:.75rem;max-width:16ch;font-size:clamp(2.25rem,5vw,4rem);line-height:1}h2 em{font-style:italic}header a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;border:1px solid var(--c-border);color:var(--c-on-surface)}header a:hover,header a:focus-visible{background:var(--c-on-surface);color:var(--c-surface)}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.75rem;list-style:none;margin:0;padding:0}@media(min-width:1024px){.grid{grid-template-columns:repeat(4,1fr)}.tall{grid-row:span 2}}figure{height:100%;min-height:14rem;position:relative;overflow:hidden;margin:0;background:linear-gradient(145deg,var(--c-surface-alt),color-mix(in srgb,var(--c-secondary) 13%,var(--c-surface-alt)));display:grid;place-items:center}.tall figure{min-height:29rem}picture,img{display:block;width:100%;height:100%;position:absolute;inset:0;object-fit:cover}.fallback{font-size:1.5rem;color:var(--c-primary)}figcaption{position:absolute;z-index:1;left:.75rem;bottom:.75rem;max-width:calc(100% - 1.5rem);padding:.3rem .5rem;background:color-mix(in srgb,var(--c-surface) 90%,transparent);font-size:.75rem}.photo-gallery--quiet{background:var(--c-surface-alt)}</style>
