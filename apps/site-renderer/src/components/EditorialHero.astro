---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';

interface Props {
  eyebrowKey: string; headlineKey: string; ctaLabelKey: string; ctaPageId?: string;
  statusKey: string; scrollKey: string; variant?: 'technical-grid' | 'quiet';
  t: (key: string) => string; locale: string; defaultLocale: string;
  instanceId: string; pagePathById?: Record<string, string>;
}
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { eyebrowKey, headlineKey, ctaLabelKey, ctaPageId = 'services', statusKey, scrollKey, variant = 'technical-grid', t, locale, defaultLocale, instanceId, pagePathById = {} } = Astro.props;
const content = { eyebrow: t(eyebrowKey), headline: t(headlineKey), cta: t(ctaLabelKey), status: t(statusKey), scroll: t(scrollKey) };
assertQualifiedComponentContentBudget('EditorialHero', content);
const headingId = `${instanceId}-editorial-hero-heading`;
const ctaHref = localeQualifiedPageHref(ctaPageId, pagePathById, locale, defaultLocale);
---

<section class:list={['editorial-hero', `editorial-hero--${variant}`]} data-component="EditorialHero" data-variant={variant} aria-labelledby={headingId}>
  <div class="texture" aria-hidden="true"></div>
  <div class="container content">
    <p class="eyebrow">{content.eyebrow}</p>
    <p class="status">{content.status}</p>
    <h1 id={headingId}>{content.headline}</h1>
    <div class="footer"><a href={ctaHref}>{content.cta}<span aria-hidden="true">→</span></a><p>{content.scroll}</p></div>
  </div>
</section>

<style>
  .editorial-hero{position:relative;overflow:hidden;background:var(--c-primary);color:var(--c-on-primary);min-height:min(42rem,78vh);display:grid;align-items:end}.texture{position:absolute;inset:0;background:radial-gradient(55% 58% at 74% 24%,color-mix(in srgb,var(--c-accent) 20%,transparent),transparent 70%),linear-gradient(115deg,transparent 0 48%,color-mix(in srgb,var(--c-on-primary) 6%,transparent) 48% 49%,transparent 49%);background-size:auto,2.2rem 2.2rem}.content{position:relative;padding-top:8rem;padding-bottom:3rem}.eyebrow,.status{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase}.status{margin-top:3rem;color:color-mix(in srgb,var(--c-on-primary) 74%,transparent)}h1{margin-top:.8rem;max-width:13ch;font-size:clamp(3rem,9vw,7.5rem);line-height:.94;letter-spacing:-.04em}.footer{margin-top:3rem;display:flex;justify-content:space-between;gap:1rem;align-items:center;flex-wrap:wrap}.footer a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.55rem;padding:.55rem 1rem;border:1px solid currentColor;color:inherit}.footer a:hover,.footer a:focus-visible{background:var(--c-on-primary);color:var(--c-primary)}.footer p{font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:color-mix(in srgb,var(--c-on-primary) 72%,transparent)}.editorial-hero--quiet{background:var(--c-surface);color:var(--c-on-surface)}.editorial-hero--quiet .texture{background:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 35%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.editorial-hero--quiet .footer a:hover,.editorial-hero--quiet .footer a:focus-visible{background:var(--c-on-surface);color:var(--c-surface)}
</style>
