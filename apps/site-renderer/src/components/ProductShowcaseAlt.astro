---
import { createRequire } from 'node:module';
import ControlledAssetPicture from './ControlledAssetPicture.astro';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Product { code:string; nameKey:string; taglineKey:string; capacityKey:string; weightKey:string; cyclesKey:string; priceKey:string; asset?:{assetId:string;altKey?:string;variantUrl?:string} }
interface Props { chapterKey:string; titleKey:string; titleAccentKey:string; introKey:string; products:Product[]; configureKey?:string; configurePageId?:string; configureCta?:{labelKey:string;pageId:string};capacityLabelKey?:string;weightLabelKey?:string;cyclesLabelKey?:string;fromLabelKey?:string;f1Key?:string;f2Key?:string;f3Key?:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;alt?:boolean;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { chapterKey,titleKey,titleAccentKey,introKey,products,configureKey,configurePageId,configureCta,capacityLabelKey='products.capacity',weightLabelKey='products.weight',cyclesLabelKey='products.cycles',fromLabelKey='products.from',f1Key,f2Key,f3Key,variant='technical-grid',t,alt,locale,defaultLocale,instanceId,pagePathById={} }=Astro.props;
const fallback={code:'',nameKey:titleKey,taglineKey:introKey,capacityKey:introKey,weightKey:introKey,cyclesKey:introKey,priceKey:introKey};
const records=products.length?products:[fallback]; const first=records[0]!;
const cta=configureCta ?? (configureKey&&configurePageId?{labelKey:configureKey,pageId:configurePageId}:undefined);
const content={chapter:t(chapterKey),title:t(titleKey),accent:t(titleAccentKey),intro:t(introKey),product:{code:first.code,name:t(first.nameKey),tagline:t(first.taglineKey),capacity:t(first.capacityKey),weight:t(first.weightKey),cycles:t(first.cyclesKey),price:t(first.priceKey),alt:first.asset?.altKey?t(first.asset.altKey):t(first.nameKey)},capacityLabel:t(capacityLabelKey),weightLabel:t(weightLabelKey),cyclesLabel:t(cyclesLabelKey),fromLabel:t(fromLabelKey),features:[f1Key,f2Key,f3Key].filter((key):key is string=>Boolean(key)).map(t),cta:cta?t(cta.labelKey):undefined};
for (const product of records) assertQualifiedComponentContentBudget('ProductShowcaseAlt',{...content,product:{code:product.code,name:t(product.nameKey),tagline:t(product.taglineKey),capacity:t(product.capacityKey),weight:t(product.weightKey),cycles:t(product.cyclesKey),price:t(product.priceKey),alt:product.asset?.altKey?t(product.asset.altKey):t(product.nameKey)}}); const href=cta?localeQualifiedPageHref(cta.pageId,pagePathById,locale,defaultLocale):undefined; const headingId=`${instanceId}-product-showcase-alt-heading`;
---
<section class:list={['block','product-showcase-alt',`product-showcase-alt--${variant}`,{alt}]} data-component="ProductShowcaseAlt" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><span>{content.chapter}</span><h2 id={headingId}>{content.title} <em>{content.accent}</em></h2><p>{content.intro}</p></header><div class="records">{records.map((product,index)=><article class="showcase"><div class="media">{product.asset?<ControlledAssetPicture assetId={product.asset.assetId} variantUrl={product.asset.variantUrl} alt={product.asset.altKey?t(product.asset.altKey):t(product.nameKey)} width={1200} height={900}/>:<span class="fallback" aria-hidden="true">{product.code}</span>}</div><div class="detail"><span>{t(product.taglineKey)}</span><h3>{t(product.nameKey)}</h3><dl><div><dt>{content.capacityLabel}</dt><dd>{t(product.capacityKey)}</dd></div><div><dt>{content.weightLabel}</dt><dd>{t(product.weightKey)}</dd></div><div><dt>{content.cyclesLabel}</dt><dd>{t(product.cyclesKey)}</dd></div></dl>{index===0&&content.features.length>0&&<ul>{content.features.map((feature)=><li>{feature}</li>)}</ul>}<footer><strong>{content.fromLabel} {t(product.priceKey)}</strong>{index===0&&href&&content.cta&&<a href={href}>{content.cta}</a>}</footer></div></article>)}</div></div></section>
<style>.product-showcase-alt--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 35%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{margin-bottom:2rem}header span,.detail>span,dt{font:700 .72rem ui-monospace,monospace;letter-spacing:.12em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{font-size:clamp(2.2rem,5vw,3.8rem)}h2 em{color:var(--c-accent);font-style:normal}.records{display:grid;gap:1rem}.showcase{display:grid;border:1px solid var(--c-border);background:var(--c-surface)}.media{aspect-ratio:4/3;display:grid;place-items:center;background:var(--c-surface-alt);overflow:hidden}.media picture,.media img{display:block;width:100%;height:100%;object-fit:cover}.detail{padding:1.5rem}.detail h3{font-size:2rem}dl{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin-top:1rem;border-top:1px solid var(--c-border);padding-top:1rem}dd{margin:.3rem 0 0;font-weight:700}ul{padding:0;list-style:none}footer{display:flex;justify-content:space-between;gap:1rem;border-top:1px solid var(--c-border);padding-top:1rem}a{min-height:2.75rem;padding:.55rem .9rem;background:var(--c-primary);color:var(--c-on-primary)}@media(min-width:900px){.showcase{grid-template-columns:7fr 5fr}.media{aspect-ratio:auto;min-height:24rem}}</style>
