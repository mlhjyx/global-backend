---
import { createRequire } from 'node:module';
import ControlledAssetPicture from './ControlledAssetPicture.astro';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Product { code:string; nameKey:string; taglineKey:string; capacityKey:string; weightKey:string; cyclesKey:string; priceKey:string; asset?:{assetId:string;altKey?:string} }
interface Props { chapterKey:string; titleKey:string; titleAccentKey:string; introKey:string; products:Product[]; configureKey?:string; configurePageId?:string; configureCta?:{labelKey:string;pageId:string}; f1Key?:string;f2Key?:string;f3Key?:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;alt?:boolean;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { chapterKey,titleKey,titleAccentKey,introKey,products,configureKey,configurePageId,configureCta,f1Key,f2Key,f3Key,variant='technical-grid',t,alt,locale,defaultLocale,instanceId,pagePathById={} }=Astro.props;
const product=products[0];
if(!product) throw new Error('PRODUCT_SHOWCASE_PRODUCTS_REQUIRED');
const resolvedCta=configureCta ?? (configureKey&&configurePageId?{labelKey:configureKey,pageId:configurePageId}:undefined);
const content={chapter:t(chapterKey),title:t(titleKey),accent:t(titleAccentKey),intro:t(introKey),product:{code:product.code,name:t(product.nameKey),tagline:t(product.taglineKey),capacity:t(product.capacityKey),weight:t(product.weightKey),cycles:t(product.cyclesKey),price:t(product.priceKey),alt:product.asset?.altKey?t(product.asset.altKey):t(product.nameKey)},features:[f1Key,f2Key,f3Key].filter((key): key is string => Boolean(key)).map(t),cta:resolvedCta?t(resolvedCta.labelKey):undefined};
assertQualifiedComponentContentBudget('ProductShowcaseAlt',content);
const headingId=`${instanceId}-product-showcase-alt-heading`;
const ctaHref=resolvedCta?localeQualifiedPageHref(resolvedCta.pageId,pagePathById,locale,defaultLocale):undefined;
---
<section class:list={['block','product-showcase-alt',`product-showcase-alt--${variant}`,{alt}]} data-component="ProductShowcaseAlt" data-variant={variant} aria-labelledby={headingId}><div class="container"><header class="head"><div><span class="chapter">{content.chapter}</span><h2 id={headingId}>{content.title}<em>{content.accent}</em></h2></div><p>{content.intro}</p></header><article class="showcase"><div class="media">{product.asset?<ControlledAssetPicture assetId={product.asset.assetId} alt={content.product.alt} width={1200} height={900}/>:<span class="fallback" aria-hidden="true">{content.product.code}</span>}</div><div class="detail"><span class="tagline">{content.product.tagline}</span><h3>{content.product.name}</h3><dl><div><dt>Capacity</dt><dd>{content.product.capacity}</dd></div><div><dt>Weight</dt><dd>{content.product.weight}</dd></div><div><dt>Cycles</dt><dd>{content.product.cycles}</dd></div></dl>{content.features.length>0&&<ul>{content.features.map((feature)=><li><i class="ri-check-line" aria-hidden="true"></i>{feature}</li>)}</ul>}<footer><div><span>From</span><strong>{content.product.price}</strong></div>{ctaHref&&content.cta&&<a href={ctaHref}>{content.cta}<i class="ri-arrow-right-up-line" aria-hidden="true"></i></a>}</footer></div></article></div></section>
<style>.product-showcase-alt--technical-grid{background-image:linear-gradient(color-mix(in srgb,var(--c-border) 35%,transparent) 1px,transparent 1px),linear-gradient(90deg,color-mix(in srgb,var(--c-border) 35%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.head{display:grid;gap:1.25rem;margin-bottom:2rem}.chapter,.tagline,dt,footer span{font-family:ui-monospace,monospace;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{margin-top:.6rem;font-size:clamp(2.2rem,5vw,3.8rem);line-height:1}h2 em{display:block;font-style:normal;color:var(--c-accent)}.head>p{max-width:34rem;color:var(--c-on-surface-muted)}.showcase{display:grid;border:1px solid var(--c-border);background:var(--c-surface)}.media{aspect-ratio:4/3;display:grid;place-items:center;background:var(--c-surface-alt);overflow:hidden}.media picture,.media img{display:block;width:100%;height:100%;object-fit:cover}.fallback{font-family:ui-monospace,monospace;font-size:2rem;color:var(--c-primary)}.detail{padding:1.5rem}.detail h3{margin-top:.7rem;font-size:clamp(1.8rem,4vw,3rem)}dl{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin-top:1.75rem;padding-top:1rem;border-top:1px solid var(--c-border)}dd{margin:.3rem 0 0;font-weight:700}ul{display:grid;gap:.55rem;list-style:none;margin:1.5rem 0 0;padding:1rem 0 0;border-top:1px solid var(--c-border)}li{display:flex;gap:.5rem;align-items:center}li i{color:var(--c-accent)}footer{display:flex;align-items:end;justify-content:space-between;gap:1rem;margin-top:1.5rem;padding-top:1rem;border-top:1px solid var(--c-border)}footer strong{display:block;margin-top:.25rem;font-size:1.5rem}footer a{display:inline-flex;align-items:center;gap:.4rem;min-height:2.75rem;padding:.55rem .9rem;background:var(--c-primary);color:var(--c-on-primary)}.product-showcase-alt--quiet{background:var(--c-surface-alt)}@media(min-width:900px){.head{grid-template-columns:1.4fr 1fr;align-items:end}.showcase{grid-template-columns:7fr 5fr}.media{aspect-ratio:auto;min-height:31rem}}</style>
