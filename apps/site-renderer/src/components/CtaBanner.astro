---
import { localePageHref } from '../lib/spec';

interface Props {
  headlineKey: string;
  cta: { labelKey: string; pageId?: string; url?: string };
  t: (key: string) => string;
  locale: string;
  defaultLocale: string;
}
const { headlineKey, cta, t, locale, defaultLocale } = Astro.props;
const href =
  cta?.url ??
  (cta?.pageId
    ? localePageHref(cta.pageId, locale, defaultLocale)
    : '#inquiry');
---

<section class="block cta">
  <h2>{t(headlineKey)}</h2>
  <a class="btn" href={href}>{t(cta.labelKey)}</a>
</section>

<style>
  .cta {
    background: var(--c-secondary);
    color: var(--c-on-primary);
    text-align: center;
    display: grid;
    gap: 1.25rem;
    justify-items: center;
  }
</style>
