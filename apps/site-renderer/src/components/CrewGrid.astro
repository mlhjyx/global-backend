---
import { createRequire } from 'node:module'; import { localeQualifiedPageHref } from '../lib/page-reference';
interface Stat{labelKey:string;value:string;subKey:string} interface Member{nameKey:string;roleKey:string;years:string;regionsKey:string;quoteKey:string;truckKey:string;authorizedProfile:true} interface Props{chapterKey:string;h1aKey:string;h1bKey:string;bodyKey:string;stats:Stat[];members:Member[];footnoteKey:string;requestKey:string;requestPageId?:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string>}
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {chapterKey,h1aKey,h1bKey,bodyKey,stats,members,footnoteKey,requestKey,requestPageId='book',variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;const content={chapter:t(chapterKey),title:`${t(h1aKey)} ${t(h1bKey)}`,body:t(bodyKey),stats:stats.map((stat)=>({label:t(stat.labelKey),value:stat.value,sub:t(stat.subKey)})),members:members.map((member)=>({name:t(member.nameKey),role:t(member.roleKey),years:member.years,regions:t(member.regionsKey),quote:t(member.quoteKey),truck:t(member.truckKey)})),footnote:t(footnoteKey),cta:t(requestKey)};assertQualifiedComponentContentBudget('CrewGrid',content);const headingId=`${instanceId}-crew-grid-heading`;
---
<section class={`crew-grid crew-grid--${variant}`} data-component="CrewGrid" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><p>{content.chapter}</p><h2 id={headingId}>{content.title}</h2><p>{content.body}</p></header><ul class="stats">{content.stats.map((stat)=><li><p>{stat.label}</p><strong>{stat.value}</strong><span>{stat.sub}</span></li>)}</ul><ul class="members">{content.members.map((member,index)=><li><article><p>{String(index+1).padStart(2,'0')} · {member.truck}</p><h3>{member.name}</h3><p>{member.role} · {member.years} years</p><p>{member.regions}</p><blockquote>{member.quote}</blockquote></article></li>)}</ul><footer><p>{content.footnote}</p><a href={localeQualifiedPageHref(requestPageId,pagePathById,locale,defaultLocale)}>{content.cta}<span aria-hidden="true">→</span></a></footer></div></section>
<style>.crew-grid{padding-block:clamp(4rem,8vw,7rem);background:var(--c-surface)}.crew-grid--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 28%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{max-width:46rem}header>p:first-child,.stats p,.members article>p:first-child{font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{margin-top:.75rem;font-size:clamp(2.2rem,5vw,4rem)}header>p:last-child{margin-top:1rem;line-height:1.7}.stats,.members{display:grid;gap:1rem;list-style:none;margin:2.5rem 0 0;padding:0}.stats{grid-template-columns:repeat(auto-fit,minmax(10rem,1fr));border-block:1px solid var(--c-border)}.stats li{padding:1rem;border-inline-end:1px solid var(--c-border)}.stats strong{display:block;margin-top:.5rem;font-size:2rem}.stats span{color:var(--c-on-surface-muted)}.members{grid-template-columns:repeat(auto-fit,minmax(min(100%,16rem),1fr))}.members article{height:100%;padding:1.25rem;border:1px solid var(--c-border);background:var(--c-surface)}h3{margin-top:2rem;font-size:1.4rem}.members article>p:not(:first-child){margin-top:.5rem;color:var(--c-on-surface-muted)}blockquote{margin:1.5rem 0 0;padding-top:1rem;border-top:1px solid var(--c-border);line-height:1.65;font-style:italic}footer{display:flex;gap:1rem;justify-content:space-between;align-items:center;flex-wrap:wrap;margin-top:3rem;padding-top:1.25rem;border-top:1px solid var(--c-border)}footer p{max-width:45rem;color:var(--c-on-surface-muted)}a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;border:1px solid var(--c-border);color:var(--c-on-surface)}a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.crew-grid--quiet{background:var(--c-surface-alt)}</style>
