---
import { createRequire } from 'node:module';interface Plan{nameKey:string;taglineKey:string;monthly:number;yearly:number;featured?:boolean;featureKeys?:string[];features?:string[]}interface Props{eyebrowKey:string;titleKey:string;titleLine2Key:string;subKey:string;monthlyKey:string;yearlyKey:string;saveKey:string;featuredKey:string;ctaPrefixKey?:string;perMoKey:string;plans:Plan[];variant?:'technical-grid'|'quiet';t:(key:string)=>string;alt?:boolean;instanceId:string}const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {eyebrowKey,titleKey,titleLine2Key,subKey,monthlyKey,yearlyKey,saveKey,featuredKey,perMoKey,plans,variant='technical-grid',t,alt,instanceId}=Astro.props;const content={eyebrow:t(eyebrowKey),title:t(titleKey),titleLine2:t(titleLine2Key),sub:t(subKey),monthlyLabel:t(monthlyKey),yearlyLabel:t(yearlyKey),save:t(saveKey),featured:t(featuredKey),perMo:t(perMoKey),plans:plans.map((plan)=>({name:t(plan.nameKey),tagline:t(plan.taglineKey),monthly:String(plan.monthly),yearly:String(plan.yearly),featured:Boolean(plan.featured),features:plan.featureKeys?.map(t)??plan.features??[]}))};assertQualifiedComponentContentBudget('PricingTiers',content);const headingId=`${instanceId}-pricing-tiers-heading`;
---
<section class:list={['block','pricing-tiers',`pricing-tiers--${variant}`,{alt}]} data-component="PricingTiers" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><p>{content.eyebrow}</p><h2 id={headingId}>{content.title}<br />{content.titleLine2}</h2><p>{content.sub}</p></header><div class="grid">{content.plans.map((plan)=><article class:list={{featured:plan.featured}}>{plan.featured&&<p class="badge">{content.featured}</p>}<h3>{plan.name}</h3><p>{plan.tagline}</p><dl><div><dt>{content.monthlyLabel}</dt><dd>${plan.monthly} <small>{content.perMo}</small></dd></div><div><dt>{content.yearlyLabel}</dt><dd>${plan.yearly} <small>{content.perMo}</small></dd></div></dl><ul>{plan.features.map((feature)=><li>{feature}</li>)}</ul></article>)}</div><p class="save-note">{content.save}</p></div></section>
<style>header{text-align:center;max-width:40rem;margin:0 auto 3rem}header>p:first-child,.save-note{font-size:.75rem;letter-spacing:.15em;text-transform:uppercase}h2{margin-top:1rem;font-size:clamp(2.25rem,5vw,3.75rem)}.grid{display:grid;grid-template-columns:1fr;gap:1.5rem}@media(min-width:768px){.grid{grid-template-columns:repeat(3,1fr)}}article{position:relative;padding:2rem;border:1px solid var(--c-border);border-radius:var(--radius-lg)}article.featured{background:var(--c-primary);color:var(--c-on-dark)}.badge{position:absolute;top:-.75rem;left:1.5rem;padding:.25rem .75rem;background:var(--c-accent);color:var(--c-on-surface);border-radius:9999px;font-size:.7rem}h3{font-size:1.5rem}dl{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1.5rem}dt{font-size:.75rem;text-transform:uppercase}dd{margin:.25rem 0 0;font-size:1.75rem;font-weight:700}dd small{font-size:.75rem;font-weight:400}ul{margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid color-mix(in srgb,currentColor 15%,transparent);list-style:none;padding-left:0}li+li{margin-top:.6rem}.pricing-tiers--technical-grid article:not(.featured){background:linear-gradient(var(--c-surface-alt) 1px,transparent 1px),linear-gradient(90deg,var(--c-surface-alt) 1px,transparent 1px);background-size:1rem 1rem}.save-note{text-align:center;margin-top:1.5rem}</style>
