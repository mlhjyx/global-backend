---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Props { eyebrowKey:string; titleKey:string; bodyKey:string; ctaLabelKey:string; ctaPageId?:string; chipIcon?:string; chipKey?:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; alt?:boolean; locale:string; defaultLocale:string; instanceId:string; pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget }=createRequire(import.meta.url)('@global/contracts');
const {eyebrowKey,titleKey,bodyKey,ctaLabelKey,ctaPageId='contact',chipKey,variant='technical-grid',t,alt,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;
const content={eyebrow:t(eyebrowKey),title:t(titleKey),body:t(bodyKey),cta:t(ctaLabelKey),chip:chipKey?t(chipKey):undefined};assertQualifiedComponentContentBudget('SplitAbout',content);
const headingId=`${instanceId}-split-about-heading`;const ctaHref=localeQualifiedPageHref(ctaPageId,pagePathById,locale,defaultLocale);
---
<section class:list={['block','split-about',`split-about--${variant}`,{alt}]} data-component="SplitAbout" data-variant={variant} aria-labelledby={headingId}><div class="container grid"><div><p class="eyebrow">{content.eyebrow}</p><h2 id={headingId}>{content.title}</h2><p class="body">{content.body}</p><a class="cta" href={ctaHref}>{content.cta}<span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a></div><aside class="note" aria-label={content.chip ?? content.title}><span>{content.chip ?? content.title}</span></aside></div></section>
<style>.split-about--technical-grid{background-image:linear-gradient(color-mix(in srgb,var(--c-border) 32%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.grid{display:grid;grid-template-columns:1fr;gap:2rem;align-items:stretch}@media(min-width:768px){.grid{grid-template-columns:minmax(0,1.2fr) minmax(15rem,.8fr);gap:4rem}}.eyebrow{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{margin-top:.8rem;max-width:14ch;font-size:clamp(2.25rem,5vw,4.25rem);line-height:.98}.body{margin-top:1.5rem;max-width:42rem;line-height:1.7;color:var(--c-on-surface-muted)}.cta{margin-top:2rem;display:inline-flex;align-items:center;gap:.5rem;min-height:2.75rem;padding:.55rem 1rem;border:1px solid var(--c-on-surface);color:var(--c-on-surface)}.cta:hover,.cta:focus-visible{background:var(--c-on-surface);color:var(--c-surface)}.note{min-height:15rem;display:flex;align-items:end;padding:1rem;border:1px solid var(--c-border);background:linear-gradient(145deg,var(--c-surface-alt),color-mix(in srgb,var(--c-accent) 12%,var(--c-surface-alt)))}.note span{font-size:clamp(1.25rem,2vw,1.75rem);max-width:12ch}.split-about--quiet{background:var(--c-surface-alt)}</style>
