---
import { createRequire } from 'node:module';
import ControlledAssetPicture from './ControlledAssetPicture.astro';
import { localeQualifiedPageHref } from '../lib/page-reference';

interface Item { titleKey: string; descKey: string; asset?: { assetId: string; altKey?: string } }
interface Props { titleKey: string; items: Item[]; allLabelKey?: string; allPageId?: string; variant?: 'technical-grid' | 'quiet'; t: (key: string) => string; alt?: boolean; locale: string; defaultLocale: string; instanceId: string; pagePathById?: Record<string, string> }
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { titleKey, items, allLabelKey, allPageId, variant = 'technical-grid', t, alt, locale, defaultLocale, instanceId, pagePathById = {} } = Astro.props;
const content = { title: t(titleKey), items: items.map((item) => ({ title: t(item.titleKey), description: t(item.descKey), alt: item.asset?.altKey ? t(item.asset.altKey) : t(item.titleKey) })), allCta: allLabelKey ? t(allLabelKey) : undefined };
assertQualifiedComponentContentBudget('ProjectsGrid', content);
const headingId = `${instanceId}-projects-grid-heading`;
const allHref = allLabelKey && allPageId ? localeQualifiedPageHref(allPageId, pagePathById, locale, defaultLocale) : undefined;
---

<section class:list={['block', 'projects-grid', `projects-grid--${variant}`, { alt }]} data-component="ProjectsGrid" data-variant={variant} aria-labelledby={headingId}><div class="container"><header class="head"><h2 id={headingId}>{content.title}</h2>{allHref && content.allCta && <a class="all" href={allHref}>{content.allCta}<i class="ri-arrow-right-line" aria-hidden="true"></i></a>}</header><ul class="grid">{items.map((item,index)=><li><article class="card"><div class="media">{item.asset?<ControlledAssetPicture assetId={item.asset.assetId} alt={content.items[index]!.alt} width={960} height={720}/>:<span class="fallback" aria-hidden="true">{String(index+1).padStart(2,'0')}</span>}</div><div class="body"><h3>{content.items[index]!.title}</h3><p>{content.items[index]!.description}</p></div></article></li>)}</ul></div></section>

<style>.projects-grid--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 32%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.head{display:flex;align-items:end;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:2rem}.head h2{font-size:clamp(2rem,4vw,3.5rem);max-width:20ch}.all{display:inline-flex;align-items:center;gap:.4rem;min-height:2.75rem;padding:.5rem .9rem;border:1px solid var(--c-border)}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,17rem),1fr));gap:1rem;list-style:none;margin:0;padding:0}.card{height:100%;border:1px solid var(--c-border);background:var(--c-surface)}.media{aspect-ratio:4/3;display:grid;place-items:center;overflow:hidden;background:var(--c-surface-alt)}.media picture,.media img{display:block;width:100%;height:100%;object-fit:cover}.fallback{font-size:1.5rem;font-family:var(--font-heading);color:var(--c-primary)}.body{padding:1.1rem}.body h3{font-size:1.2rem}.body p{margin-top:.5rem;color:var(--c-on-surface-muted)}.projects-grid--quiet{background:var(--c-surface-alt)}</style>
