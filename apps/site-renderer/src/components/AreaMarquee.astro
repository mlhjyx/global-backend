---
import { createRequire } from 'node:module';
interface Area { labelKey: string }
interface Props { headingKey?: string; items: Array<string | Area>; variant?: 'technical-grid' | 'quiet'; t: (key: string) => string; alt?: boolean; instanceId: string }
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { headingKey, items, variant = 'technical-grid', t, alt, instanceId } = Astro.props;
const heading = headingKey ? t(headingKey) : undefined;
const labels = items.map((item) => typeof item === 'string' ? item : t(item.labelKey));
assertQualifiedComponentContentBudget('AreaMarquee', { heading, items: labels });
const headingId = instanceId + '-area-marquee-heading';
---
<section class:list={['block', 'area-marquee', 'area-marquee--' + variant, { alt }]} data-component="AreaMarquee" data-variant={variant} aria-labelledby={heading ? headingId : undefined}>
  <div class="container">{heading && <h2 id={headingId} class="sr-only">{heading}</h2>}<ul>{labels.map((label) => <li><i class="ri-map-pin-2-line" aria-hidden="true"></i>{label}</li>)}</ul></div>
</section>
<style>.area-marquee{padding:1.5rem 0;border-block:1px solid var(--c-border)}ul{display:flex;flex-wrap:wrap;gap:.75rem 1.5rem;list-style:none;padding:0;margin:0}li{display:flex;align-items:center;gap:.5rem;font-family:var(--font-heading);font-size:clamp(1rem,2.5vw,1.5rem);font-weight:600}li i{color:var(--c-accent)}.area-marquee--technical-grid li{padding:.35rem .6rem;background:linear-gradient(var(--c-surface-alt) 1px,transparent 1px),linear-gradient(90deg,var(--c-surface-alt) 1px,transparent 1px);background-size:.75rem .75rem}</style>
