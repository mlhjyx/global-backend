---
import { createRequire } from 'node:module'; import { localeQualifiedPageHref } from '../lib/page-reference';
interface Cta {labelKey:string;pageId?:string;url?:string} interface Props {eyebrowKey:string;h1Line1Key:string;h1Line2Key:string;primaryCta:Cta;secondaryCta?:Cta;scrollKey:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string>}
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {eyebrowKey,h1Line1Key,h1Line2Key,primaryCta,secondaryCta,scrollKey,variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;const href=(cta:Cta)=>cta.url??localeQualifiedPageHref(cta.pageId??'',pagePathById,locale,defaultLocale);const content={eyebrow:t(eyebrowKey),title:`${t(h1Line1Key)} ${t(h1Line2Key)}`,primaryCta:t(primaryCta.labelKey),secondaryCta:secondaryCta?t(secondaryCta.labelKey):undefined,scroll:t(scrollKey)};assertQualifiedComponentContentBudget('FarmhouseHero',content);const headingId=`${instanceId}-farmhouse-heading`;
---
<section class={`farmhouse-hero farmhouse-hero--${variant}`} data-component="FarmhouseHero" data-variant={variant} aria-labelledby={headingId}><div class="texture" aria-hidden="true"></div><div class="container content"><p class="eyebrow">{content.eyebrow}</p><h1 id={headingId}>{t(h1Line1Key)}<br />{t(h1Line2Key)}</h1><div class="ctas"><a href={href(primaryCta)}>{content.primaryCta}<span aria-hidden="true">→</span></a>{secondaryCta&&<a class="secondary" href={href(secondaryCta)}>{content.secondaryCta}</a>}</div><p class="scroll">{content.scroll}</p></div></section>
<style>.farmhouse-hero{position:relative;overflow:hidden;min-height:min(42rem,82vh);display:grid;align-items:end;background:#4a3528;color:var(--c-on-dark)}.texture{position:absolute;inset:0;background:radial-gradient(78% 62% at 25% 36%,color-mix(in srgb,var(--c-secondary) 18%,transparent),transparent 70%),repeating-linear-gradient(135deg,transparent 0 2rem,rgba(255,255,255,.035) 2rem 2.05rem)}.content{position:relative;padding-top:7rem;padding-bottom:3rem}.eyebrow,.scroll{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase}.eyebrow{color:color-mix(in srgb,var(--c-on-dark) 80%,transparent)}h1{margin-top:1rem;font-size:clamp(3rem,8vw,6rem);line-height:.94;max-width:13ch}.ctas{margin-top:2rem;display:flex;flex-wrap:wrap;gap:.75rem}.ctas a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;background:var(--c-surface);color:var(--c-on-surface)}.ctas a.secondary{background:transparent;border:1px solid currentColor;color:inherit}.ctas a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.scroll{margin-top:3rem;color:color-mix(in srgb,var(--c-on-dark) 72%,transparent)}.farmhouse-hero--quiet{background:var(--c-surface-alt);color:var(--c-on-surface)}.farmhouse-hero--quiet .texture{background:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 30%,transparent) 1px,transparent 1px);background-size:2rem 2rem}</style>
