---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';

interface Props { fileKey:string; chapterKey:string; eyebrowKey:string; h1aKey:string; h1bKey:string; bodyKey:string; cta1Key:string; cta1PageId?:string; cta2Key:string; cta2PhoneKey:string; trustOpenKey:string; trustLicKey:string; coverageLabelKey:string; coverageValueKey:string; etaLabelKey:string; etaValueKey:string; marqueeItems:string[]; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; locale:string; defaultLocale:string; instanceId:string; pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { fileKey, chapterKey, eyebrowKey, h1aKey, h1bKey, bodyKey, cta1Key, cta1PageId='book', cta2Key, cta2PhoneKey, trustOpenKey, trustLicKey, coverageLabelKey, coverageValueKey, etaLabelKey, etaValueKey, marqueeItems, variant='technical-grid', t, locale, defaultLocale, instanceId, pagePathById={} } = Astro.props;
const phone=t(cta2PhoneKey).replace(/[^0-9+]/g,'');
const hasValidPhone=/^\+?[1-9]\d{6,14}$/.test(phone);
const content={file:t(fileKey),chapter:t(chapterKey),eyebrow:t(eyebrowKey),title:`${t(h1aKey)} ${t(h1bKey)}`,body:t(bodyKey),cta:t(cta1Key),call:t(cta2Key),phone:t(cta2PhoneKey),trustOpen:t(trustOpenKey),trustLicense:t(trustLicKey),coverageLabel:t(coverageLabelKey),coverageValue:t(coverageValueKey),etaLabel:t(etaLabelKey),etaValue:t(etaValueKey),areas:marqueeItems};
assertQualifiedComponentContentBudget('DispatchHero',content);
const headingId=`${instanceId}-dispatch-hero-heading`;
---
<section class={`dispatch-hero dispatch-hero--${variant}`} data-component="DispatchHero" data-variant={variant} aria-labelledby={headingId}>
  <div class="container"><header><p>{content.file}</p><p>{content.chapter}</p></header><div class="grid"><div><p class="eyebrow">{content.eyebrow}</p><h1 id={headingId}>{t(h1aKey)}<br />{t(h1bKey)}</h1><p class="body">{content.body}</p><div class="ctas"><a href={localeQualifiedPageHref(cta1PageId,pagePathById,locale,defaultLocale)}>{content.cta}<span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a>{hasValidPhone ? <a class="secondary" href={`tel:${phone}`}>{content.call} <span>{content.phone}</span></a> : <p class="secondary">{content.call} <span>{content.phone}</span></p>}</div><p class="trust">{content.trustOpen} · {content.trustLicense}</p></div><aside aria-label={`${content.coverageLabel} and ${content.etaLabel}`}><p>{content.coverageLabel}</p><strong>{content.coverageValue}</strong><p>{content.etaLabel}</p><strong>{content.etaValue}</strong></aside></div><ul aria-label="Service coverage">{content.areas.map((area)=><li>{area}</li>)}</ul></div>
</section>
<style>
.dispatch-hero{background:var(--c-surface);color:var(--c-on-surface);padding:clamp(5rem,10vw,9rem) 0 0}.dispatch-hero--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 28%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{display:flex;justify-content:space-between;gap:1rem;font:.7rem var(--font-mono);letter-spacing:.12em;text-transform:uppercase;color:var(--c-on-surface-muted);border-block:1px solid var(--c-border);padding:.8rem 0}.grid{display:grid;gap:2rem;padding-block:clamp(3rem,7vw,6rem)}@media(min-width:800px){.grid{grid-template-columns:3fr 2fr}}.eyebrow{font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h1{margin-top:1rem;font-size:clamp(2.8rem,7vw,6rem);line-height:.95}.body{max-width:40rem;margin-top:1.25rem;line-height:1.7}.ctas{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:2rem}.ctas a,.ctas .secondary{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;background:var(--c-primary);color:var(--c-on-primary)}.ctas .secondary{background:transparent;border:1px solid currentColor;color:inherit}.ctas a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.trust{margin-top:1.5rem;color:var(--c-on-surface-muted)}aside{padding:1.5rem;border:1px solid var(--c-border);align-self:start}aside p{font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:var(--c-on-surface-muted)}aside strong{display:block;margin:.35rem 0 1.5rem;font-size:clamp(1.6rem,4vw,3rem)}ul{display:flex;gap:.5rem;flex-wrap:wrap;list-style:none;margin:0;padding:1rem 0;border-top:1px solid var(--c-border)}li{padding:.4rem .65rem;border:1px solid var(--c-border);font-size:.8rem}.dispatch-hero--quiet{background:var(--c-surface-alt)}
</style>
