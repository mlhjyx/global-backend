---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Colorway { code:string; nameKey:string; subtitleKey:string; finishKey:string; hex:string; editionKey:string } interface Cta { labelKey:string; pageId:string }
interface Props { chapterKey:string; titleKey:string; titleAccentKey:string; introKey:string; items:Colorway[]; reserveCta?:Cta; reserveLabelKey?:string; reservePageId?:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; locale:string; defaultLocale:string; instanceId:string; pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget }=createRequire(import.meta.url)('@global/contracts'); const {chapterKey,titleKey,titleAccentKey,introKey,items,reserveCta:configuredReserve,reserveLabelKey,reservePageId,variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props; const reserveCta=configuredReserve ?? (reserveLabelKey?{labelKey:reserveLabelKey,pageId:reservePageId??'book'}:undefined); const first=items[0]; const content={chapter:t(chapterKey),title:`${t(titleKey)} ${t(titleAccentKey)}`,intro:t(introKey),items:items.map(item=>({code:item.code,name:t(item.nameKey),subtitle:t(item.subtitleKey),finish:t(item.finishKey),hex:item.hex,edition:t(item.editionKey)})),reserveCta:reserveCta?t(reserveCta.labelKey):undefined}; assertQualifiedComponentContentBudget('ColorwayPicker',content); const headingId=`${instanceId}-colorway-picker-heading`; const groupId=`${instanceId}-colorways`; const reserveHref=reserveCta?localeQualifiedPageHref(reserveCta.pageId,pagePathById,locale,defaultLocale):undefined;
---
<section class={`colorway-picker colorway-picker--${variant}`} data-component="ColorwayPicker" data-variant={variant} data-colorway-picker aria-labelledby={headingId}><div class="container"><header><p>{content.chapter}</p><h2 id={headingId}>{t(titleKey)} <em>{t(titleAccentKey)}</em></h2><p class="intro">{content.intro}</p></header><div class="selected" aria-live="polite"><p class="code" data-code>{first.code}</p><h3 data-name>{t(first.nameKey)}</h3><p data-subtitle>{t(first.subtitleKey)}</p><dl><div><dt>Finish</dt><dd data-finish>{t(first.finishKey)}</dd></div><div><dt>Hex</dt><dd data-hex>{first.hex.toUpperCase()}</dd></div><div><dt>Edition</dt><dd data-edition>{t(first.editionKey)}</dd></div></dl>{reserveCta && <a href={reserveHref}>{content.reserveCta}<span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a>}</div><fieldset><legend>Select a colorway</legend><div class="options">{items.map((item,index)=><label><input type="radio" name={groupId} value={item.code} checked={index===0} data-code={item.code} data-name={t(item.nameKey)} data-subtitle={t(item.subtitleKey)} data-finish={t(item.finishKey)} data-hex={item.hex.toUpperCase()} data-edition={t(item.editionKey)} /><span class="dot" style={`background:${item.hex}`}></span><span><b>{t(item.nameKey)}</b><small>{item.code} · {t(item.finishKey)}</small></span></label>)}</div></fieldset></div></section>
<script>
  document.querySelectorAll<HTMLElement>('[data-colorway-picker]').forEach((root) => {
    const update = (input: HTMLInputElement) => {
      (['code','name','subtitle','finish','hex','edition'] as const).forEach((field) => {
        const target=root.querySelector<HTMLElement>(`[data-${field}]`);
        const value=input.dataset[field]; if (target && value) target.textContent=value;
      });
    };
    root.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((input) => input.addEventListener('change', () => update(input)));
  });
</script>
<style>
.colorway-picker{padding:clamp(5rem,10vw,9rem) 0;background:var(--c-surface);color:var(--c-on-surface)}.colorway-picker--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 30%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{display:grid;gap:1rem;max-width:56rem}header>p:first-child,legend,dt{font:.72rem var(--font-mono);letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{font-size:clamp(2.5rem,6vw,5rem);line-height:.95}em{font-style:italic;color:var(--c-accent)}.intro{max-width:38rem;line-height:1.7}.selected{margin-top:3rem;padding:1.5rem;border:1px solid var(--c-border);max-width:42rem}.code{font:.72rem var(--font-mono);letter-spacing:.14em;color:var(--c-on-surface-muted)}h3{margin-top:.5rem;font-size:2rem}.selected>p:not(.code){margin-top:.75rem;line-height:1.6}.selected dl{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:1.5rem}.selected dd{margin:.35rem 0}.selected a{display:inline-flex;gap:.5rem;margin-top:1.5rem;min-height:2.75rem;align-items:center;padding:.55rem 1rem;background:var(--c-primary);color:var(--c-on-primary)}.selected a:focus-visible,label:has(input:focus-visible){outline:2px solid currentColor;outline-offset:3px}fieldset{margin-top:2rem;border:0;padding:0}.options{display:grid;gap:.75rem}@media(min-width:700px){.options{grid-template-columns:repeat(3,1fr)}}label{display:flex;align-items:center;gap:.75rem;min-height:3.5rem;padding:.75rem;border:1px solid var(--c-border);cursor:pointer}input{inline-size:1.1rem;block-size:1.1rem;accent-color:var(--c-primary)}.dot{width:1.75rem;height:1.75rem;border-radius:50%;border:1px solid color-mix(in srgb,var(--c-on-surface) 25%,transparent)}b,small{display:block}small{margin-top:.2rem;color:var(--c-on-surface-muted)}.colorway-picker--quiet{background:var(--c-surface-alt)}
</style>
