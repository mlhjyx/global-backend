---
import { createRequire } from 'node:module';
import ControlledAssetPicture from './ControlledAssetPicture.astro';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Item { nameKey: string; asset?: { assetId: string; altKey?: string; variantUrl?: string } }
interface Props { eyebrowKey:string; titleKey:string; items:Item[]; allPageId?:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; alt?:boolean; locale:string; defaultLocale:string; instanceId:string; pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { eyebrowKey,titleKey,items,allPageId,variant='technical-grid',t,alt,locale,defaultLocale,instanceId,pagePathById={} }=Astro.props;
const content={eyebrow:t(eyebrowKey),title:t(titleKey),items:items.map((item)=>({name:t(item.nameKey),alt:item.asset?.altKey?t(item.asset.altKey):t(item.nameKey)}))};
assertQualifiedComponentContentBudget('CollectionCards',content);
const headingId=`${instanceId}-collection-cards-heading`;
const resolvedAllPageId=allPageId ?? 'home';
const allHref=localeQualifiedPageHref(resolvedAllPageId,pagePathById,locale,defaultLocale);
---
<section class:list={['block','collection-cards',`collection-cards--${variant}`,{alt}]} data-component="CollectionCards" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><span class="eyebrow">{content.eyebrow}</span><h2 id={headingId}>{content.title}</h2></header><ul class="grid">{items.map((item,index)=><li><article class="card">{allHref?<a class="card-link" href={allHref}><div class="media">{item.asset?<ControlledAssetPicture assetId={item.asset.assetId} variantUrl={item.asset.variantUrl} alt={content.items[index]!.alt} width={720} height={900}/>:<span class="fallback" aria-hidden="true">{String(index+1).padStart(2,'0')}</span>}</div><h3>{content.items[index]!.name}</h3></a>:<><div class="media">{item.asset?<ControlledAssetPicture assetId={item.asset.assetId} variantUrl={item.asset.variantUrl} alt={content.items[index]!.alt} width={720} height={900}/>:<span class="fallback" aria-hidden="true">{String(index+1).padStart(2,'0')}</span>}</div><h3>{content.items[index]!.name}</h3></>}</article></li>)}</ul></div></section>
<style>.collection-cards--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 30%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{margin-bottom:2rem}.eyebrow{font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{margin-top:.6rem;font-size:clamp(2rem,4vw,3.25rem)}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,15rem),1fr));gap:1rem;list-style:none;margin:0;padding:0}.card{height:100%;border:1px solid var(--c-border);background:var(--c-surface)}.card-link{display:block;color:inherit;text-decoration:none}.media{aspect-ratio:4/5;display:grid;place-items:center;overflow:hidden;background:var(--c-surface-alt)}.media picture,.media img{display:block;width:100%;height:100%;object-fit:cover}.fallback{font-family:var(--font-heading);font-size:1.5rem;color:var(--c-primary)}h3{padding:1rem;font-size:1.15rem}.collection-cards--quiet{background:var(--c-surface-alt)}</style>
