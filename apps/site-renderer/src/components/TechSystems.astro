---
import { createRequire } from 'node:module';

import type { Translate } from '../i18n';

const require = createRequire(import.meta.url);
const { assertQualifiedComponentContentBudget } = require('@global/contracts') as typeof import('@global/contracts');

type System = { label: string; titleKey: string; descKey: string; metric: string; suffix: string; metricLabelKey: string };
type Props = { id?: string; instanceId: string; chapterKey: string; titleKey: string; titleAccentKey: string; introKey: string; systems: System[]; liveKey?: string; variant?: 'technical-grid' | 'quiet'; t: Translate; alt?: boolean };
const { id, instanceId, chapterKey, titleKey, titleAccentKey, introKey, systems, liveKey, variant = 'technical-grid', t, alt } = Astro.props;
const chapter = t(chapterKey); const title = `${t(titleKey)} ${t(titleAccentKey)}`; const intro = t(introKey);
const live = liveKey ? t(liveKey) : undefined;
const resolvedSystems = systems.map((system) => ({ label: system.label, title: t(system.titleKey), description: t(system.descKey), metric: system.metric, suffix: system.suffix, metricLabel: t(system.metricLabelKey) }));
assertQualifiedComponentContentBudget('TechSystems', { chapter, title, intro, systems: resolvedSystems, live: liveKey ? t(liveKey) : undefined });
const baseId = `tech-systems-${id ?? 'section'}-${instanceId}`.replace(/[^a-zA-Z0-9_-]/g, '-'); const headingId = `${baseId}-heading`;
---

<section class:list={['block', 'tech-systems', `tech-systems--${variant}`, { alt }]} data-component="TechSystems" data-variant={variant} aria-labelledby={headingId}>
  <div class="container"><div class="tech-systems__intro"><div><p class="tech-systems__chapter">{chapter}</p><h2 id={headingId}>{t(titleKey)} <span>{t(titleAccentKey)}</span></h2></div><div><p>{intro}</p>{live && <p class="tech-systems__live">{live}</p>}</div></div>
    <ol class="tech-systems__list">{resolvedSystems.map((system, index) => { const itemId = `${baseId}-system-${index + 1}`; return <li><article aria-labelledby={itemId}><p class="tech-systems__label">{String(index + 1).padStart(2, '0')} / {system.label}</p><h3 id={itemId}>{system.title}</h3><p class="tech-systems__description">{system.description}</p><dl><div><dt>{system.metricLabel}</dt><dd>{system.metric}<span>{system.suffix}</span></dd></div></dl></article></li>; })}</ol>
  </div>
</section>

<style>
  .tech-systems { background: var(--c-primary); color: var(--c-on-primary); overflow: hidden; } .tech-systems__intro { display: grid; gap: 1.5rem; align-items: end; } @media (min-width: 48rem) { .tech-systems__intro { grid-template-columns: 1.15fr .85fr; } }
  .tech-systems__chapter { margin: 0 0 .65rem; color: color-mix(in srgb, var(--c-on-primary) 75%, transparent); font: 700 .75rem/1.2 var(--font-mono, monospace); letter-spacing: .12em; text-transform: uppercase; } h2, h3, p { margin: 0; } h2 { color: var(--c-on-primary); font: 700 clamp(1.75rem, 4vw, 3.25rem)/1.06 var(--font-display, var(--font-sans, sans-serif)); letter-spacing: -.025em; } h2 span { color: var(--c-accent); } .tech-systems__intro > div:last-child > p:first-child { color: color-mix(in srgb, var(--c-on-primary) 75%, transparent); font: 400 1rem/1.6 var(--font-sans, sans-serif); } .tech-systems__live { display: inline-flex; margin-top: 1rem; border: 1px solid color-mix(in srgb, var(--c-on-primary) 32%, transparent); padding: .45rem .7rem; color: var(--c-on-primary); font: 700 .7rem/1.2 var(--font-mono, monospace); letter-spacing: .08em; text-transform: uppercase; }
  .tech-systems__list { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 15rem), 1fr)); gap: 1px; margin: 2rem 0 0; padding: 1px; list-style: none; background: color-mix(in srgb, var(--c-on-primary) 20%, transparent); } li { min-width: 0; background: color-mix(in srgb, var(--c-on-primary) 5%, transparent); } article { min-height: 100%; padding: clamp(1.25rem, 3vw, 2rem); } .tech-systems__label { color: color-mix(in srgb, var(--c-on-primary) 65%, transparent); font: 700 .7rem/1.2 var(--font-mono, monospace); letter-spacing: .09em; text-transform: uppercase; } h3 { margin-top: 2rem; color: var(--c-on-primary); font: 700 clamp(1.1rem, 1.8vw, 1.5rem)/1.25 var(--font-sans, sans-serif); } .tech-systems__description { margin-top: .75rem; color: color-mix(in srgb, var(--c-on-primary) 78%, transparent); font: 400 .95rem/1.6 var(--font-sans, sans-serif); } dl { margin: 2rem 0 0; padding-top: 1rem; border-top: 1px solid color-mix(in srgb, var(--c-on-primary) 20%, transparent); } dt { color: color-mix(in srgb, var(--c-on-primary) 65%, transparent); font: 700 .7rem/1.2 var(--font-mono, monospace); letter-spacing: .09em; text-transform: uppercase; } dd { margin: .5rem 0 0; color: var(--c-accent); font: 700 2rem/1 var(--font-display, var(--font-sans, sans-serif)); font-variant-numeric: tabular-nums; } dd span { margin-left: .2rem; font-size: 1rem; }
  .tech-systems--technical-grid { background-image: linear-gradient(to right, color-mix(in srgb, var(--c-on-primary) 12%, transparent) 1px, transparent 1px); background-size: 4rem 100%; } .tech-systems--quiet { background-image: none; }
  @media (prefers-reduced-motion: reduce) { *, *::before, *::after { scroll-behavior: auto !important; } }
</style>
