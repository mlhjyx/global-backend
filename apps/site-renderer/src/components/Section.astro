---
/**
 * 组件分发（04 §5 的 55 型封闭枚举）。未知 type 与非法 props 均 fail-closed，
 * 防止契约漂移被静默吞掉后进入不可变 Release。
 */
import HeroBanner from './HeroBanner.astro';
import StatsBand from './StatsBand.astro';
import ProductGrid from './ProductGrid.astro';
import AboutBlock from './AboutBlock.astro';
import CertWall from './CertWall.astro';
import ProcessTimeline from './ProcessTimeline.astro';
import FaqAccordion from './FaqAccordion.astro';
import CtaBanner from './CtaBanner.astro';
import InquiryForm from './InquiryForm.astro';
import MapLocation from './MapLocation.astro';
import HeroFull from './HeroFull.astro';
import AreaMarquee from './AreaMarquee.astro';
import ServicesGrid from './ServicesGrid.astro';
import TrustSplit from './TrustSplit.astro';
import ProcessSteps from './ProcessSteps.astro';
import PricingTable from './PricingTable.astro';
import Testimonials from './Testimonials.astro';
import AreaGallery from './AreaGallery.astro';
import FaqSplit from './FaqSplit.astro';
import CtaCenter from './CtaCenter.astro';
import EditorialHero from './EditorialHero.astro';
import ProjectsGrid from './ProjectsGrid.astro';
import ServicesDark from './ServicesDark.astro';
import StatsCountup from './StatsCountup.astro';
import MaterialsLibrary from './MaterialsLibrary.astro';
import LogoMarquee from './LogoMarquee.astro';
import SplitAbout from './SplitAbout.astro';
import WarmHero from './WarmHero.astro';
import ServiceRows from './ServiceRows.astro';
import DishesShowcase from './DishesShowcase.astro';
import PhotoGallery from './PhotoGallery.astro';
import MediaCta from './MediaCta.astro';
import FarmhouseHero from './FarmhouseHero.astro';
import ValueStrip from './ValueStrip.astro';
import FeaturedSpotlight from './FeaturedSpotlight.astro';
import StoryChapters from './StoryChapters.astro';
import CollectionCards from './CollectionCards.astro';
import DispatchHero from './DispatchHero.astro';
import LedgerStats from './LedgerStats.astro';
import ServicesEditorial from './ServicesEditorial.astro';
import DispatchTimeline from './DispatchTimeline.astro';
import CrewGrid from './CrewGrid.astro';
import CoverageMap from './CoverageMap.astro';
import AxiomHero from './AxiomHero.astro';
import ChapterShowcase from './ChapterShowcase.astro';
import ColorwayPicker from './ColorwayPicker.astro';
import SaaSHero from './SaaSHero.astro';
import FeatureCards from './FeatureCards.astro';
import PricingTiers from './PricingTiers.astro';
import ArticleGrid from './ArticleGrid.astro';
import IndustrialHero from './IndustrialHero.astro';
import ProductShowcaseAlt from './ProductShowcaseAlt.astro';
import TechSystems from './TechSystems.astro';
import MinimalHero from './MinimalHero.astro';
import StatementBlock from './StatementBlock.astro';
import { createRequire } from 'node:module';
const { SITE_SPEC_COMPONENT_TYPES, validateBlock } = createRequire(import.meta.url)('@global/contracts');

interface Props {
  block: { type: string; props: Record<string, unknown> };
  t: (key: string) => string;
  index: number;
  locale: string;
  defaultLocale: string;
}
const { block, t, index, locale, defaultLocale } = Astro.props;
const registry: Record<string, unknown> = {
  HeroBanner,
  StatsBand,
  ProductGrid,
  AboutBlock,
  CertWall,
  ProcessTimeline,
  FaqAccordion,
  CtaBanner,
  InquiryForm,
  MapLocation,
  HeroFull,
  AreaMarquee,
  ServicesGrid,
  TrustSplit,
  ProcessSteps,
  PricingTable,
  Testimonials,
  AreaGallery,
  FaqSplit,
  CtaCenter,
  EditorialHero,
  ProjectsGrid,
  ServicesDark,
  StatsCountup,
  MaterialsLibrary,
  LogoMarquee,
  SplitAbout,
  WarmHero,
  ServiceRows,
  DishesShowcase,
  PhotoGallery,
  MediaCta,
  FarmhouseHero,
  ValueStrip,
  FeaturedSpotlight,
  StoryChapters,
  CollectionCards,
  DispatchHero,
  LedgerStats,
  ServicesEditorial,
  DispatchTimeline,
  CrewGrid,
  CoverageMap,
  AxiomHero,
  ChapterShowcase,
  ColorwayPicker,
  SaaSHero,
  FeatureCards,
  PricingTiers,
  ArticleGrid,
  IndustrialHero,
  ProductShowcaseAlt,
  TechSystems,
  MinimalHero,
  StatementBlock,
};
// 一致性校验：registry keys 必须等于封闭真值 SITE_SPEC_COMPONENT_TYPES（防手工漂移）
const _registryKeys = Object.keys(registry);
if (
  _registryKeys.length !== SITE_SPEC_COMPONENT_TYPES.length ||
  _registryKeys.some((k) => !SITE_SPEC_COMPONENT_TYPES.includes(k as never))
) {
  throw new Error(
    'REGISTRY_DRIFT: Section registry keys 与 SITE_SPEC_COMPONENT_TYPES 不一致',
  );
}
validateBlock(block); // 运行时 props schema 校验（type 封闭 + 必填 props），fail-closed 不静默缺块
const Component = registry[block.type] as ((props: unknown) => unknown) | undefined;
if (!Component) throw new Error(
  `UNKNOWN_COMPONENT_TYPE: ${block.type} -- 不在封闭 55 型注册表（SITE_SPEC_COMPONENT_TYPES）`,
);
const alt = index % 2 === 1;
---

{Component ? (
  <Component
    {...block.props}
    t={t}
    alt={alt}
    locale={locale}
    defaultLocale={defaultLocale}
  />
) : null}
