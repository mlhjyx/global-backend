---
import { createRequire } from 'node:module';
interface Props { labelKey:string; statementKey:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; alt?:boolean; instanceId:string }
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts'); const {labelKey,statementKey,variant='technical-grid',t,alt,instanceId}=Astro.props;const label=t(labelKey),statement=t(statementKey);assertQualifiedComponentContentBudget('StatementBlock',{label,statement});const headingId=`${instanceId}-statement-heading`;
---
<section class:list={['block','statement-block',`statement-block--${variant}`,{alt}]} data-component="StatementBlock" data-variant={variant} aria-labelledby={headingId}><div class="container statement"><p class="eyebrow">{label}</p><h2 id={headingId}>{statement}</h2></div></section>
<style>.statement{max-width:48rem;padding:1.5rem}.statement-block--technical-grid .statement{border-left:3px solid var(--c-primary);background:linear-gradient(var(--c-surface-alt) 1px,transparent 1px),linear-gradient(90deg,var(--c-surface-alt) 1px,transparent 1px),var(--c-surface);background-size:1rem 1rem}.eyebrow{font-size:.75rem;text-transform:uppercase;letter-spacing:.16em;color:var(--c-on-surface-muted)}h2{margin-top:1rem;font-size:clamp(1.875rem,4vw,3.5rem);line-height:1.1;font-weight:500}</style>
