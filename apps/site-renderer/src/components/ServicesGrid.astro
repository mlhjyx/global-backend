---
import { createRequire } from 'node:module';
import { localePageHref } from '../lib/spec';

interface Service { icon: string; titleKey: string; descKey: string; fromKey?: string }
interface Props {
  eyebrowKey: string; titleKey: string; titleAccentKey: string; introKey: string;
  allLabelKey?: string; allPageId?: string; services: Service[];
  variant?: 'technical-grid' | 'quiet'; t: (key: string) => string;
  alt?: boolean; locale: string; defaultLocale: string; instanceId: string;
}
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { eyebrowKey, titleKey, titleAccentKey, introKey, allLabelKey, allPageId, services, variant = 'technical-grid', t, alt, locale, defaultLocale, instanceId } = Astro.props;
const eyebrow = t(eyebrowKey); const title = t(titleKey); const accent = t(titleAccentKey); const intro = t(introKey);
const cards = services.map((service) => ({ title: t(service.titleKey), description: t(service.descKey), from: service.fromKey ? t(service.fromKey) : undefined, icon: service.icon }));
assertQualifiedComponentContentBudget('ServicesGrid', { eyebrow, title, accent, intro, cards });
const allHref = allLabelKey && allPageId ? localePageHref(allPageId, locale, defaultLocale) : undefined;
const headingId = `${instanceId}-services-heading`;
---

<section class:list={['block', 'services-grid', `services-grid--${variant}`, { alt }]} data-component="ServicesGrid" data-variant={variant} aria-labelledby={headingId}>
  <div class="container">
    <div class="head"><div><span class="eyebrow">{eyebrow}</span><h2 id={headingId} class="section-title">{title} <em>{accent}</em></h2><p class="muted intro">{intro}</p></div>{allHref && <a class="btn btn-outline btn-sm" href={allHref}>{t(allLabelKey!)} <span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a>}</div>
    <ul class="grid">{cards.map((card) => <li><article class="card"><div class="icon" aria-hidden="true"><i class={card.icon}></i></div><div><h3>{card.title}</h3><p class="muted">{card.description}</p>{card.from && <p class="from">{card.from}</p>}</div></article></li>)}</ul>
  </div>
</section>

<style>
  .head { display:flex; flex-direction:column; gap:1.25rem; margin-bottom:clamp(2rem,4vw,3.5rem); } @media (min-width:768px){.head{flex-direction:row;align-items:end;justify-content:space-between}} .intro{margin-top:.85rem;max-width:40rem}.grid{display:grid;grid-template-columns:1fr;gap:1.25rem;list-style:none;padding:0;margin:0}@media(min-width:640px){.grid{grid-template-columns:repeat(2,1fr)}}@media(min-width:1024px){.grid{grid-template-columns:repeat(3,1fr)}}.card{height:100%;display:grid;gap:1rem;padding:1.5rem;border:1px solid var(--c-border);border-radius:var(--radius-lg);background:var(--c-surface)}.services-grid--technical-grid .card{background:linear-gradient(var(--c-surface-alt) 1px,transparent 1px),linear-gradient(90deg,var(--c-surface-alt) 1px,transparent 1px),var(--c-surface);background-size:1rem 1rem}.icon{width:2.75rem;height:2.75rem;display:grid;place-items:center;border-radius:9999px;background:var(--c-primary-dark);color:var(--c-on-dark)}h3{font-size:1.1rem;font-weight:600}.muted{margin-top:.5rem}.from{margin-top:1rem;font-size:.75rem;font-weight:600;color:var(--c-on-surface-muted)}
</style>
