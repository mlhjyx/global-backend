---
import { localePageHref } from '../lib/spec';

interface Props {
  eyebrowKey: string;
  h1aKey: string;
  h1bKey: string;
  subKey: string;
  cta1Key: string;
  cta2Key: string;
  scrollKey: string;
  t: (key: string) => string;
  locale: string;
  defaultLocale: string;
}
const { eyebrowKey, h1aKey, h1bKey, subKey, cta1Key, cta2Key, scrollKey, t, locale, defaultLocale } = Astro.props;
const startHref = localePageHref('book', locale, defaultLocale);
---

<section class="saas-hero">
  <div class="pastel-bg" aria-hidden="true"></div>
  <div class="inner">
    <div class="eyebrow"><span class="dot"></span>{t(eyebrowKey)}</div>
    <h1>{t(h1aKey)}<br />{t(h1bKey)}</h1>
    <p class="sub">{t(subKey)}</p>
    <div class="ctas">
      <a class="cta-ink" href={startHref}>{t(cta1Key)}<i class="ri-arrow-right-line"></i></a>
      <a class="cta-demo" href="#product"><span class="play"><i class="ri-play-fill"></i></span>{t(cta2Key)}</a>
    </div>
  </div>
  <div class="panel reveal">
    <div class="panel-bar"><span></span><span></span><span></span></div>
    <div class="panel-body">
      <div class="panel-side"></div>
      <div class="panel-main">
        <div class="panel-row w60"></div>
        <div class="panel-row w40"></div>
        <div class="panel-row w80"></div>
        <div class="panel-cards">
          <div class="panel-card"></div><div class="panel-card"></div><div class="panel-card"></div>
        </div>
      </div>
    </div>
  </div>
  <div class="scroll-cue"><span class="line"></span>{t(scrollKey)}</div>
</section>

<style>
  .saas-hero { position: relative; background: var(--c-surface); padding: clamp(6rem, 12vw, 9rem) 0 0; overflow: hidden; }
  .pastel-bg { position: absolute; inset: 0; background: radial-gradient(60% 50% at 80% 10%, color-mix(in srgb, var(--c-accent) 35%, transparent), transparent 60%), radial-gradient(50% 40% at 10% 20%, color-mix(in srgb, var(--c-secondary) 35%, transparent), transparent 60%); opacity: 0.5; }
  .inner { position: relative; max-width: 48rem; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 2.5rem); text-align: center; }
  .eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.2em; color: var(--c-on-surface-muted); margin-bottom: 1.25rem; }
  .eyebrow .dot { width: 8px; height: 8px; border-radius: 9999px; background: var(--c-on-surface); }
  h1 { font-weight: 700; font-size: clamp(2.5rem, 6vw, 4.25rem); line-height: 1.02; letter-spacing: -0.02em; color: var(--c-on-surface); }
  .sub { margin: 1.5rem auto 0; max-width: 32rem; font-size: 1.05rem; line-height: 1.7; color: var(--c-on-surface-muted); }
  .ctas { margin-top: 2rem; display: flex; flex-direction: column; gap: 0.75rem; align-items: center; }
  @media (min-width: 640px) { .ctas { flex-direction: row; justify-content: center; } }
  .cta-ink { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--c-primary); color: var(--c-on-primary); padding: 0.85rem 1.5rem; border-radius: 9999px; font-size: 0.9rem; font-weight: 500; transition: background .2s ease; }
  .cta-ink:hover { background: #000; }
  .cta-demo { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; font-weight: 500; color: var(--c-on-surface); }
  .play { width: 2.25rem; height: 2.25rem; display: grid; place-items: center; border-radius: 9999px; border: 1px solid color-mix(in srgb, var(--c-on-surface) 20%, transparent); transition: background .2s ease; }
  .cta-demo:hover .play { background: color-mix(in srgb, var(--c-on-surface) 5%, transparent); }
  .panel { position: relative; max-width: 64rem; margin: 3rem auto 0; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--c-border); background: var(--c-surface-alt); }
  .panel-bar { display: flex; gap: 0.4rem; padding: 0.85rem 1rem; border-bottom: 1px solid var(--c-border); }
  .panel-bar span { width: 0.7rem; height: 0.7rem; border-radius: 9999px; background: color-mix(in srgb, var(--c-on-surface) 15%, transparent); }
  .panel-body { display: grid; grid-template-columns: 5rem 1fr; min-height: 18rem; }
  .panel-side { background: var(--c-surface); border-right: 1px solid var(--c-border); }
  .panel-main { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .panel-row { height: 0.75rem; border-radius: 9999px; background: color-mix(in srgb, var(--c-on-surface) 10%, transparent); }
  .w40 { width: 40%; } .w60 { width: 60%; } .w80 { width: 80%; }
  .panel-cards { margin-top: auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
  .panel-card { aspect-ratio: 4 / 3; border-radius: var(--radius); background: linear-gradient(135deg, color-mix(in srgb, var(--c-accent) 40%, var(--c-surface)), color-mix(in srgb, var(--c-secondary) 40%, var(--c-surface))); }
  .scroll-cue { position: relative; display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 2.5rem 0; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.25em; font-weight: 500; color: var(--c-on-surface-muted); }
  .scroll-cue .line { width: 2.5rem; height: 1px; background: color-mix(in srgb, var(--c-on-surface) 40%, transparent); }
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity .8s ease, transform .8s cubic-bezier(0.22,1,0.36,1); }
  .reveal { opacity: 1; transform: translateY(0); }
</style>
