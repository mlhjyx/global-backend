---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Cta { labelKey:string; pageId:string }
interface Props { eyebrowKey:string; h1aKey:string; h1bKey:string; subKey:string; primaryCta?:Cta; secondaryCta?:Cta; cta1Key?:string; cta1PageId?:string; cta2Key?:string; cta2PageId?:string; scrollKey:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; locale:string; defaultLocale:string; instanceId:string; pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget }=createRequire(import.meta.url)('@global/contracts');
const { eyebrowKey,h1aKey,h1bKey,subKey,primaryCta:configuredPrimary,secondaryCta:configuredSecondary,cta1Key,cta1PageId,cta2Key,cta2PageId,scrollKey,variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={} }=Astro.props; const primaryCta=configuredPrimary ?? {labelKey:cta1Key!,pageId:cta1PageId??'book'}; const secondaryCta=configuredSecondary ?? (cta2Key?{labelKey:cta2Key,pageId:cta2PageId??'book'}:undefined);
const content={eyebrow:t(eyebrowKey),title:`${t(h1aKey)} ${t(h1bKey)}`,sub:t(subKey),primaryCta:t(primaryCta.labelKey),secondaryCta:secondaryCta? t(secondaryCta.labelKey):undefined,scroll:t(scrollKey)};
assertQualifiedComponentContentBudget('SaaSHero',content);
const headingId=`${instanceId}-saas-hero-heading`;
const href=(cta:Cta)=>localeQualifiedPageHref(cta.pageId,pagePathById,locale,defaultLocale);
---
<section class={`saas-hero saas-hero--${variant}`} data-component="SaaSHero" data-variant={variant} aria-labelledby={headingId}>
  <div class="container"><p class="eyebrow">{content.eyebrow}</p><h1 id={headingId}>{t(h1aKey)}<br />{t(h1bKey)}</h1><p class="sub">{content.sub}</p><div class="ctas"><a href={href(primaryCta)}>{content.primaryCta}<span aria-hidden="true">→</span></a>{secondaryCta && <a class="secondary" href={href(secondaryCta)}>{content.secondaryCta}</a>}</div><div class="panel" aria-hidden="true"><span></span><span></span><span></span></div><p class="scroll">{content.scroll}</p></div>
</section>
<style>
.saas-hero{padding:clamp(5rem,10vw,9rem) 0;background:var(--c-surface);color:var(--c-on-surface)}.saas-hero--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 30%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.container{text-align:center;max-width:64rem}.eyebrow,.scroll{font:.72rem var(--font-mono);letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h1{margin-top:1rem;font-size:clamp(2.8rem,7vw,6rem);line-height:.95}.sub{max-width:40rem;margin:1.25rem auto;line-height:1.7}.ctas{display:flex;justify-content:center;gap:.75rem;flex-wrap:wrap;margin:2rem 0}.ctas a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;background:var(--c-primary);color:var(--c-on-primary)}.ctas .secondary{background:transparent;color:inherit;border:1px solid currentColor}.ctas a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.panel{display:grid;grid-template-columns:1fr 2fr 1fr;gap:1rem;min-height:12rem;margin-top:3rem;padding:1.5rem;border:1px solid var(--c-border);background:var(--c-surface-alt)}.panel span{display:block;background:color-mix(in srgb,var(--c-primary) 18%,var(--c-surface))}.scroll{margin-top:1.5rem}.saas-hero--quiet{background:var(--c-surface-alt)}
</style>
