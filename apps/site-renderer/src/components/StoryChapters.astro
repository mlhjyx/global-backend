---
import { createRequire } from 'node:module'; interface Chapter{eyebrowKey:string;titleKey:string;bodyKey:string;align?:'left'|'right'} interface Props{introEyebrowKey:string;introTitleKey:string;chapters:Chapter[];variant?:'technical-grid'|'quiet';t:(key:string)=>string;alt?:boolean;instanceId:string}
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {introEyebrowKey,introTitleKey,chapters,variant='technical-grid',t,alt,instanceId}=Astro.props;const content={eyebrow:t(introEyebrowKey),title:t(introTitleKey),chapters:chapters.map((chapter)=>({eyebrow:t(chapter.eyebrowKey),title:t(chapter.titleKey),body:t(chapter.bodyKey)}))};assertQualifiedComponentContentBudget('StoryChapters',content);const headingId=`${instanceId}-story-chapters-heading`;
---
<section class={`block story-chapters story-chapters--${variant}${alt ? ' alt' : ''}`} data-component="StoryChapters" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><p class="eyebrow">{content.eyebrow}</p><h2 id={headingId}>{content.title}</h2></header><ol>{content.chapters.map((chapter,index)=><li><article><p class="number">Chapter {String(index+1).padStart(2,'0')}</p><p class="eyebrow">{chapter.eyebrow}</p><h3>{chapter.title}</h3><p class="body">{chapter.body}</p></article></li>)}</ol></div></section>
<style>.story-chapters--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 28%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{max-width:42rem;margin-bottom:2rem}.eyebrow{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{margin-top:.75rem;font-size:clamp(2.25rem,5vw,4rem)}ol{display:grid;gap:1rem;margin:0;padding:0;list-style:none}article{display:grid;grid-template-columns:7rem 1fr;gap:1rem;padding:1.25rem;border:1px solid var(--c-border);background:var(--c-surface)}.number{font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--c-primary)}article h3{margin-top:.6rem;font-size:clamp(1.5rem,3vw,2.5rem)}.body{margin-top:.75rem;max-width:42rem;line-height:1.7;color:var(--c-on-surface-muted)}.story-chapters--quiet{background:var(--c-surface-alt)}@media(max-width:520px){article{grid-template-columns:1fr}}</style>
