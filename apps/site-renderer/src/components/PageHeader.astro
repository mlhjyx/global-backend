---
/**
 * PageHeader（doc 11 缺口，多页站刚需）：内页页头--大标题 + 可选副标题。
 * 不含 breadcrumb（避免与 nav 重复），保持极简；内页（products/contact 等）通用。
 */
interface Props {
  titleKey: string;
  subtitleKey?: string;
  variant?: string;
  t: (key: string) => string;
  alt?: boolean;
}
const { titleKey, subtitleKey, t, alt } = Astro.props;
---

<section class:list={['block', 'page-header', { alt }]}>
  <div class="inner">
    <h1>{t(titleKey)}</h1>
    {subtitleKey && <p class="muted sub">{t(subtitleKey)}</p>}
  </div>
</section>

<style>
  .inner {
    max-width: 820px;
  }
  h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
  }
  .sub {
    margin-top: 0.75rem;
    font-size: 1.1rem;
  }
</style>
