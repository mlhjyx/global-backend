---
import { createRequire } from 'node:module'; import { localeQualifiedPageHref } from '../lib/page-reference';
interface Item{nameKey:string;categoryKey:string;priceKey:string} interface Props{eyebrowKey:string;titleKey:string;allLabelKey?:string;allPageId?:string;items:Item[];variant?:'technical-grid'|'quiet';t:(key:string)=>string;alt?:boolean;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string>}
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {eyebrowKey,titleKey,allLabelKey,allPageId='home',items,variant='technical-grid',t,alt,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;const content={eyebrow:t(eyebrowKey),title:t(titleKey),items:items.map((item)=>({name:t(item.nameKey),category:t(item.categoryKey),price:t(item.priceKey)})),cta:allLabelKey?t(allLabelKey):undefined};assertQualifiedComponentContentBudget('FeaturedSpotlight',content);const headingId=`${instanceId}-spotlight-heading`;const allHref=content.cta?localeQualifiedPageHref(allPageId,pagePathById,locale,defaultLocale):undefined;
---
<section class={`block featured-spotlight featured-spotlight--${variant}${alt ? ' alt' : ''}`} data-component="FeaturedSpotlight" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><div><p class="eyebrow">{content.eyebrow}</p><h2 id={headingId}>{content.title}</h2></div>{allHref&&<a href={allHref}>{content.cta}<span aria-hidden="true">→</span></a>}</header><ul class="grid">{content.items.map((item,index)=><li><article><p class="number" aria-hidden="true">{String(index+1).padStart(2,'0')}</p><p class="category">{item.category}</p><h3>{item.name}</h3><p class="price">{item.price}</p></article></li>)}</ul></div></section>
<style>.featured-spotlight--technical-grid{background-image:linear-gradient(color-mix(in srgb,var(--c-border) 28%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{display:flex;align-items:end;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:2rem}.eyebrow,.category{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{margin-top:.75rem;font-size:clamp(2.25rem,5vw,4rem)}header a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;border:1px solid var(--c-border);color:var(--c-on-surface)}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,14rem),1fr));gap:1rem;list-style:none;margin:0;padding:0}.grid article{height:100%;padding:1.25rem;border:1px solid var(--c-border);background:var(--c-surface)}.number{font-size:1.35rem;color:var(--c-primary)}.category{margin-top:3rem}.grid h3{margin-top:.5rem;font-size:1.25rem}.price{margin-top:.75rem;color:var(--c-on-surface-muted)}.featured-spotlight--quiet{background:var(--c-surface-alt)}</style>
