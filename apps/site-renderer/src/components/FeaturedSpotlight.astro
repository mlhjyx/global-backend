---
import { localePageHref } from '../lib/spec';

interface Item { nameKey: string; categoryKey: string; priceKey: string }
interface Props {
  eyebrowKey: string;
  titleKey: string;
  allLabelKey?: string;
  allPageId?: string;
  items: Item[];
  t: (key: string) => string;
  alt?: boolean;
  locale: string;
  defaultLocale: string;
}
const { eyebrowKey, titleKey, allLabelKey, allPageId = 'home', items = [], t, alt, locale, defaultLocale } = Astro.props;
const allHref = localePageHref(allPageId, locale, defaultLocale);
---

<section class:list={['block', { alt }]} data-spotlight>
  <div class="container">
    <div class="head reveal">
      <div>
        <span class="eyebrow-flat">{t(eyebrowKey)}</span>
        <h2 class="serif-title">{t(titleKey)}</h2>
      </div>
      {allLabelKey && <a class="all-link" href={allHref}>{t(allLabelKey)} <span class="arr">&rarr;</span></a>}
    </div>

    <div class="grid reveal">
      <div class="stage">
        <div class="stage-ph"><i class="ri-store-2-line"></i></div>
        <div class="stage-info">
          <p class="stage-cat" data-stage-cat>{t(items[0]?.categoryKey ?? '')}</p>
          <div class="stage-row">
            <h3 data-stage-name>{t(items[0]?.nameKey ?? '')}</h3>
            <div class="stage-meta">
              <span class="stage-price" data-stage-price>{t(items[0]?.priceKey ?? '')}</span>
              <span class="view-piece">{t('cta.viewPiece')}<i class="ri-arrow-right-line"></i></span>
            </div>
          </div>
        </div>
      </div>
      <ul class="thumbs">
        {items.map((it, i) => (
          <li>
            <button
              type="button"
              class:list={['thumb', { active: i === 0 }]}
              data-thumb
              data-name={t(it.nameKey)}
              data-cat={t(it.categoryKey)}
              data-price={t(it.priceKey)}
              aria-label={t(it.nameKey)}
            >
              <span class="thumb-ph"><i class="ri-gift-line"></i></span>
            </button>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-spotlight]').forEach((root) => {
    const thumbs = Array.from(root.querySelectorAll<HTMLElement>('[data-thumb]'));
    const nameEl = root.querySelector<HTMLElement>('[data-stage-name]');
    const catEl = root.querySelector<HTMLElement>('[data-stage-cat]');
    const priceEl = root.querySelector<HTMLElement>('[data-stage-price]');
    const stage = root.querySelector<HTMLElement>('.stage');
    const select = (btn: HTMLElement) => {
      thumbs.forEach((t) => t.classList.remove('active'));
      btn.classList.add('active');
      if (stage) { stage.classList.remove('fade'); void stage.offsetWidth; stage.classList.add('fade'); }
      if (nameEl) nameEl.textContent = btn.dataset.name ?? '';
      if (catEl) catEl.textContent = btn.dataset.cat ?? '';
      if (priceEl) priceEl.textContent = btn.dataset.price ?? '';
    };
    thumbs.forEach((btn) => {
      btn.addEventListener('click', () => select(btn));
      btn.addEventListener('mouseenter', () => select(btn));
    });
  });
</script>

<style>
  .head { display: flex; flex-direction: column; gap: 1rem; margin-bottom: clamp(2rem, 4vw, 2.5rem); }
  @media (min-width: 768px) { .head { flex-direction: row; align-items: flex-end; justify-content: space-between; } }
  .eyebrow-flat { font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--c-on-surface-muted); }
  .serif-title { margin-top: 0.75rem; font-family: var(--font-heading); font-weight: 600; font-size: clamp(1.875rem, 4vw, 3rem); line-height: 1.1; }
  .all-link { font-size: 0.85rem; color: var(--c-on-surface-muted); text-decoration: underline; text-underline-offset: 4px; white-space: nowrap; }
  .all-link .arr { display: inline-block; transition: transform .3s ease; }
  .all-link:hover .arr { transform: translateX(4px); }
  .grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 1024px) { .grid { grid-template-columns: 8fr 4fr; gap: 2.5rem; } }
  .stage { position: relative; aspect-ratio: 5 / 4; border-radius: var(--radius-lg); overflow: hidden; }
  .stage.fade .stage-ph { animation: sf .6s ease-out; }
  @keyframes sf { from { opacity: 0.4; transform: scale(1.02); } to { opacity: 1; transform: scale(1); } }
  .stage-ph { position: absolute; inset: 0; display: grid; place-items: center; background:
      radial-gradient(60% 50% at 40% 30%, color-mix(in srgb, var(--c-secondary) 16%, transparent), transparent 60%),
      linear-gradient(140deg, var(--c-surface-alt2), var(--c-surface-alt)); }
  .stage-ph i { font-size: 4rem; color: rgba(0,0,0,0.12); }
  .stage-info { position: absolute; left: 0; right: 0; bottom: 0; padding: clamp(1.25rem, 3vw, 2rem); background: linear-gradient(to top, rgba(0,0,0,0.7), rgba(0,0,0,0.3) 60%, transparent); color: var(--c-on-dark); }
  .stage-cat { font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(255,255,255,0.8); margin-bottom: 0.5rem; }
  .stage-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .stage-row h3 { font-family: var(--font-heading); font-weight: 600; font-size: clamp(1.25rem, 2.5vw, 2.25rem); }
  .stage-meta { display: flex; align-items: center; gap: 1rem; }
  .stage-price { font-size: 1.05rem; }
  .view-piece { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.5rem 1rem; border-radius: 9999px; background: var(--c-surface); color: var(--c-on-surface); font-size: 0.8rem; }
  .thumbs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; list-style: none; padding: 0; margin: 0; }
  @media (min-width: 1024px) { .thumbs { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
  .thumb { position: relative; width: 100%; aspect-ratio: 1 / 1; border-radius: var(--radius); overflow: hidden; border: none; padding: 0; cursor: pointer; background: transparent; transition: opacity .3s ease; }
  .thumb:not(.active) { opacity: 0.7; }
  .thumb:not(.active):hover { opacity: 1; }
  .thumb.active { box-shadow: 0 0 0 2px var(--c-on-surface), 0 0 0 4px var(--c-surface); }
  .thumb-ph { position: absolute; inset: 0; display: grid; place-items: center; background: linear-gradient(140deg, var(--c-surface-alt2), var(--c-surface-alt)); }
  .thumb-ph i { font-size: 1.5rem; color: rgba(0,0,0,0.15); }
</style>
