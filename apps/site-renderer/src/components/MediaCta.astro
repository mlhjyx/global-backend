---
import { createRequire } from 'node:module'; import { localeQualifiedPageHref } from '../lib/page-reference';
interface Cta {labelKey:string;pageId?:string;url?:string} interface Props {eyebrowKey:string;titleKey:string;titleAccentKey:string;subKey:string;primaryCta:Cta;secondaryCta?:Cta;whatsappLabelKey?:string;whatsappUrl?:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string>}
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {eyebrowKey,titleKey,titleAccentKey,subKey,primaryCta,secondaryCta,whatsappLabelKey,whatsappUrl,variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;const href=(cta:Cta)=>cta.url??localeQualifiedPageHref(cta.pageId??'',pagePathById,locale,defaultLocale);const content={eyebrow:t(eyebrowKey),title:t(titleKey),accent:t(titleAccentKey),sub:t(subKey),primaryCta:t(primaryCta.labelKey),secondaryCta:secondaryCta?t(secondaryCta.labelKey):undefined,whatsapp:whatsappLabelKey&&whatsappUrl?t(whatsappLabelKey):undefined};assertQualifiedComponentContentBudget('MediaCta',content);const headingId=`${instanceId}-media-cta-heading`;
---
<section class={`media-cta media-cta--${variant}`} data-component="MediaCta" data-variant={variant} aria-labelledby={headingId}><div class="texture" aria-hidden="true"></div><div class="container content"><p class="eyebrow">{content.eyebrow}</p><h2 id={headingId}>{content.title} <em>{content.accent}</em></h2><p class="sub">{content.sub}</p><div class="ctas"><a href={href(primaryCta)}>{content.primaryCta}<span aria-hidden="true">→</span></a>{secondaryCta&&<a class="secondary" href={href(secondaryCta)}>{content.secondaryCta}</a>}{content.whatsapp&&<a class="secondary" href={whatsappUrl} rel="noopener noreferrer">{content.whatsapp}</a>}</div></div></section>
<style>.media-cta{position:relative;overflow:hidden;background:#2a1a10;color:var(--c-on-dark);min-height:30rem;display:grid;align-items:center}.texture{position:absolute;inset:0;background:radial-gradient(70% 60% at 25% 50%,color-mix(in srgb,var(--c-secondary) 20%,transparent),transparent 70%),repeating-linear-gradient(120deg,transparent 0 2rem,rgba(255,255,255,.035) 2rem 2.05rem)}.content{position:relative;padding-top:5rem;padding-bottom:5rem;max-width:52rem;margin-left:max(1.5rem,5vw)}.eyebrow{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--c-secondary)}h2{margin-top:1rem;max-width:16ch;font-size:clamp(2.25rem,5vw,4.5rem);line-height:1}h2 em{font-style:italic}.sub{margin-top:1.25rem;max-width:38rem;line-height:1.7;color:color-mix(in srgb,var(--c-on-dark) 85%,transparent)}.ctas{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:2rem}.ctas a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;background:var(--c-secondary);color:var(--c-on-surface)}.ctas a.secondary{border:1px solid currentColor;background:transparent;color:inherit}.ctas a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.media-cta--quiet{background:var(--c-surface-alt);color:var(--c-on-surface)}.media-cta--quiet .texture{background:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 30%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.media-cta--quiet .sub{color:var(--c-on-surface-muted)}</style>
