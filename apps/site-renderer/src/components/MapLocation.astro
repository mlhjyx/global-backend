---
import { createRequire } from 'node:module';

/**
 * Release address card: no map provider, iframe, external request, consent
 * dependency or geolocation. `static` is the legacy alias for technical-grid.
 */
interface Props {
  titleKey: string;
  addressKey: string;
  variant?: 'technical-grid' | 'quiet' | 'static';
  t: (key: string) => string;
  alt?: boolean;
  instanceId: string;
}
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const {
  titleKey,
  addressKey,
  variant: requestedVariant = 'technical-grid',
  t,
  alt,
  instanceId,
} = Astro.props;
const variant = requestedVariant === 'static' ? 'technical-grid' : requestedVariant;
const title = t(titleKey);
const address = t(addressKey);
assertQualifiedComponentContentBudget('MapLocation', { title, address });
const headingId = `${instanceId}-map-location-heading`;
---

<section
  class:list={['block', 'map-location', `map-location--${variant}`, { alt }]}
  data-component="MapLocation"
  data-variant={variant}
  aria-labelledby={headingId}
>
  <h2 id={headingId}>{title}</h2>
  <div class="card" data-location-address>
    <address>{address}</address>
  </div>
</section>

<style>
  h2 {
    margin-bottom: 1.25rem;
  }
  .card {
    border: 1px solid var(--c-surface-alt);
    border-left: 4px solid var(--c-primary);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    max-width: 560px;
  }
  address {
    font-style: normal;
  }
  .map-location--technical-grid .card {
    background:
      linear-gradient(var(--c-surface-alt) 1px, transparent 1px),
      linear-gradient(90deg, var(--c-surface-alt) 1px, transparent 1px),
      var(--c-surface);
    background-size: 1rem 1rem;
  }
  .map-location--quiet .card {
    border-left-width: 1px;
  }
</style>
