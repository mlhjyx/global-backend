---
import { createRequire } from 'node:module';
interface Stat { value:number; suffix?:string; labelKey:string }
interface Props { headingKey:string; stats:Stat[]; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; alt?:boolean; instanceId:string }
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts'); const {headingKey,stats,variant='technical-grid',t,alt,instanceId}=Astro.props; const heading=t(headingKey);const values=stats.map((stat)=>({value:`${stat.value}${stat.suffix??''}`,label:t(stat.labelKey)}));assertQualifiedComponentContentBudget('StatsCountup',{heading,stats:values});const headingId=`${instanceId}-stats-heading`;
---
<section class:list={['block','stats-countup',`stats-countup--${variant}`,{alt}]} data-component="StatsCountup" data-variant={variant} aria-labelledby={headingId}><div class="container"><h2 id={headingId} class="sr-only">{heading}</h2><ul>{values.map((stat)=><li><p class="value">{stat.value}</p><p class="label">{stat.label}</p></li>)}</ul></div></section>
<style>.stats-countup{background:var(--c-primary);color:var(--c-on-dark)}.stats-countup.alt{background:var(--c-surface);color:var(--c-on-surface)}ul{display:grid;grid-template-columns:repeat(2,1fr);gap:2rem 1.5rem;list-style:none;padding:0;margin:0}@media(min-width:1024px){ul{grid-template-columns:repeat(4,1fr);gap:3rem}li:not(:first-child){border-left:1px solid color-mix(in srgb,currentColor 15%,transparent);padding-left:3rem}}.value{font-size:clamp(3rem,7vw,5.5rem);font-weight:600;line-height:1;font-variant-numeric:tabular-nums}.label{margin-top:1rem;font-size:.8rem;letter-spacing:.15em;text-transform:uppercase;opacity:.75}.stats-countup--technical-grid li{background:linear-gradient(color-mix(in srgb,currentColor 10%,transparent) 1px,transparent 1px),linear-gradient(90deg,color-mix(in srgb,currentColor 10%,transparent) 1px,transparent 1px);background-size:1rem 1rem}</style>
