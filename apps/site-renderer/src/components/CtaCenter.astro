---
import { localePageHref } from '../lib/spec';

interface Cta { labelKey: string; pageId?: string; url?: string }
interface Props {
  eyebrowKey: string;
  titleKey: string;
  titleAccentKey?: string;
  subtitleKey: string;
  primaryCta: Cta;
  secondaryCta?: Cta;
  t: (key: string) => string;
  alt?: boolean;
  locale: string;
  defaultLocale: string;
}
const {
  eyebrowKey, titleKey, titleAccentKey, subtitleKey,
  primaryCta, secondaryCta, t, alt, locale, defaultLocale,
} = Astro.props;
const href = (c?: Cta) => c?.url ?? (c?.pageId ? localePageHref(c.pageId, locale, defaultLocale) : '#book');
---

<section class:list={['block', { alt }]}>
  <div class="container cta-center reveal">
    <span class="eyebrow">{t(eyebrowKey)}</span>
    <h2 class="cta-title">
      {t(titleKey)}{titleAccentKey && <em> {t(titleAccentKey)}</em>}
    </h2>
    <p class="muted cta-sub">{t(subtitleKey)}</p>
    <div class="ctas">
      <a class="btn btn-dark btn-lg btn-pill" href={href(primaryCta)}>
        {t(primaryCta.labelKey)}<i class="ri-arrow-right-up-line"></i>
      </a>
      {secondaryCta && (
        <a class="btn btn-ghost btn-lg" href={href(secondaryCta)}>
          {t(secondaryCta.labelKey)}<i class="ri-arrow-right-line"></i>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-center { max-width: 56rem; margin: 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .cta-title { font-size: clamp(2rem, 5.5vw, 4rem); font-weight: 600; max-width: 20ch; margin-top: 1.25rem; }
  .cta-title em { font-style: normal; color: var(--c-accent); }
  .cta-sub { margin-top: 1.25rem; max-width: 36rem; font-size: 1.05rem; }
  .ctas { margin-top: 2rem; display: flex; flex-direction: column; gap: 0.75rem; width: 100%; }
  @media (min-width: 640px) { .ctas { flex-direction: row; align-items: center; justify-content: center; width: auto; } }
</style>
