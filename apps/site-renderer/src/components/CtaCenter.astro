---
import { createRequire } from 'node:module';
import { localePagePathHref } from '../lib/spec';

interface Cta { labelKey: string; pageId?: string; url?: string }
interface Props {
  eyebrowKey: string;
  titleKey: string;
  titleAccentKey?: string;
  subtitleKey: string;
  primaryCta: Cta;
  secondaryCta?: Cta;
  variant?: 'technical-grid' | 'quiet';
  t: (key: string) => string;
  alt?: boolean;
  locale: string;
  defaultLocale: string;
  instanceId: string;
  pagePathById?: Record<string, string>;
}
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const {
  eyebrowKey, titleKey, titleAccentKey, subtitleKey, primaryCta, secondaryCta,
  variant = 'technical-grid', t, alt, locale, defaultLocale, instanceId, pagePathById = {},
} = Astro.props;
const content = {
  eyebrow: t(eyebrowKey),
  title: t(titleKey),
  accent: titleAccentKey ? t(titleAccentKey) : undefined,
  subtitle: t(subtitleKey),
  primaryCta: t(primaryCta.labelKey),
  secondaryCta: secondaryCta ? t(secondaryCta.labelKey) : undefined,
};
assertQualifiedComponentContentBudget('CtaCenter', content);
const headingId = `${instanceId}-cta-center-heading`;
const href = (cta: Cta) => {
  if (cta.url) return cta.url;
  const pagePath = cta.pageId ? pagePathById[cta.pageId] : undefined;
  if (!pagePath) throw new Error('PAGE_REFERENCE_UNKNOWN: CtaCenter.' + (cta.pageId ?? '(empty)'));
  return localePagePathHref(pagePath, locale, defaultLocale);
};
---

<section class:list={['block', 'cta-center', `cta-center--${variant}`, { alt }]} data-component="CtaCenter" data-variant={variant} aria-labelledby={headingId}>
  <div class="container cta-center__content">
    <span class="eyebrow">{content.eyebrow}</span>
    <h2 id={headingId} class="cta-title">
      {content.title}{content.accent && <em> {content.accent}</em>}
    </h2>
    <p class="muted cta-sub">{content.subtitle}</p>
    <div class="ctas">
      <a class="btn btn-dark btn-lg btn-pill" href={href(primaryCta)}>
        {content.primaryCta}<i class="ri-arrow-right-up-line" aria-hidden="true"></i>
      </a>
      {secondaryCta && content.secondaryCta && (
        <a class="btn btn-ghost btn-lg" href={href(secondaryCta)}>
          {content.secondaryCta}<i class="ri-arrow-right-line" aria-hidden="true"></i>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-center { background-image: linear-gradient(color-mix(in srgb, var(--c-border) 45%, transparent) 1px, transparent 1px), linear-gradient(90deg, color-mix(in srgb, var(--c-border) 45%, transparent) 1px, transparent 1px); background-size: 2rem 2rem; }
  .cta-center--quiet { background-image: none; }
  .cta-center__content { max-width: 56rem; margin: 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .cta-title { font-size: clamp(2rem, 5.5vw, 4rem); font-weight: 600; max-width: 20ch; margin-top: 1.25rem; }
  .cta-title em { font-style: normal; color: var(--c-accent); }
  .cta-sub { margin-top: 1.25rem; max-width: 36rem; font-size: 1.05rem; }
  .ctas { margin-top: 2rem; display: flex; flex-direction: column; gap: 0.75rem; width: 100%; }
  @media (min-width: 640px) { .ctas { flex-direction: row; align-items: center; justify-content: center; width: auto; } }
</style>
