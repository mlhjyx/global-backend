---
import { withBase } from '../lib/links';

interface Props {
  assetId?: string;
  variantUrl?: string;
  alt: string;
  width: number;
  height: number;
  class?: string;
}

const { assetId, variantUrl, alt, width, height, class: className } = Astro.props;
const resolvedUrl =
  variantUrl && /^\/(?!\/)/.test(variantUrl) ? withBase(variantUrl) : undefined;
---

{
  assetId && resolvedUrl ? (
    <picture class={className} data-asset-variant="gallery-card/v1">
      <source media="(min-width: 768px)" srcset={resolvedUrl} />
      <img src={resolvedUrl} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
    </picture>
  ) : (
    <span data-asset-fallback aria-hidden="true">{assetId ?? ""}</span>
  )
}
