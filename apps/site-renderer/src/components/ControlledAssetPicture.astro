---
interface Props {
  assetId?: string;
  alt: string;
  width: number;
  height: number;
  class?: string;
}

const { assetId, alt, width, height, class: className } = Astro.props;
---

{
  assetId ? (
    <picture class={className} data-asset-variant="gallery-card/v1">
      <source media="(min-width: 768px)" srcset={`#asset:${assetId}`} />
      <img src={`#asset:${assetId}`} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
    </picture>
  ) : null
}
