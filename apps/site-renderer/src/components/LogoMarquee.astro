---
import { createRequire } from 'node:module';

import type { Translate } from '../i18n';

const require = createRequire(import.meta.url);
const { assertQualifiedComponentContentBudget } = require('@global/contracts') as typeof import('@global/contracts');

type Props = {
  id?: string;
  instanceId: string;
  eyebrowKey: string;
  titleKey: string;
  titleLine2Key?: string;
  items: string[];
  variant?: 'technical-grid' | 'quiet';
  t: Translate;
  alt?: boolean;
};

const { id, instanceId, eyebrowKey, titleKey, titleLine2Key, items, variant = 'technical-grid', t, alt } = Astro.props;
const eyebrow = t(eyebrowKey);
const title = [t(titleKey), titleLine2Key ? t(titleLine2Key) : undefined].filter(Boolean).join(' ');
assertQualifiedComponentContentBudget('LogoMarquee', { eyebrow, title, items });
const baseId = `logo-marquee-${id ?? 'section'}-${instanceId}`.replace(/[^a-zA-Z0-9_-]/g, '-');
const headingId = `${baseId}-heading`;
---

<section class:list={['block', 'logo-marquee', `logo-marquee--${variant}`, { alt }]} data-component="LogoMarquee" data-variant={variant} aria-labelledby={headingId}>
  <div class="container logo-marquee__intro">
    <p class="logo-marquee__eyebrow">{eyebrow}</p>
    <h2 id={headingId}>{t(titleKey)}{titleLine2Key && <><br />{t(titleLine2Key)}</>}</h2>
  </div>
  <div class="logo-marquee__viewport">
    <div class="logo-marquee__track">
      <ul role="list">{items.map((item) => <li>{item}</li>)}</ul>
      <ul aria-hidden="true">{items.map((item) => <li>{item}</li>)}</ul>
    </div>
  </div>
</section>

<style>
  .logo-marquee { overflow: hidden; background: var(--c-surface); border-block: 1px solid var(--c-border); }
  .logo-marquee.alt { background: var(--c-surface-alt); }
  .logo-marquee__intro { max-width: 42rem; }
  .logo-marquee__eyebrow { margin: 0 0 .65rem; color: var(--c-primary); font: 700 .75rem/1.2 var(--font-sans, sans-serif); letter-spacing: .12em; text-transform: uppercase; }
  h2 { margin: 0; color: var(--c-on-surface); font: 700 clamp(1.75rem, 4vw, 3.25rem)/1.06 var(--font-display, var(--font-sans, sans-serif)); letter-spacing: -.025em; text-wrap: balance; }
  .logo-marquee__viewport { margin-top: clamp(1.75rem, 4vw, 3rem); overflow: hidden; border-block: 1px solid var(--c-border); }
  .logo-marquee__track { display: flex; width: max-content; animation: logo-marquee-scroll 42s linear infinite; }
  ul { display: flex; align-items: stretch; margin: 0; padding: 0; list-style: none; }
  li { display: grid; min-width: min(15rem, 72vw); place-items: center; padding: 1.25rem 2.25rem; border-right: 1px solid var(--c-border); color: var(--c-on-surface); font: 700 clamp(1rem, 2vw, 1.4rem)/1.2 var(--font-display, var(--font-sans, sans-serif)); text-align: center; overflow-wrap: anywhere; }
  .logo-marquee--technical-grid { background-image: linear-gradient(to right, color-mix(in srgb, var(--c-border) 42%, transparent) 1px, transparent 1px); background-size: 4rem 100%; }
  .logo-marquee--quiet { background-image: none; }
  @keyframes logo-marquee-scroll { to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .logo-marquee__viewport { overflow: visible; } .logo-marquee__track { width: auto; animation: none; } .logo-marquee__track > ul[aria-hidden='true'] { display: none; } ul { width: 100%; flex-wrap: wrap; } li { flex: 1 1 12rem; } }
</style>
