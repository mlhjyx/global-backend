---
import { createRequire } from 'node:module'; import { localeQualifiedPageHref } from '../lib/page-reference';
interface Service {code:string;titleKey:string;bodyKey:string;specKey:string} interface Props {chapterKey:string;titleKey?:string;services:Service[];notListKey?:string;notListBodyKey?:string;notListCtaKey?:string;bookLabelKey?:string;bookPageId?:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string>}
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {chapterKey,titleKey='services.titleLine',services,notListKey,notListBodyKey,notListCtaKey,bookLabelKey,bookPageId='book',variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;const hasBookCta=Boolean(bookLabelKey);const hasAside=Boolean(notListKey&&notListBodyKey);const hasAsideCta=Boolean(hasAside&&notListCtaKey);const hasVisibleCta=hasBookCta||hasAsideCta;const content={chapter:t(chapterKey),title:t(titleKey),services:services.map((s)=>({code:s.code,title:t(s.titleKey),body:t(s.bodyKey),spec:t(s.specKey)})),cta:bookLabelKey?t(bookLabelKey):undefined,asideLabel:notListKey&&notListBodyKey?t(notListKey):undefined,aside:notListKey&&notListBodyKey?t(notListBodyKey):undefined,asideCta:notListKey&&notListBodyKey&&notListCtaKey?t(notListCtaKey):undefined};assertQualifiedComponentContentBudget('ServicesEditorial',content);const headingId=`${instanceId}-services-editorial-heading`;const href=hasVisibleCta?localeQualifiedPageHref(bookPageId,pagePathById,locale,defaultLocale):undefined;
---
<section class={`services-editorial services-editorial--${variant}`} data-component="ServicesEditorial" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><p>{content.chapter}</p><h2 id={headingId}>{content.title}</h2></header><ul>{content.services.map((service)=><li><article><p>{service.code} · {service.spec}</p><h3>{service.title}</h3><p>{service.body}</p>{content.cta&&href&&<a href={href}>{content.cta}<span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a>}</article></li>)}{hasAside&&<li><aside><p>{content.asideLabel}</p><p>{content.aside}</p>{content.asideCta&&href&&<a href={href}>{content.asideCta}<span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a>}</aside></li>}</ul></div></section>
<style>.services-editorial{padding-block:clamp(4rem,8vw,7rem);background:var(--c-surface)}.services-editorial--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 28%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{display:flex;gap:1rem;align-items:baseline;justify-content:space-between;flex-wrap:wrap;margin-bottom:2rem}header p,article>p,aside>p:first-child{font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{font-size:clamp(2.2rem,5vw,4rem)}ul{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,16rem),1fr));gap:1rem;list-style:none;margin:0;padding:0}article,aside{height:100%;padding:1.25rem;border:1px solid var(--c-border);background:var(--c-surface)}h3{margin-top:2rem;font-size:1.5rem}article>p:not(:first-child),aside>p:not(:first-child){margin-top:.75rem;line-height:1.65;color:var(--c-on-surface-muted)}a{display:inline-flex;min-height:2.75rem;align-items:center;gap:.5rem;margin-top:1.5rem;color:var(--c-on-surface);border-bottom:1px solid currentColor}a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.services-editorial--quiet{background:var(--c-surface-alt)}</style>
