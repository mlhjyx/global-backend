---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Cta { labelKey:string; pageId?:string; url?:string } interface Stat { value:string; labelKey:string }
interface Props { eyebrowKey:string;h1Key:string;h1AccentKey:string;subKey:string;primaryCta:Cta;secondaryCta?:Cta;stats:Stat[];scrollKey:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string> }
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');
const {eyebrowKey,h1Key,h1AccentKey,subKey,primaryCta,secondaryCta,stats,scrollKey,variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;
const href=(cta:Cta)=>cta.url??localeQualifiedPageHref(cta.pageId ?? '',pagePathById,locale,defaultLocale);
const content={eyebrow:t(eyebrowKey),title:t(h1Key),accent:t(h1AccentKey),sub:t(subKey),primaryCta:t(primaryCta.labelKey),secondaryCta:secondaryCta?t(secondaryCta.labelKey):undefined,stats:stats.map((stat)=>({value:stat.value,label:t(stat.labelKey)})),scroll:t(scrollKey)};assertQualifiedComponentContentBudget('WarmHero',content);const headingId=`${instanceId}-warm-hero-heading`;
---
<section class:list={['warm-hero',`warm-hero--${variant}`]} data-component="WarmHero" data-variant={variant} aria-labelledby={headingId}><div class="texture" aria-hidden="true"></div><div class="container content"><p class="eyebrow">{content.eyebrow}</p><h1 id={headingId}>{content.title} <em>{content.accent}</em></h1><p class="sub">{content.sub}</p><div class="ctas"><a href={href(primaryCta)}>{content.primaryCta}<span aria-hidden="true">→</span></a>{secondaryCta&&<a class="secondary" href={href(secondaryCta)}>{content.secondaryCta}</a>}</div><ul class="stats">{content.stats.map((stat)=><li><strong>{stat.value}</strong><span>{stat.label}</span></li>)}</ul><p class="scroll">{content.scroll}</p></div></section>
<style>.warm-hero{position:relative;overflow:hidden;background:#3a2a1c;color:var(--c-on-dark);min-height:min(44rem,82vh);display:grid;align-items:center}.texture{position:absolute;inset:0;background:radial-gradient(64% 58% at 50% 22%,color-mix(in srgb,var(--c-secondary) 20%,transparent),transparent 68%),repeating-linear-gradient(135deg,transparent 0 2rem,rgba(255,255,255,.035) 2rem 2.05rem)}.content{position:relative;padding-top:7rem;padding-bottom:4rem;text-align:center}.eyebrow,.scroll{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase}.eyebrow{color:color-mix(in srgb,var(--c-secondary) 82%,white)}h1{margin:1rem auto 0;max-width:15ch;font-size:clamp(2.75rem,7vw,5.75rem);line-height:.98}h1 em{font-style:italic;color:var(--c-secondary)}.sub{margin:1.5rem auto 0;max-width:42rem;line-height:1.7;color:color-mix(in srgb,var(--c-on-dark) 85%,transparent)}.ctas{margin-top:2rem;display:flex;justify-content:center;gap:.75rem;flex-wrap:wrap}.ctas a{display:inline-flex;align-items:center;gap:.5rem;min-height:2.75rem;padding:.55rem 1rem;background:var(--c-secondary);color:var(--c-on-surface)}.ctas a:hover,.ctas a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.ctas .secondary{background:transparent;color:inherit;border:1px solid currentColor}.stats{margin:3rem auto 0;max-width:40rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(7rem,1fr));gap:1rem;list-style:none;padding:0}.stats strong{display:block;font-size:clamp(1.4rem,3vw,2rem);color:var(--c-secondary)}.stats span{display:block;margin-top:.3rem;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase}.scroll{margin-top:3rem;color:color-mix(in srgb,var(--c-on-dark) 75%,transparent)}.warm-hero--quiet{background:var(--c-surface-alt);color:var(--c-on-surface)}.warm-hero--quiet .texture{background:radial-gradient(64% 58% at 50% 22%,color-mix(in srgb,var(--c-secondary) 14%,transparent),transparent 68%)}.warm-hero--quiet .sub,.warm-hero--quiet .scroll{color:var(--c-on-surface-muted)}</style>
