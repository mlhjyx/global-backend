---
import { createRequire } from 'node:module';

interface Piece { tagKey: string; nameKey: string; specKey: string }
interface Props {
  chapterKey: string;
  h1aKey: string;
  h1bKey: string;
  pieces: Piece[];
  variant?: 'technical-grid' | 'quiet';
  t: (key: string) => string;
  instanceId: string;
}

const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { chapterKey, h1aKey, h1bKey, pieces, variant = 'technical-grid', t, instanceId } = Astro.props;
const content = {
  chapter: t(chapterKey),
  title: `${t(h1aKey)} ${t(h1bKey)}`,
  pieces: pieces.map((piece) => ({ tag: t(piece.tagKey), name: t(piece.nameKey), spec: t(piece.specKey) })),
};
assertQualifiedComponentContentBudget('ChapterShowcase', content);
const headingId = `${instanceId}-chapter-showcase-heading`;
---

<section
  class:list={['chapter-showcase', `chapter-showcase--${variant}`]}
  data-component="ChapterShowcase"
  data-variant={variant}
  aria-labelledby={headingId}
>
  <div class="container">
    <header>
      <p class="chapter">{content.chapter}</p>
      <h2 id={headingId}>{content.title}</h2>
    </header>
    <ul>
      {content.pieces.map((piece, index) => (
        <li>
          <article>
            <p class="index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</p>
            <p class="tag">{piece.tag}</p>
            <h3>{piece.name}</h3>
            <p class="spec">{piece.spec}</p>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .chapter-showcase { background: var(--c-surface); color: var(--c-on-surface); }
  .chapter-showcase--technical-grid { background-image: linear-gradient(90deg, color-mix(in srgb, var(--c-border) 28%, transparent) 1px, transparent 1px); background-size: 2rem 2rem; }
  header { max-width: 46rem; margin-bottom: 2rem; }
  .chapter, .tag { font-size: .72rem; letter-spacing: .16em; text-transform: uppercase; color: var(--c-on-surface-muted); }
  h2 { margin-top: .75rem; font-size: clamp(2.25rem, 5vw, 4rem); }
  ul { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr)); gap: 1rem; margin: 0; padding: 0; list-style: none; }
  article { height: 100%; padding: 1.25rem; border: 1px solid var(--c-border); background: var(--c-surface); }
  .index { color: var(--c-primary); font-size: 1.35rem; }
  .tag { margin-top: 2.5rem; }
  h3 { margin-top: .5rem; font-size: 1.3rem; }
  .spec { margin-top: .75rem; line-height: 1.6; color: var(--c-on-surface-muted); }
  .chapter-showcase--quiet { background: var(--c-surface-alt); }
</style>
