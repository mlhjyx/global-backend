---
interface Piece { tagKey: string; nameKey: string; specKey: string }
interface Props {
  chapterKey: string;
  h1aKey: string;
  h1bKey: string;
  pieces: Piece[];
  t: (key: string) => string;
}
const { chapterKey, h1aKey, h1bKey, pieces = [], t } = Astro.props;
---

<section class="chapter-showcase" id="line">
  <div class="hairline"></div>
  <div class="inner">
    <div class="chapter-tag reveal">{t(chapterKey)}</div>
    <div class="headline reveal" style="transition-delay:160ms">
      <span class="h-word">{t(h1aKey)}</span>
      <span class="h-line"><span class="h-line-fill"></span></span>
      <span class="h-word">{t(h1bKey)}</span>
    </div>

    <div class="grid">
      {pieces.map((p, i) => (
        <article class="card reveal" style={`transition-delay:${360 + i * 80}ms`}>
          <div class="ph"><i class="ri-headphone-line"></i></div>
          <div class="overlay"></div>
          <span class="tag">{t(p.tagKey)}</span>
          <div class="cap">
            <h3>{t(p.nameKey)}</h3>
            <span class="spec">{t(p.specKey)}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .chapter-showcase { position: relative; background: var(--c-surface); color: var(--c-on-surface); font-family: var(--font-body); padding: clamp(4rem, 9vw, 7rem) 0; overflow: hidden; }
  .hairline { position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(to right, transparent, rgba(255,255,255,0.16) 20%, rgba(255,255,255,0.16) 80%, transparent); }
  .inner { max-width: 84rem; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3.5rem); }
  .chapter-tag { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.32em; color: var(--c-primary); font-weight: 500; margin-bottom: 1.25rem; }
  .headline { display: flex; align-items: center; gap: 1.75rem; margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
  .h-word { font-size: clamp(2.75rem, 5.6vw, 5.5rem); font-weight: 700; line-height: 0.9; letter-spacing: -0.045em; white-space: nowrap; }
  .h-line { flex: 1; position: relative; height: 8px; min-width: 3rem; }
  .h-line-fill { position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 100%; height: 4px; background: var(--c-primary); box-shadow: 0 0 20px rgba(122,168,238,0.35); }
  .grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 768px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .grid { grid-template-columns: repeat(4, 1fr); } }
  .card { position: relative; aspect-ratio: 16 / 11; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); transition: border-color .4s ease; }
  .card:hover { border-color: rgba(122,168,238,0.4); }
  .ph { position: absolute; inset: 0; display: grid; place-items: center; background: radial-gradient(60% 50% at 40% 30%, color-mix(in srgb, var(--c-primary) 14%, transparent), transparent 60%), linear-gradient(140deg, #1B2435, #0F1420); }
  .ph i { font-size: 3rem; color: rgba(255,255,255,0.12); }
  .overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.42) 0%, transparent 30%, transparent 60%, rgba(0,0,0,0.58) 100%); }
  .tag { position: absolute; top: 1.25rem; left: 1.25rem; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.32em; color: var(--c-primary); font-weight: 500; }
  .cap { position: absolute; bottom: 1.25rem; left: 1.5rem; right: 1.5rem; display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; }
  .cap h3 { font-size: clamp(1.5rem, 3vw, 3rem); font-weight: 700; line-height: 0.95; letter-spacing: -0.025em; }
  .cap .spec { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.28em; color: rgba(255,255,255,0.55); white-space: nowrap; }
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 900ms ease, transform 900ms cubic-bezier(0.22,1,0.36,1); }
  .reveal { opacity: 1; transform: translateY(0); }
</style>
