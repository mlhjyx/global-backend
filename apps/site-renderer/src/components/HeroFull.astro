---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Cta { labelKey:string; pageId?:string; url?:string } interface Selector { icon:string; titleKey:string; subtitleKey:string; tagKey:string } interface Props { eyebrowKey:string; ratingKey?:string; h1aKey:string; h1bKey:string; h1cKey:string; subKey:string; primaryCta:Cta; secondaryCta?:Cta; selectors?:Selector[]; revealSuffixKey?:string; revealCta?:Cta; image?:{assetId:string}|null; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; locale:string; defaultLocale:string; instanceId:string; pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget }=createRequire(import.meta.url)('@global/contracts'); const {eyebrowKey,ratingKey,h1aKey,h1bKey,h1cKey,subKey,primaryCta,secondaryCta,selectors=[],revealSuffixKey,revealCta,image=null,variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props; const content={eyebrow:t(eyebrowKey),rating:ratingKey?t(ratingKey):undefined,title:`${t(h1aKey)} ${t(h1bKey)} ${t(h1cKey)}`,sub:t(subKey),primaryCta:t(primaryCta.labelKey),secondaryCta:secondaryCta?t(secondaryCta.labelKey):undefined,contexts:selectors.map((item)=>({tag:t(item.tagKey),title:t(item.titleKey),subtitle:t(item.subtitleKey)})),revealSuffix:revealSuffixKey?t(revealSuffixKey):undefined,revealCta:revealCta?t(revealCta.labelKey):undefined}; assertQualifiedComponentContentBudget('HeroFull',content); const headingId=`${instanceId}-hero-full-heading`; const href=(cta:Cta)=>cta.url ?? localeQualifiedPageHref(cta.pageId!,pagePathById,locale,defaultLocale);
---
<section class={`hero-full hero-full--${variant}`} data-component="HeroFull" data-variant={variant} aria-labelledby={headingId}><div class="image" aria-hidden="true">{image && <img src={`#asset:${image.assetId}`} alt="" />}</div><div class="container"><header><p>{content.eyebrow}</p>{content.rating && <p>{content.rating}</p>}</header><div><h1 id={headingId}>{t(h1aKey)}<br /><em>{t(h1bKey)}</em><br />{t(h1cKey)}</h1><p class="sub">{content.sub}</p><div class="ctas"><a href={href(primaryCta)}>{content.primaryCta}<span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a>{secondaryCta && <a class="secondary" href={href(secondaryCta)}>{content.secondaryCta}</a>}</div>{content.contexts.length>0 && <ul class="context">{content.contexts.map((item)=><li><p>{item.tag}</p><h2>{item.title}</h2><span>{item.subtitle}</span></li>)}</ul>}{content.revealSuffix && <p class="reveal-note">{content.revealSuffix} {revealCta && <a href={href(revealCta)}>{content.revealCta}</a>}</p>}</div></div></section>
<style>
.hero-full{position:relative;min-height:80svh;padding:clamp(5rem,10vw,9rem) 0;background:var(--c-surface);color:var(--c-on-surface);overflow:hidden}.hero-full--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 30%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.image{position:absolute;inset:0;opacity:.14}.image img{width:100%;height:100%;object-fit:cover}.container{position:relative;min-height:60svh;display:flex;flex-direction:column;justify-content:space-between}header{display:flex;justify-content:space-between;gap:1rem;font:.72rem var(--font-mono);letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h1{font-size:clamp(3.2rem,9vw,7rem);line-height:.9}em{font-style:italic;color:var(--c-accent)}.sub{max-width:38rem;margin-top:1.5rem;line-height:1.7}.ctas{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:2rem}.ctas a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;background:var(--c-primary);color:var(--c-on-primary)}.ctas .secondary{background:transparent;color:inherit;border:1px solid currentColor}.ctas a:focus-visible,.reveal-note a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.context{display:grid;grid-template-columns:repeat(auto-fit,minmax(11rem,1fr));gap:.75rem;list-style:none;margin:2rem 0 0;padding:0}.context li{border-top:1px solid var(--c-border);padding-top:.75rem}.context p{font:.7rem var(--font-mono);letter-spacing:.1em;text-transform:uppercase;color:var(--c-on-surface-muted)}.context h2{margin-top:.5rem;font-size:1.1rem}.context span,.reveal-note{display:block;margin-top:.5rem;color:var(--c-on-surface-muted)}.reveal-note a{color:inherit;text-decoration:underline}.hero-full--quiet{background:var(--c-surface-alt)}
</style>
