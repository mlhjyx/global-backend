---
import { localePageHref } from '../lib/spec';

interface Cta { labelKey: string; pageId?: string; url?: string }
interface Selector { icon: string; titleKey: string; subtitleKey: string; tagKey: string }
interface Props {
  eyebrowKey: string;
  ratingKey?: string;
  h1aKey: string;
  h1bKey: string;
  h1cKey: string;
  subKey: string;
  primaryCta: Cta;
  secondaryCta?: Cta;
  selectors?: Selector[];
  revealSuffixKey?: string;
  revealCta?: Cta;
  image?: { assetId: string } | null;
  t: (key: string) => string;
  locale: string;
  defaultLocale: string;
}
const {
  eyebrowKey, ratingKey, h1aKey, h1bKey, h1cKey, subKey,
  primaryCta, secondaryCta, selectors = [], revealSuffixKey, revealCta,
  image = null, t, locale, defaultLocale,
} = Astro.props;
const href = (c?: Cta) =>
  c?.url ?? (c?.pageId ? localePageHref(c.pageId, locale, defaultLocale) : '#book');
---

<section class="hero-wrap" data-hero-selector>
  <div class="hero-frame">
    <div class="hero-bg" aria-hidden="true">
      {image ? (
        <img src={`#asset:${image.assetId}`} alt="" />
      ) : null}
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content">
      <div class="hero-top">
        <span class="hero-pill">
          <span class="pulse-dot"></span>
          {t(eyebrowKey)}
        </span>
        {ratingKey && (
          <span class="hero-rating"><i class="ri-star-fill"></i> {t(ratingKey)}</span>
        )}
      </div>

      <div class="hero-mid">
        <h1>
          {t(h1aKey)}<br />
          for <span class="accent">{t(h1bKey)}</span><br class="br-md" />
          <em>{t(h1cKey)}</em>
        </h1>
        <p class="hero-sub">{t(subKey)}</p>
        <div class="hero-ctas">
          <a class="btn btn-accent btn-lg btn-pill" href={href(primaryCta)}>
            {t(primaryCta.labelKey)}<i class="ri-arrow-right-up-line"></i>
          </a>
          {secondaryCta && (
            <a class="btn btn-on-dark-outline btn-lg btn-pill" href={href(secondaryCta)}>
              {t(secondaryCta.labelKey)}<i class="ri-arrow-right-line"></i>
            </a>
          )}
        </div>
      </div>

      {selectors.length > 0 && (
        <div class="hero-bottom">
          <div class="hero-selectors">
            {selectors.map((s) => (
              <button
                type="button"
                class="hero-card"
                data-hero-card
                data-title={t(s.titleKey)}
                data-subtitle={t(s.subtitleKey)}
              >
                <div class="hero-card-top">
                  <span class="hero-card-icon"><i class={s.icon}></i></span>
                  <span class="hero-card-tag">{t(s.tagKey)}</span>
                </div>
                <h3>{t(s.titleKey)}</h3>
                <p>{t(s.subtitleKey)}</p>
              </button>
            ))}
          </div>

          {revealSuffixKey && (
            <div class="hero-reveal" data-hero-reveal>
              <span class="hero-reveal-check"><i class="ri-check-line"></i></span>
              <div class="hero-reveal-text">
                <p class="hero-reveal-title"><span data-reveal-title></span> {t(revealSuffixKey)}</p>
                <p class="hero-reveal-sub" data-reveal-sub></p>
              </div>
              {revealCta && (
                <a class="btn btn-dark btn-pill" href={href(revealCta)}>
                  {t(revealCta.labelKey)}<i class="ri-arrow-right-up-line"></i>
                </a>
              )}
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<script>
  // Hero contract-on-scroll: as the page scrolls, the hero frames itself (padding + radius).
  const wrap = document.querySelector('.hero-wrap') as HTMLElement | null;
  const frame = document.querySelector('.hero-frame') as HTMLElement | null;
  if (wrap && frame && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const DISTANCE = 280;
    const apply = () => {
      const p = Math.min(1, Math.max(0, window.scrollY / DISTANCE));
      const pad = p * 16;
      const radius = p * 24;
      wrap.style.paddingLeft = `${pad}px`;
      wrap.style.paddingRight = `${pad}px`;
      wrap.style.paddingTop = `${pad}px`;
      frame.style.borderRadius = `${radius}px`;
    };
    apply();
    window.addEventListener('scroll', apply, { passive: true });
  }
</script>

<style>
  .hero-wrap {
    padding: 0;
    transition: padding 0.15s ease-out;
  }
  .hero-frame {
    position: relative;
    width: 100%;
    min-height: 100svh;
    overflow: hidden;
    transition: border-radius 0.15s ease-out;
  }
  .hero-bg { position: absolute; inset: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
  .hero-bg {
    background:
      radial-gradient(120% 90% at 70% 10%, color-mix(in srgb, var(--c-primary) 55%, transparent), transparent 60%),
      linear-gradient(135deg, var(--c-primary-dark), var(--c-primary) 55%, var(--c-secondary));
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      color-mix(in srgb, var(--c-primary-dark) 70%, transparent),
      color-mix(in srgb, var(--c-primary-dark) 40%, transparent) 45%,
      color-mix(in srgb, var(--c-primary-dark) 82%, transparent));
  }
  .hero-content {
    position: relative;
    z-index: 2;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2.5rem;
    padding: calc(var(--header-h) + 1.5rem) clamp(1rem, 5vw, 4rem) 2rem;
    color: var(--c-on-dark);
  }
  @media (min-width: 768px) { .hero-content { gap: 3.5rem; padding-top: calc(var(--header-h) + 2rem); } }
  .hero-top { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .hero-pill {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.35rem 0.8rem;
    border-radius: 9999px;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.25);
    font-size: 0.75rem;
    color: var(--c-on-dark);
  }
  .hero-rating { display: none; align-items: center; gap: 0.4rem; font-size: 0.75rem; color: var(--c-on-dark-muted); }
  .hero-rating i { color: var(--c-accent); }
  @media (min-width: 768px) { .hero-rating { display: inline-flex; } }
  .hero-mid { max-width: 48rem; }
  h1 {
    font-size: clamp(2.1rem, 7vw, 5.3rem);
    line-height: 1.02;
    color: var(--c-on-dark);
    font-weight: 600;
  }
  h1 .accent { color: var(--c-accent); }
  h1 em { font-style: italic; font-weight: 500; }
  .br-md { display: none; }
  @media (min-width: 768px) { .br-md { display: inline; } }
  .hero-sub {
    margin-top: 1.25rem;
    max-width: 36rem;
    font-size: clamp(0.95rem, 1.5vw, 1.125rem);
    color: var(--c-on-dark-muted);
    line-height: 1.6;
  }
  .hero-ctas { margin-top: 1.75rem; display: flex; flex-direction: column; gap: 0.75rem; }
  @media (min-width: 640px) { .hero-ctas { flex-direction: row; align-items: center; } }
  .hero-bottom { display: flex; flex-direction: column; gap: 0.75rem; }
  .hero-selectors { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
  @media (min-width: 640px) { .hero-selectors { grid-template-columns: repeat(3, 1fr); } }
  .hero-card {
    text-align: left;
    padding: 1.25rem;
    border-radius: var(--radius-lg);
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.25);
    color: var(--c-on-dark);
    cursor: pointer;
    transition: transform .3s ease, background .3s ease, border-color .3s ease;
  }
  .hero-card:hover { background: rgba(255,255,255,0.15); transform: translateY(-2px); }
  .hero-card.active {
    background: var(--c-accent);
    color: var(--c-on-accent);
    border-color: var(--c-accent);
    transform: translateY(-2px);
  }
  .hero-card-top { display: flex; align-items: center; justify-content: space-between; }
  .hero-card-icon {
    width: 2.5rem; height: 2.5rem;
    display: grid; place-items: center;
    border-radius: 9999px;
    background: rgba(255,255,255,0.15);
  }
  .hero-card.active .hero-card-icon { background: var(--c-primary-dark); color: var(--c-accent); }
  .hero-card-icon i { font-size: 1.1rem; }
  .hero-card-tag {
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.16em;
    padding: 0.25rem 0.5rem; border-radius: 9999px;
    background: rgba(255,255,255,0.1);
  }
  .hero-card.active .hero-card-tag { background: rgba(14,26,51,0.1); }
  .hero-card h3 { margin-top: 1rem; font-size: 1.15rem; font-weight: 600; }
  .hero-card p { margin-top: 0.25rem; font-size: 0.875rem; color: var(--c-on-dark-muted); }
  .hero-card.active p { color: color-mix(in srgb, var(--c-on-accent) 80%, transparent); }
  .hero-reveal {
    display: none;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-lg);
    background: var(--c-surface);
    color: var(--c-on-surface);
  }
  @media (min-width: 640px) { .hero-reveal { flex-direction: row; align-items: center; justify-content: space-between; } }
  .hero-reveal.show { display: flex; animation: fade-up 0.4s ease-out both; }
  @keyframes fade-up { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .hero-reveal-check {
    width: 2.25rem; height: 2.25rem;
    display: grid; place-items: center;
    border-radius: 9999px;
    background: var(--c-accent);
    color: var(--c-on-accent);
    flex: none;
  }
  .hero-reveal-text { flex: 1; }
  .hero-reveal-title { font-size: 0.9rem; font-weight: 600; }
  .hero-reveal-sub { font-size: 0.85rem; color: var(--c-on-surface-muted); }
</style>
