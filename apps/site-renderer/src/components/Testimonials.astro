---
import { createRequire } from 'node:module';

import type { Translate } from '../i18n';

const require = createRequire(import.meta.url);
const { assertQualifiedComponentContentBudget } = require('@global/contracts') as typeof import('@global/contracts');

type Testimonial = { quoteKey: string; nameKey: string; postcodeKey: string; rating: number; platformKey: string };
type Props = { id?: string; instanceId: string; eyebrowKey: string; titleKey?: string; items: Testimonial[]; variant?: 'technical-grid' | 'quiet'; t: Translate; alt?: boolean };
const { id, instanceId, eyebrowKey, titleKey, items, variant = 'technical-grid', t, alt } = Astro.props;
const eyebrow = t(eyebrowKey);
const title = titleKey ? t(titleKey) : eyebrow;
const resolvedItems = items.map((item) => ({ quote: t(item.quoteKey), name: t(item.nameKey), location: t(item.postcodeKey), platform: t(item.platformKey), rating: item.rating }));
assertQualifiedComponentContentBudget('Testimonials', { eyebrow, title, items: resolvedItems });
const baseId = `testimonials-${id ?? 'section'}-${instanceId}`.replace(/[^a-zA-Z0-9_-]/g, '-');
const headingId = `${baseId}-heading`;
---

<section class:list={['block', 'testimonials', `testimonials--${variant}`, { alt }]} data-component="Testimonials" data-variant={variant} aria-labelledby={headingId}>
  <div class="container">
    <p class="testimonials__eyebrow">{eyebrow}</p>
    <h2 id={headingId}>{title}</h2>
    <ul class="testimonials__list" role="list">
      {resolvedItems.map((item, index) => {
        const itemId = `${baseId}-item-${index + 1}`;
        return <li><article aria-labelledby={itemId}><blockquote><p>{item.quote}</p></blockquote><footer><h3 id={itemId}>{item.name}</h3><p>{item.location}</p><p><span aria-label={`${item.rating.toFixed(1)} out of 5`}>{item.rating.toFixed(1)} / 5</span><span aria-hidden="true"> · </span>{item.platform}</p></footer></article></li>;
      })}
    </ul>
  </div>
</section>

<style>
  .testimonials { background: var(--c-surface); border-block: 1px solid var(--c-border); }
  .testimonials.alt { background: var(--c-surface-alt); }
  .testimonials__eyebrow { margin: 0 0 .65rem; color: var(--c-primary); font: 700 .75rem/1.2 var(--font-sans, sans-serif); letter-spacing: .12em; text-transform: uppercase; }
  h2 { margin: 0; color: var(--c-on-surface); font: 700 clamp(1.75rem, 4vw, 3.25rem)/1.06 var(--font-display, var(--font-sans, sans-serif)); letter-spacing: -.025em; }
  .testimonials__list { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr)); gap: 1px; margin: 2rem 0 0; padding: 1px; list-style: none; background: var(--c-border); }
  li { min-width: 0; background: var(--c-surface); }
  .testimonials.alt li { background: var(--c-surface-alt); }
  article { display: grid; height: 100%; grid-template-rows: 1fr auto; gap: 2rem; padding: clamp(1.25rem, 3vw, 2rem); }
  blockquote { margin: 0; } blockquote p { margin: 0; color: var(--c-on-surface); font: 600 clamp(1.05rem, 1.8vw, 1.35rem)/1.4 var(--font-display, var(--font-sans, sans-serif)); }
  footer { border-top: 1px solid var(--c-border); padding-top: 1rem; } footer p, h3 { margin: 0; } h3 { color: var(--c-on-surface); font: 700 1rem/1.3 var(--font-sans, sans-serif); } footer p { margin-top: .35rem; color: var(--c-on-surface-muted); font: 400 .875rem/1.45 var(--font-sans, sans-serif); }
  .testimonials--technical-grid { background-image: linear-gradient(to right, color-mix(in srgb, var(--c-border) 42%, transparent) 1px, transparent 1px); background-size: 4rem 100%; }
  .testimonials--quiet { background-image: none; }
  @media (prefers-reduced-motion: reduce) { *, *::before, *::after { scroll-behavior: auto !important; } }
</style>
