---
import { createRequire } from 'node:module'; import { localePagePathHref } from '../lib/spec'; interface Cta{labelKey:string;pageId:string}interface Row{icon:string;serviceKey:string;noteKey:string;fromKey:string}interface Props{eyebrowKey:string;titleKey:string;titleAccentKey:string;introKey:string;serviceColumnKey:string;fromColumnKey:string;primaryCta:Cta;secondaryCta?:Cta;rows:Row[];footnoteKey:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;alt?:boolean;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string>}const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {eyebrowKey,titleKey,titleAccentKey,introKey,serviceColumnKey,fromColumnKey,primaryCta,secondaryCta,rows,footnoteKey,variant='technical-grid',t,alt,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;const content={eyebrow:t(eyebrowKey),title:t(titleKey),accent:t(titleAccentKey),intro:t(introKey),serviceColumn:t(serviceColumnKey),fromColumn:t(fromColumnKey),primaryCta:t(primaryCta.labelKey),secondaryCta:secondaryCta?t(secondaryCta.labelKey):undefined,footnote:t(footnoteKey),rows:rows.map((row)=>({icon:row.icon,service:t(row.serviceKey),note:t(row.noteKey),from:t(row.fromKey)}))};assertQualifiedComponentContentBudget('PricingTable',content);const headingId=`${instanceId}-pricing-table-heading`;const href=(cta:Cta)=>{const pagePath=pagePathById[cta.pageId];if(!pagePath)throw new Error('PAGE_REFERENCE_UNKNOWN: PricingTable.'+cta.pageId);return localePagePathHref(pagePath,locale,defaultLocale)};
---
<section class:list={['block','pricing-table',`pricing-table--${variant}`,{alt}]} data-component="PricingTable" data-variant={variant} aria-labelledby={headingId}><div class="container layout"><header><span>{content.eyebrow}</span><h2 id={headingId}>{content.title} <em>{content.accent}</em></h2><p>{content.intro}</p><div class="ctas"><a href={href(primaryCta)}>{content.primaryCta}</a>{secondaryCta&&<a href={href(secondaryCta)}>{content.secondaryCta}</a>}</div></header><div><table><thead><tr><th scope="col">{content.serviceColumn}</th><th scope="col">{content.fromColumn}</th></tr></thead><tbody>{content.rows.map((row)=><tr><td><i class={row.icon} aria-hidden="true"></i><span><strong>{row.service}</strong><small>{row.note}</small></span></td><td>{row.from}</td></tr>)}</tbody></table><p class="footnote">{content.footnote}</p></div></div></section>
<style>.layout{display:grid;gap:2rem}@media(min-width:1024px){.layout{grid-template-columns:5fr 7fr}}header>span{font-size:.75rem;letter-spacing:.15em;text-transform:uppercase}h2{margin-top:1rem;font-size:clamp(2rem,5vw,3.5rem)}header>p{margin-top:1rem}.ctas{display:flex;flex-wrap:wrap;gap:1rem;margin-top:2rem}.ctas a{padding:.75rem 1rem;border:1px solid var(--c-border);border-radius:9999px;font-weight:600}.ctas a:first-child{background:var(--c-primary);color:var(--c-on-dark)}table{width:100%;border-collapse:collapse;border:1px solid var(--c-border)}th,td{padding:1rem;text-align:left;border-bottom:1px solid var(--c-border)}th:last-child,td:last-child{text-align:right}td:first-child{display:flex;gap:.75rem;align-items:start}td i{margin-top:.15rem}small{display:block;margin-top:.25rem}.pricing-table--technical-grid table{background:linear-gradient(var(--c-surface-alt) 1px,transparent 1px),linear-gradient(90deg,var(--c-surface-alt) 1px,transparent 1px);background-size:1rem 1rem}.footnote{margin-top:1rem;font-size:.8rem}</style>
