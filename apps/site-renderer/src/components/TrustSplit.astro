---
import { createRequire } from 'node:module';
interface Stat { value: string; labelKey: string }
interface Props { eyebrowKey:string; titleKey:string; titleAccentKey:string; introKey:string; stats:Stat[]; badges:string[]; portraitNameKey:string; portraitRoleKey:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; alt?:boolean; instanceId:string }
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { eyebrowKey,titleKey,titleAccentKey,introKey,stats,badges,portraitNameKey,portraitRoleKey,variant='technical-grid',t,alt,instanceId }=Astro.props;
const eyebrow=t(eyebrowKey), title=t(titleKey), accent=t(titleAccentKey), intro=t(introKey), name=t(portraitNameKey), role=t(portraitRoleKey);
const metrics=stats.map((stat)=>({value:String(stat.value),label:t(stat.labelKey)}));
assertQualifiedComponentContentBudget('TrustSplit',{eyebrow,title,accent,intro,metrics,badges,name,role});
const headingId=`${instanceId}-trust-heading`;
---
<section class:list={['block','trust-split',`trust-split--${variant}`,{alt}]} data-component="TrustSplit" data-variant={variant} aria-labelledby={headingId}><div class="container grid-12 trust"><div class="left"><span class="eyebrow">{eyebrow}</span><h2 id={headingId} class="section-title">{title} <em>{accent}</em></h2><p class="muted intro">{intro}</p><ul class="stats">{metrics.map((metric)=><li><strong>{metric.value}</strong><span>{metric.label}</span></li>)}</ul><ul class="badges">{badges.map((badge)=><li><span aria-hidden="true"><i class="ri-check-line"></i></span>{badge}</li>)}</ul></div><aside class="profile" aria-label={name}><div class="profile-icon" aria-hidden="true"><i class="ri-user-line"></i></div><div><p class="name">{name}</p><p class="muted">{role}</p></div></aside></div></section>
<style>.trust{align-items:center}.left{grid-column:span 7}.profile{grid-column:span 5;display:grid;grid-template-columns:auto 1fr;gap:1rem;align-items:center;padding:2rem;border:1px solid var(--c-border);border-radius:var(--radius-lg);background:var(--c-surface)}@media(max-width:1023px){.left,.profile{grid-column:span 1}}.intro{margin-top:1rem;max-width:36rem}.stats,.badges{list-style:none;padding:0;margin:2rem 0 0;display:flex;flex-wrap:wrap;gap:1rem}.stats li{display:grid;gap:.35rem;padding-right:1rem;border-right:1px solid var(--c-border)}.stats strong{font-size:clamp(1.5rem,3vw,3rem);color:var(--c-accent)}.stats span,.badges li{font-size:.85rem;color:var(--c-on-surface-muted)}.badges li{display:inline-flex;gap:.35rem;align-items:center;border:1px solid var(--c-border);border-radius:9999px;padding:.35rem .7rem}.badges span{color:var(--c-accent)}.profile-icon{width:3rem;height:3rem;display:grid;place-items:center;border-radius:9999px;background:var(--c-primary-dark);color:var(--c-on-dark)}.name{font-weight:600}.trust-split--technical-grid .profile{background:linear-gradient(var(--c-surface-alt) 1px,transparent 1px),linear-gradient(90deg,var(--c-surface-alt) 1px,transparent 1px),var(--c-surface);background-size:1rem 1rem}</style>
