---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Dish {nameKey:string;seasonKey:string;noteKey:string} interface Props {eyebrowKey:string;titleKey:string;titleAccentKey:string;dishes:Dish[];addLabelKey?:string;addPageId?:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;alt?:boolean;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string>}
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {eyebrowKey,titleKey,titleAccentKey,dishes,addLabelKey='cta.addToMenu',addPageId='services',variant='technical-grid',t,alt,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;const content={eyebrow:t(eyebrowKey),title:t(titleKey),accent:t(titleAccentKey),dishes:dishes.map((dish)=>({name:t(dish.nameKey),season:t(dish.seasonKey),note:t(dish.noteKey)})),cta:t(addLabelKey)};assertQualifiedComponentContentBudget('DishesShowcase',content);const headingId=`${instanceId}-dishes-heading`;const ctaHref=localeQualifiedPageHref(addPageId,pagePathById,locale,defaultLocale);
---
<section class:list={['block','dishes-showcase',`dishes-showcase--${variant}`,{alt}]} data-component="DishesShowcase" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><p class="eyebrow">{content.eyebrow}</p><h2 id={headingId}>{content.title} <em>{content.accent}</em></h2></header><ul class="grid">{content.dishes.map((dish,index)=><li><article><p class="number" aria-hidden="true">{String(index+1).padStart(2,'0')}</p><p class="season">{dish.season}</p><h3>{dish.name}</h3><p class="note">{dish.note}</p>{ctaHref&&<a href={ctaHref}>{content.cta}<span aria-hidden="true">→</span></a>}</article></li>)}</ul></div></section>
<style>.dishes-showcase--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 28%,transparent) 1px,transparent 1px);background-size:2rem 2rem}header{max-width:38rem;margin-bottom:2rem}.eyebrow,.season{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--c-accent-strong)}h2{margin-top:.75rem;font-size:clamp(2.25rem,5vw,4rem);line-height:1}h2 em{font-style:italic}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,15rem),1fr));gap:1rem;list-style:none;margin:0;padding:0}.grid article{height:100%;padding:1.25rem;border:1px solid var(--c-border);background:var(--c-surface)}.number{font-size:1.5rem;color:var(--c-on-surface-muted)}.season{margin-top:3rem}.grid h3{margin-top:.6rem;font-size:1.3rem}.note{margin-top:.75rem;line-height:1.6;color:var(--c-on-surface-muted)}.grid a{margin-top:1.25rem;display:inline-flex;gap:.4rem;min-height:2.25rem;align-items:center;color:var(--c-primary);text-decoration:underline;text-underline-offset:.2em}.dishes-showcase--quiet{background:var(--c-surface-alt)}</style>
