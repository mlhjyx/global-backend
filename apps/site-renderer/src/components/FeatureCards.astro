---
import { createRequire } from 'node:module';

import type { Translate } from '../i18n';

const require = createRequire(import.meta.url);
const { assertQualifiedComponentContentBudget } = require('@global/contracts') as typeof import('@global/contracts');

type Feature = { icon: string; titleKey: string; descKey: string };
type Props = { id?: string; instanceId: string; eyebrowKey: string; titleKey: string; titleLine2Key: string; introKey: string; items: Feature[]; learnKey?: string; variant?: 'technical-grid' | 'quiet'; t: Translate; alt?: boolean };
const { id, instanceId, eyebrowKey, titleKey, titleLine2Key, introKey, items, learnKey, variant = 'technical-grid', t, alt } = Astro.props;
const eyebrow = t(eyebrowKey);
const title = `${t(titleKey)} ${t(titleLine2Key)}`;
const intro = t(introKey);
const resolvedItems = items.map((item) => ({ title: t(item.titleKey), description: t(item.descKey) }));
assertQualifiedComponentContentBudget('FeatureCards', { eyebrow, title, intro, items: resolvedItems, learn: learnKey ? t(learnKey) : undefined });
const baseId = `feature-cards-${id ?? 'section'}-${instanceId}`.replace(/[^a-zA-Z0-9_-]/g, '-');
const headingId = `${baseId}-heading`;
---

<section class:list={['block', 'feature-cards', `feature-cards--${variant}`, { alt }]} data-component="FeatureCards" data-variant={variant} aria-labelledby={headingId}>
  <div class="container">
    <div class="feature-cards__intro">
      <div><p class="feature-cards__eyebrow">{eyebrow}</p><h2 id={headingId}>{t(titleKey)}<br />{t(titleLine2Key)}</h2></div>
      <p>{intro}</p>
    </div>
    <ul class="feature-cards__list" role="list">
      {resolvedItems.map((item, index) => { const itemId = `${baseId}-item-${index + 1}`; return <li><article aria-labelledby={itemId}><span class="feature-cards__number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span><h3 id={itemId}>{item.title}</h3><p>{item.description}</p></article></li>; })}
    </ul>
  </div>
</section>

<style>
  .feature-cards { background: var(--c-surface); border-block: 1px solid var(--c-border); }
  .feature-cards.alt { background: var(--c-surface-alt); }
  .feature-cards__intro { display: grid; gap: 1.5rem; align-items: end; max-width: 68rem; } @media (min-width: 48rem) { .feature-cards__intro { grid-template-columns: 1.15fr .85fr; } }
  .feature-cards__eyebrow { margin: 0 0 .65rem; color: var(--c-primary); font: 700 .75rem/1.2 var(--font-sans, sans-serif); letter-spacing: .12em; text-transform: uppercase; }
  h2, h3, p { margin: 0; } h2 { color: var(--c-on-surface); font: 700 clamp(1.75rem, 4vw, 3.25rem)/1.06 var(--font-display, var(--font-sans, sans-serif)); letter-spacing: -.025em; } .feature-cards__intro > p { max-width: 32rem; color: var(--c-on-surface-muted); font: 400 1rem/1.6 var(--font-sans, sans-serif); }
  .feature-cards__list { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr)); gap: 1px; margin: 2rem 0 0; padding: 1px; list-style: none; background: var(--c-border); }
  li { min-width: 0; background: var(--c-surface); } .feature-cards.alt li { background: var(--c-surface-alt); } article { min-height: 100%; padding: clamp(1.25rem, 3vw, 2rem); } .feature-cards__number { display: block; margin-bottom: 2rem; color: var(--c-primary); font: 700 .75rem/1 var(--font-mono, monospace); letter-spacing: .1em; } h3 { color: var(--c-on-surface); font: 700 clamp(1.05rem, 1.7vw, 1.35rem)/1.3 var(--font-sans, sans-serif); } article p { margin-top: .75rem; color: var(--c-on-surface-muted); font: 400 .95rem/1.6 var(--font-sans, sans-serif); }
  .feature-cards--technical-grid { background-image: linear-gradient(to right, color-mix(in srgb, var(--c-border) 42%, transparent) 1px, transparent 1px); background-size: 4rem 100%; } .feature-cards--quiet { background-image: none; }
  @media (prefers-reduced-motion: reduce) { *, *::before, *::after { scroll-behavior: auto !important; } }
</style>
