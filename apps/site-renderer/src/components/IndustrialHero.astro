---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Cta { labelKey:string; pageId:string } interface Stat { value:string; suffix?:string; labelKey:string }
interface Props { badgeKey:string; badgeSubKey:string; leftH1Key:string; leftH1AccentKey:string; leftSubKey:string; leftStats:Stat[]; rightH1Key:string; rightH2aKey:string; rightH2bKey?:string; rightH2bAccentKey:string; rightSubKey:string; primaryCta?:Cta; secondaryCta?:Cta; cta1Key?:string; cta1PageId?:string; cta2Key?:string; cta2PageId?:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; locale:string; defaultLocale:string; instanceId:string; pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget }=createRequire(import.meta.url)('@global/contracts');
const {badgeKey,badgeSubKey,leftH1Key,leftH1AccentKey,leftSubKey,leftStats,rightH1Key,rightH2aKey,rightH2bKey,rightH2bAccentKey,rightSubKey,primaryCta:configuredPrimary,secondaryCta:configuredSecondary,cta1Key,cta1PageId,cta2Key,cta2PageId,variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props; const primaryCta=configuredPrimary ?? {labelKey:cta1Key!,pageId:cta1PageId??'book'}; const secondaryCta=configuredSecondary ?? (cta2Key?{labelKey:cta2Key,pageId:cta2PageId??'book'}:undefined);
const content={badge:t(badgeKey),badgeSub:t(badgeSubKey),leftTitle:`${t(leftH1Key)} ${t(leftH1AccentKey)}`,leftSub:t(leftSubKey),stats:leftStats.map(s=>({value:`${s.value}${s.suffix??''}`,label:t(s.labelKey)})),rightTitle:`${t(rightH1Key)} ${t(rightH2aKey)} ${rightH2bKey?t(rightH2bKey):''} ${t(rightH2bAccentKey)}`,rightSub:t(rightSubKey),primaryCta:t(primaryCta.labelKey),secondaryCta:secondaryCta?t(secondaryCta.labelKey):undefined};
assertQualifiedComponentContentBudget('IndustrialHero',content); const headingId=`${instanceId}-industrial-hero-heading`; const href=(cta:Cta)=>localeQualifiedPageHref(cta.pageId,pagePathById,locale,defaultLocale);
---
<section class={`industrial-hero industrial-hero--${variant}`} data-component="IndustrialHero" data-variant={variant} aria-labelledby={headingId}><div class="container"><div><p class="badge">{content.badge} · {content.badgeSub}</p><h1 id={headingId}>{t(leftH1Key)} <em>{t(leftH1AccentKey)}</em></h1><p class="sub">{content.leftSub}</p><dl>{leftStats.map(s=><div><dt>{t(s.labelKey)}</dt><dd>{s.value}{s.suffix}</dd></div>)}</dl></div><div class="action"><h2>{t(rightH1Key)}<br />{t(rightH2aKey)} {rightH2bKey && t(rightH2bKey)} <em>{t(rightH2bAccentKey)}</em></h2><p class="sub">{content.rightSub}</p><div class="ctas"><a href={href(primaryCta)}>{content.primaryCta}<span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a>{secondaryCta && <a class="secondary" href={href(secondaryCta)}>{content.secondaryCta}</a>}</div></div></div></section>
<style>
.industrial-hero{padding:clamp(5rem,10vw,9rem) 0;background:var(--c-surface);color:var(--c-on-surface)}.industrial-hero--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 30%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.container{display:grid;gap:3rem}@media(min-width:800px){.container{grid-template-columns:1fr 1fr}}.badge,dt{font:.7rem var(--font-mono);letter-spacing:.13em;text-transform:uppercase;color:var(--c-on-surface-muted)}h1,h2{font-size:clamp(2.5rem,6vw,5rem);line-height:.95}em{color:var(--c-accent);font-style:normal}.sub{max-width:34rem;margin-top:1.25rem;line-height:1.7}dl{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;margin-top:2rem}dl div{border-top:1px solid var(--c-border);padding-top:.75rem}dd{margin:.35rem 0;font-size:1.8rem}.action{align-self:end}.ctas{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:2rem}.ctas a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;background:var(--c-primary);color:var(--c-on-primary)}.ctas .secondary{background:transparent;color:inherit;border:1px solid currentColor}.ctas a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.industrial-hero--quiet{background:var(--c-surface-alt)}
</style>
