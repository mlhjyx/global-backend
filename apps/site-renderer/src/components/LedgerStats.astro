---
import { createRequire } from 'node:module';interface Stat{value:string;labelKey:string}interface Props{chapterKey:string;titleKey:string;bodyKey:string;stats:Stat[];clients:string[];clientsLabelKey:string;variant?:'technical-grid'|'quiet';t:(key:string)=>string;alt?:boolean;instanceId:string}const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {chapterKey,titleKey,bodyKey,stats,clients,clientsLabelKey,variant='technical-grid',t,alt,instanceId}=Astro.props;const content={chapter:t(chapterKey),title:t(titleKey),body:t(bodyKey),stats:stats.map((stat)=>({value:stat.value,label:t(stat.labelKey)})),clients,clientsLabel:t(clientsLabelKey)};assertQualifiedComponentContentBudget('LedgerStats',content);const headingId=`${instanceId}-ledger-heading`;
---
<section class:list={['block','ledger-stats',`ledger-stats--${variant}`,{alt}]} data-component="LedgerStats" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><p>{content.chapter}</p><div><h2 id={headingId}>{content.title}</h2><p>{content.body}</p></div></header><ul class="stats">{content.stats.map((stat)=><li><p class="value">{stat.value}</p><p>{stat.label}</p></li>)}</ul><aside aria-label={content.clientsLabel}><p>{content.clientsLabel}</p><ul class="clients">{content.clients.map((client)=><li>{client}</li>)}</ul></aside></div></section>
<style>.ledger-stats{background:var(--c-primary);color:var(--c-on-dark)}header{display:grid;gap:1.5rem;margin-bottom:3rem}@media(min-width:768px){header{grid-template-columns:3fr 9fr}}header>p,aside>p{font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;opacity:.7}h2{font-size:clamp(2.25rem,6vw,4.5rem);line-height:.95}.stats{display:grid;grid-template-columns:repeat(2,1fr);list-style:none;padding:0;margin:0;border-top:1px solid color-mix(in srgb,currentColor 15%,transparent)}@media(min-width:1024px){.stats{grid-template-columns:repeat(4,1fr)}}.stats li{padding:2rem 1.25rem;border-inline-end:1px solid color-mix(in srgb,currentColor 15%,transparent)}.value{font-size:clamp(2.25rem,5vw,3.75rem);font-weight:700}aside{margin-top:3rem;padding-top:2rem;border-top:1px solid color-mix(in srgb,currentColor 15%,transparent)}.clients{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;list-style:none;padding:0}@media(min-width:768px){.clients{grid-template-columns:repeat(4,1fr)}}</style>
