---
import { createRequire } from 'node:module';
import { localeQualifiedPageHref } from '../lib/page-reference';
interface Cta { labelKey:string; pageId:string } interface Props { eyebrowKey:string; h1Key:string; h1AccentKey:string; subKey:string; primaryCta?:Cta; secondaryCta?:Cta; cta1Key?:string; cta1PageId?:string; cta2Key?:string; cta2PageId?:string; scrollKey:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; locale:string; defaultLocale:string; instanceId:string; pagePathById?:Record<string,string> }
const { assertQualifiedComponentContentBudget }=createRequire(import.meta.url)('@global/contracts'); const {eyebrowKey,h1Key,h1AccentKey,subKey,primaryCta:configuredPrimary,secondaryCta:configuredSecondary,cta1Key,cta1PageId,cta2Key,cta2PageId,scrollKey,variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props; const primaryCta=configuredPrimary ?? {labelKey:cta1Key!,pageId:cta1PageId??'book'}; const secondaryCta=configuredSecondary ?? (cta2Key?{labelKey:cta2Key,pageId:cta2PageId??'book'}:undefined); const content={eyebrow:t(eyebrowKey),title:`${t(h1Key)} ${t(h1AccentKey)}`,sub:t(subKey),primaryCta:t(primaryCta.labelKey),secondaryCta:secondaryCta?t(secondaryCta.labelKey):undefined,scroll:t(scrollKey)}; assertQualifiedComponentContentBudget('MinimalHero',content); const headingId=`${instanceId}-minimal-hero-heading`; const href=(cta:Cta)=>localeQualifiedPageHref(cta.pageId,pagePathById,locale,defaultLocale);
---
<section class={`minimal-hero minimal-hero--${variant}`} data-component="MinimalHero" data-variant={variant} aria-labelledby={headingId}><div class="container"><p class="eyebrow">{content.eyebrow}</p><h1 id={headingId}>{t(h1Key)} <em>{t(h1AccentKey)}</em></h1><p class="sub">{content.sub}</p><div class="ctas"><a href={href(primaryCta)}>{content.primaryCta}<span aria-hidden="true">→</span></a>{secondaryCta && <a class="secondary" href={href(secondaryCta)}>{content.secondaryCta}</a>}</div><p class="scroll">{content.scroll}</p></div></section>
<style>
.minimal-hero{padding:clamp(6rem,13vw,11rem) 0;text-align:center;background:var(--c-surface);color:var(--c-on-surface)}.minimal-hero--technical-grid{background-image:radial-gradient(color-mix(in srgb,var(--c-border) 45%,transparent) 1px,transparent 1px);background-size:1.25rem 1.25rem}.container{max-width:52rem}.eyebrow,.scroll{font:.72rem var(--font-mono);letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h1{margin-top:1rem;font-size:clamp(3rem,8vw,6rem);line-height:.95}em{font-style:italic}.sub{max-width:38rem;margin:1.5rem auto;line-height:1.7}.ctas{display:flex;justify-content:center;gap:.75rem;flex-wrap:wrap;margin-top:2rem}.ctas a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;background:var(--c-primary);color:var(--c-on-primary)}.ctas .secondary{background:transparent;color:inherit;border:1px solid currentColor}.ctas a:focus-visible{outline:2px solid currentColor;outline-offset:3px}.scroll{margin-top:3rem}.minimal-hero--quiet{background:var(--c-surface-alt)}
</style>
