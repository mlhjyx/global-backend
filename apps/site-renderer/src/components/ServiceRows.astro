---
import { createRequire } from 'node:module';
import { localePageHref } from '../lib/spec';

interface Service { icon: string; titleKey: string; descKey: string; fromKey: string; unitKey: string }
interface Cta { labelKey: string; pageId: string }
interface Props {
  eyebrowKey: string;
  titleKey: string;
  titleAccentKey: string;
  introKey: string;
  fromLabelKey: string;
  cta: Cta;
  services: Service[];
  variant?: 'technical-grid' | 'quiet';
  t: (key: string) => string;
  alt?: boolean;
  locale: string;
  defaultLocale: string;
  instanceId: string;
}
const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { eyebrowKey, titleKey, titleAccentKey, introKey, fromLabelKey, cta, services, variant = 'technical-grid', t, alt, locale, defaultLocale, instanceId } = Astro.props;
const content = {
  eyebrow: t(eyebrowKey), title: t(titleKey), accent: t(titleAccentKey), intro: t(introKey), fromLabel: t(fromLabelKey), cta: t(cta.labelKey),
  services: services.map((service) => ({ icon: service.icon, title: t(service.titleKey), description: t(service.descKey), from: t(service.fromKey), unit: t(service.unitKey) })),
};
assertQualifiedComponentContentBudget('ServiceRows', content);
const headingId = `${instanceId}-service-rows-heading`;
const ctaHref = localePageHref(cta.pageId, locale, defaultLocale);
---

<section class:list={['block', 'service-rows', `service-rows--${variant}`, { alt }]} data-component="ServiceRows" data-variant={variant} aria-labelledby={headingId}>
  <div class="container">
    <div class="head">
      <div>
        <span class="eyebrow-accent">{content.eyebrow}</span>
        <h2 id={headingId} class="serif-title">{content.title}<em>{content.accent}</em></h2>
      </div>
      <p class="intro">{content.intro}</p>
    </div>

    <ul class="grid">
      {content.services.map((service, index) => (
        <li>
          <article class:list={['card', { dark: index % 3 === 0 }]}>
            <div class="ph"><i class={service.icon} aria-hidden="true"></i></div>
            <div class="body">
              <span class="icon-circle"><i class={service.icon} aria-hidden="true"></i></span>
              <h3>{service.title}</h3>
              <p class="desc">{service.description}</p>
              <div class="foot">
                <div>
                  <span class="from-label">{content.fromLabel}</span>
                  <span class="price">{service.from}<span class="unit">{service.unit}</span></span>
                </div>
                <a class:list={['learn', { dark: index % 3 === 0 }]} href={ctaHref}>
                  {content.cta}<i class="ri-arrow-right-up-line" aria-hidden="true"></i>
                </a>
              </div>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .service-rows--technical-grid { background-image: linear-gradient(color-mix(in srgb, var(--c-border) 40%, transparent) 1px, transparent 1px), linear-gradient(90deg, color-mix(in srgb, var(--c-border) 40%, transparent) 1px, transparent 1px); background-size: 2rem 2rem; }
  .head { display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
  @media (min-width: 768px) { .head { grid-template-columns: 1.4fr 1fr; align-items: end; } }
  .eyebrow-accent { font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--c-primary); }
  .serif-title { margin-top: 1rem; font-family: var(--font-heading); font-weight: 500; font-size: clamp(2rem, 4.5vw, 3rem); line-height: 1.1; max-width: 22ch; }
  .serif-title em { font-style: italic; font-weight: 400; }
  .intro { font-size: 0.95rem; line-height: 1.7; color: var(--c-on-surface-muted); max-width: 28rem; }
  .grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 768px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  .card { height: 100%; display: grid; grid-template-columns: 1fr; overflow: hidden; border-radius: var(--radius-lg); border: 1px solid var(--c-border); background: var(--c-surface); }
  @media (min-width: 640px) { .card { grid-template-columns: 2fr 3fr; } }
  .card.dark { background: var(--c-on-surface); color: var(--c-on-dark); border-color: var(--c-on-surface); }
  .ph { aspect-ratio: 1 / 1; display: grid; place-items: center; background: radial-gradient(60% 50% at 40% 30%, color-mix(in srgb, var(--c-secondary) 18%, transparent), transparent 60%), linear-gradient(140deg, var(--c-surface-alt2), var(--c-surface-alt)); }
  @media (min-width: 640px) { .ph { aspect-ratio: auto; height: 100%; min-height: 16rem; } }
  .ph i { font-size: 3rem; color: rgba(0,0,0,0.15); }
  .card.dark .ph { background: linear-gradient(140deg, #3a2a1c, #5c3a24); }
  .card.dark .ph i { color: rgba(255,255,255,0.2); }
  .body { padding: clamp(1.5rem, 3vw, 2.25rem); display: flex; flex-direction: column; }
  .icon-circle { width: 2.75rem; height: 2.75rem; display: grid; place-items: center; border-radius: 9999px; background: color-mix(in srgb, var(--c-primary) 14%, transparent); color: var(--c-primary); }
  .card.dark .icon-circle { background: rgba(255,255,255,0.1); color: var(--c-secondary); }
  .card h3 { margin-top: 1.25rem; font-family: var(--font-heading); font-weight: 500; font-size: clamp(1.5rem, 2.5vw, 1.875rem); line-height: 1.2; }
  .desc { margin-top: 0.75rem; font-size: 0.9rem; line-height: 1.65; opacity: 0.8; }
  .foot { margin-top: auto; padding-top: 1.75rem; display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; }
  .from-label { font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; opacity: 0.7; display: block; }
  .price { font-family: var(--font-heading); font-weight: 500; font-size: 1.5rem; }
  .unit { margin-left: 0.25rem; font-size: 0.75rem; font-family: var(--font-body); font-weight: 400; opacity: 0.7; }
  .learn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem; border-radius: 9999px; font-size: 0.75rem; background: var(--c-on-surface); color: var(--c-on-dark); white-space: nowrap; }
  .learn.dark { background: var(--c-secondary); color: var(--c-on-surface); }
</style>
