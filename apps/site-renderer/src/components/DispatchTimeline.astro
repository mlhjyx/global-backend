---
import { createRequire } from 'node:module'; import { localeQualifiedPageHref } from '../lib/page-reference';
interface Step {t:string;titleKey:string;bodyKey:string} interface Props {chapterKey:string;titleKey:string;titleAccentKey:string;bodyKey:string;ctaKey:string;ctaPageId?:string;callKey:string;callPhoneKey:string;steps:Step[];variant?:'technical-grid'|'quiet';t:(key:string)=>string;locale:string;defaultLocale:string;instanceId:string;pagePathById?:Record<string,string>}
const {assertQualifiedComponentContentBudget}=createRequire(import.meta.url)('@global/contracts');const {chapterKey,titleKey,titleAccentKey,bodyKey,ctaKey,ctaPageId='book',callKey,callPhoneKey,steps,variant='technical-grid',t,locale,defaultLocale,instanceId,pagePathById={}}=Astro.props;const phone=t(callPhoneKey).replace(/[^0-9+]/g,'');const hasValidPhone=/^\+?[1-9]\d{6,14}$/.test(phone);const content={chapter:t(chapterKey),title:t(titleKey),accent:t(titleAccentKey),body:t(bodyKey),cta:t(ctaKey),call:`${t(callKey)} ${t(callPhoneKey)}`,steps:steps.map((step)=>({time:step.t,title:t(step.titleKey),body:t(step.bodyKey)}))};assertQualifiedComponentContentBudget('DispatchTimeline',content);const headingId=`${instanceId}-dispatch-timeline-heading`;
---
<section class={`dispatch-timeline dispatch-timeline--${variant}`} data-component="DispatchTimeline" data-variant={variant} aria-labelledby={headingId}><div class="container"><div class="intro"><p>{content.chapter}</p><h2 id={headingId}>{content.title} <em>{content.accent}</em></h2><p>{content.body}</p><div><a href={localeQualifiedPageHref(ctaPageId,pagePathById,locale,defaultLocale)}>{content.cta}<span aria-hidden="true"><i class="ri-arrow-right-line"></i></span></a>{hasValidPhone ? <a class="call" href={`tel:${phone}`}>{content.call}</a> : <p class="call">{content.call}</p>}</div></div><ol>{content.steps.map((step,index)=><li><article><p>{String(index+1).padStart(2,'0')} · {step.time}</p><h3>{step.title}</h3><p>{step.body}</p></article></li>)}</ol></div></section>
<style>.dispatch-timeline{padding-block:clamp(4rem,8vw,7rem);background:var(--c-surface-alt)}.dispatch-timeline--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 28%,transparent) 1px,transparent 1px);background-size:2rem 2rem}.intro{max-width:44rem}.intro>p:first-child,ol article>p:first-child{font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h2{margin-top:.75rem;font-size:clamp(2.2rem,5vw,4rem)}h2 em{font-style:italic}.intro>p:not(:first-child){margin-top:1rem;line-height:1.7}.intro div{display:flex;gap:1rem;flex-wrap:wrap;margin-top:1.5rem}.intro a{min-height:2.75rem;display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1rem;background:var(--c-primary);color:var(--c-on-primary)}.intro .call{background:transparent;color:var(--c-on-surface);border:1px solid var(--c-border)}a:focus-visible{outline:2px solid currentColor;outline-offset:3px}ol{display:grid;gap:1rem;margin:3rem 0 0;padding:0;list-style:none;counter-reset:steps}article{display:grid;grid-template-columns:minmax(5rem,.25fr) 1fr;gap:1rem;padding:1.25rem;border-top:1px solid var(--c-border)}h3{font-size:1.35rem}article>p:last-child{grid-column:2;line-height:1.65;color:var(--c-on-surface-muted)}.dispatch-timeline--quiet{background:var(--c-surface-alt)}@media(max-width:520px){article{grid-template-columns:1fr}article>p:last-child{grid-column:auto}}</style>
