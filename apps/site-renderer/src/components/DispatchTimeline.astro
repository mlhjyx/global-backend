---
interface Step { t: string; titleKey: string; bodyKey: string }
interface Props {
  chapterKey: string;
  titleKey: string;
  titleAccentKey: string;
  bodyKey: string;
  ctaKey: string;
  callKey: string;
  callPhoneKey: string;
  steps: Step[];
  t: (key: string) => string;
  alt?: boolean;
}
const { chapterKey, titleKey, titleAccentKey, bodyKey, ctaKey, callKey, callPhoneKey, steps = [], t, alt } = Astro.props;
---

<section class:list={['block', { alt }]} id="dispatch">
  <div class="container wide">
    <div class="grid-12">
      <div class="left">
        <div class="mono-tag">{t(chapterKey)}</div>
        <h2 class="display">{t(titleKey)}<br /><span class="accent">{t(titleAccentKey)}</span></h2>
        <p class="body">{t(bodyKey)}</p>
        <div class="ctas">
          <a class="cta-ink" href="#book">{t(ctaKey)} <span>-&gt;</span></a>
          <a class="call" href={`tel:${t(callPhoneKey).replace(/[^0-9+]/g, '')}`}>{t(callKey)} {t(callPhoneKey)}</a>
        </div>
      </div>
      <div class="right">
        <div class="timeline">
          <div class="line"></div>
          {steps.map((s, i) => (
            <div class="step">
              <div class="time">{s.t}</div>
              <div class="dot-wrap"><div class="dot"></div>{i === 0 && <div class="dot-flicker"></div>}</div>
              <div class="step-body">
                <div class="mono-tag">Step {String(i + 1).padStart(2, '0')}</div>
                <h3>{t(s.titleKey)}</h3>
                <p>{t(s.bodyKey)}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .wide { max-width: 88rem; }
  .grid-12 { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) { .grid-12 { grid-template-columns: 5fr 7fr; } }
  .mono-tag { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.18em; color: var(--c-on-surface-muted); }
  .display { margin-top: 1rem; font-family: var(--font-heading); font-weight: 900; font-stretch: 125%; font-size: clamp(2.25rem, 5vw, 3.75rem); line-height: 0.95; letter-spacing: -0.02em; }
  .accent { color: color-mix(in srgb, var(--c-accent) 90%, transparent); }
  .body { margin-top: 1.5rem; max-width: 28rem; line-height: 1.7; color: color-mix(in srgb, var(--c-on-surface) 80%, transparent); }
  .ctas { margin-top: 2.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .cta-ink { display: inline-flex; align-items: center; justify-content: space-between; gap: 2rem; height: 3rem; padding: 0 1.25rem; background: var(--c-primary); color: var(--c-on-primary); font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em; transition: background .2s ease, color .2s ease; width: fit-content; }
  .cta-ink:hover { background: var(--c-accent); color: var(--c-on-accent); }
  .call { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.18em; color: color-mix(in srgb, var(--c-on-surface) 70%, transparent); transition: color .2s ease; }
  .call:hover { color: var(--c-accent); }
  .timeline { position: relative; }
  .line { position: absolute; left: 4rem; top: 0.5rem; bottom: 0.5rem; width: 1px; background: rgba(31,31,31,0.15); }
  @media (min-width: 768px) { .line { left: 5.5rem; } }
  .step { position: relative; display: grid; grid-template-columns: 3rem 1rem 1fr; gap: 1rem; padding-bottom: 3rem; }
  @media (min-width: 768px) { .step { grid-template-columns: 4.5rem 1rem 1fr; gap: 1.5rem; } }
  .step:last-child { padding-bottom: 0; }
  .time { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 0.85rem; color: var(--c-on-surface); padding-top: 0.25rem; font-variant-numeric: tabular-nums; }
  .dot-wrap { position: relative; padding-top: 0.6rem; }
  .dot { width: 0.75rem; height: 0.75rem; background: var(--c-surface); border: 1px solid var(--c-on-surface); }
  .dot-flicker { position: absolute; inset: -4px; border: 1px solid var(--c-accent); animation: flicker 1.8s ease-in-out infinite; }
  @keyframes flicker { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
  .step-body { margin-top: -0.25rem; }
  .step-body h3 { margin-top: 0.5rem; font-family: var(--font-heading); font-weight: 700; font-stretch: 125%; font-size: clamp(1.2rem, 2.5vw, 1.75rem); line-height: 1.2; letter-spacing: -0.01em; }
  .step-body p { margin-top: 0.75rem; max-width: 32rem; line-height: 1.6; color: color-mix(in srgb, var(--c-on-surface) 75%, transparent); }
</style>
