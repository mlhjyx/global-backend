---
import { createRequire } from 'node:module';

interface Area { name: string }
interface Pin { labelKey: string; subKey: string; top: string; left: string; pulse?: boolean }
interface Props { chapterKey:string; titleKey:string; titleLine2Key:string; bodyKey:string; indexLabelKey:string; areas:Area[]; footnoteKey:string; pins:Pin[]; plateLabelKey:string; updatedKey:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; instanceId:string }

const { assertQualifiedComponentContentBudget } = createRequire(import.meta.url)('@global/contracts');
const { chapterKey, titleKey, titleLine2Key, bodyKey, indexLabelKey, areas, footnoteKey, pins, plateLabelKey, updatedKey, variant='technical-grid', t, instanceId } = Astro.props;
const content = { chapter:t(chapterKey), title:`${t(titleKey)} ${t(titleLine2Key)}`, body:t(bodyKey), index:t(indexLabelKey), areas:areas.map((area) => area.name), pins:pins.map((pin) => ({ label:t(pin.labelKey), sub:t(pin.subKey) })), footnote:t(footnoteKey), plate:t(plateLabelKey), updated:t(updatedKey) };
assertQualifiedComponentContentBudget('CoverageMap', content);
const headingId = `${instanceId}-coverage-map-heading`;
---

<section class={`coverage-map coverage-map--${variant}`} data-component="CoverageMap" data-variant={variant} aria-labelledby={headingId}>
  <div class="container">
    <header>
      <p>{content.chapter}</p>
      <div><h2 id={headingId}>{t(titleKey)}<br />{t(titleLine2Key)}</h2><p class="body">{content.body}</p></div>
    </header>
    <div class="layout">
      <section class="coverage-index" aria-label={content.index}>
        <p>{content.index}</p>
        <ol>{content.areas.map((area, index) => <li><span>{String(index + 1).padStart(2, '0')}</span>{area}</li>)}</ol>
        <p class="footnote">{content.footnote}</p>
      </section>
      <figure class="coverage-plate" aria-describedby={`${headingId}-caption`}>
        <div class="diagram" aria-hidden="true">
          <div class="grid-lines"></div>
          {pins.map((pin) => <span class="pin" style={`top:${pin.top};left:${pin.left}`}></span>)}
        </div>
        <figcaption id={`${headingId}-caption`}><span>{content.plate}</span><span>{content.updated}</span></figcaption>
      </figure>
    </div>
    {content.pins.length > 0 && <ul class="pin-list" aria-label="Coverage locations">{content.pins.map((pin) => <li><strong>{pin.sub}</strong><span>{pin.label}</span></li>)}</ul>}
  </div>
</section>

<style>
  .coverage-map{padding-block:clamp(4rem,8vw,7rem);background:var(--c-surface)}
  .coverage-map--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 28%,transparent) 1px,transparent 1px);background-size:2rem 2rem}
  header{display:grid;gap:1.25rem;margin-bottom:2rem} @media(min-width:768px){header{grid-template-columns:3fr 9fr}}
  header>p,.coverage-index>p:first-child,.footnote,figcaption{font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}
  h2{font-size:clamp(2.3rem,5vw,4.4rem);line-height:.95}.body{max-width:42rem;margin-top:1.25rem;line-height:1.7}
  .layout{display:grid;gap:1rem}@media(min-width:900px){.layout{grid-template-columns:5fr 7fr}}
  .coverage-index{border:1px solid var(--c-border);padding:1.25rem}.coverage-index ol,.pin-list{list-style:none;margin:1rem 0 0;padding:0}.coverage-index li{display:flex;gap:1rem;padding:.85rem 0;border-top:1px solid var(--c-border);font-weight:650}.coverage-index li span{font:inherit;color:var(--c-on-surface-muted);font-size:.75rem;letter-spacing:.12em}.footnote{margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid var(--c-border)}
  .coverage-plate{margin:0;border:1px solid var(--c-border);background:var(--c-secondary)}.diagram{position:relative;min-height:22rem;overflow:hidden;background:radial-gradient(circle at 50% 50%,color-mix(in srgb,var(--c-accent) 14%,transparent),transparent 48%),var(--c-secondary)}.grid-lines{position:absolute;inset:0;background-image:linear-gradient(color-mix(in srgb,var(--c-on-dark) 14%,transparent) 1px,transparent 1px),linear-gradient(90deg,color-mix(in srgb,var(--c-on-dark) 14%,transparent) 1px,transparent 1px);background-size:2.5rem 2.5rem}.pin{position:absolute;width:.8rem;height:.8rem;background:var(--c-accent);transform:translate(-50%,-50%);box-shadow:0 0 0 4px color-mix(in srgb,var(--c-accent) 20%,transparent)}figcaption{display:flex;justify-content:space-between;gap:1rem;padding:1rem;color:var(--c-on-dark)}
  .pin-list{display:grid;gap:.75rem;grid-template-columns:repeat(auto-fit,minmax(12rem,1fr));margin-top:1rem}.pin-list li{display:grid;gap:.15rem;padding:1rem;border:1px solid var(--c-border)}.pin-list strong{font-size:.78rem;letter-spacing:.1em;text-transform:uppercase}.pin-list span{color:var(--c-on-surface-muted)}.coverage-map--quiet{background:var(--c-surface-alt)}
</style>
