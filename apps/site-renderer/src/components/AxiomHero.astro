---
import { createRequire } from 'node:module';
interface Props { brandKey:string; brandSubKey:string; chapterKey:string; liveKey:string; h1aKey:string; h1bKey:string; h1cKey:string; serialKey:string; subKey:string; scrollKey:string; variant?:'technical-grid'|'quiet'; t:(key:string)=>string; instanceId:string }
const { assertQualifiedComponentContentBudget }=createRequire(import.meta.url)('@global/contracts'); const {brandKey,brandSubKey,chapterKey,liveKey,h1aKey,h1bKey,h1cKey,serialKey,subKey,scrollKey,variant='technical-grid',t,instanceId}=Astro.props; const content={brand:t(brandKey),brandSub:t(brandSubKey),chapter:t(chapterKey),status:t(liveKey),title:`${t(h1aKey)} ${t(h1bKey)} ${t(h1cKey)}`,serial:t(serialKey),sub:t(subKey),scroll:t(scrollKey)}; assertQualifiedComponentContentBudget('AxiomHero',content); const headingId=`${instanceId}-axiom-hero-heading`;
---
<section class={`axiom-hero axiom-hero--${variant}`} data-component="AxiomHero" data-variant={variant} aria-labelledby={headingId}><div class="container"><header><p>{content.brand} <span>{content.brandSub}</span></p><p>{content.chapter}</p><p><i aria-hidden="true"></i>{content.status}</p></header><div class="stage"><p class="serial">{content.serial}</p><h1 id={headingId}>{t(h1aKey)}<br />{t(h1bKey)}<br />{t(h1cKey)}</h1><p class="sub">{content.sub}</p></div><p class="scroll">{content.scroll}</p></div></section>
<style>
.axiom-hero{min-height:75svh;padding:clamp(4rem,9vw,8rem) 0;background:var(--c-surface);color:var(--c-on-surface)}.axiom-hero--technical-grid{background-image:linear-gradient(90deg,color-mix(in srgb,var(--c-border) 30%,transparent) 1px,transparent 1px),linear-gradient(color-mix(in srgb,var(--c-border) 30%,transparent) 1px,transparent 1px);background-size:3rem 3rem}.container{display:flex;min-height:60svh;flex-direction:column;justify-content:space-between}header{display:flex;justify-content:space-between;gap:1rem;font:.7rem var(--font-mono);letter-spacing:.13em;text-transform:uppercase;color:var(--c-on-surface-muted)}header span{opacity:.7}header i{display:inline-block;width:.55rem;height:.55rem;margin-right:.45rem;background:var(--c-primary);border-radius:50%}.stage{max-width:60rem;margin:auto 0}.serial,.scroll{font:.72rem var(--font-mono);letter-spacing:.14em;text-transform:uppercase;color:var(--c-on-surface-muted)}h1{margin-top:1rem;font-size:clamp(3.3rem,10vw,8rem);line-height:.84;letter-spacing:-.045em}.sub{max-width:34rem;margin-top:1.5rem;line-height:1.7}.scroll{margin-top:2rem}.axiom-hero--quiet{background:var(--c-surface-alt)}
</style>
