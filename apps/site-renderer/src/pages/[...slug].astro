---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { buildStaticLocalePaths, loadSpec, makeT } from '../lib/spec';

export function getStaticPaths() {
  const spec = loadSpec();
  return buildStaticLocalePaths(spec).map(({ slug, pageId, locale }) => ({
    params: { slug },
    props: { pageId, locale },
  }));
}

const { pageId, locale } = Astro.props;
const spec = loadSpec();
const t = makeT(spec, locale);
const page = spec.pages.find((p) => p.id === pageId)!;
---

<Base
  spec={spec}
  locale={locale}
  t={t}
  title={t(page.seo.titleKey)}
  description={t(page.seo.descriptionKey)}
>
  {page.puck.content.map((block, i) => (
    <Section
      block={block}
      t={t}
      index={i}
      locale={locale}
      defaultLocale={spec.site.defaultLocale}
    />
  ))}
</Base>
