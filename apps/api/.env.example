# apps/api 环境变量样例（复制为 .env 并填值；.env 不提交）

# ── 服务 ──
PORT=3000
NODE_ENV=development

# ── 数据库（app_user 走 RLS；owner 绕 RLS 供 relay/seed）──
APP_DATABASE_URL=postgresql://app_user:app_pw@localhost:5432/global_dev
DATABASE_URL=postgresql://global:global@localhost:5432/global_dev

# ── Temporal ──
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default

# ── 模型中转站（new-api）──
MODEL_GATEWAY_URL=http://localhost:3001/v1
MODEL_GATEWAY_KEY=            # 在 new-api UI 建令牌后填入（不得提交）
# 仅供没有显式 model 的 legacy/general task 兜底；Site Builder 由 task-routes.ts 分任务选型。
# 它不是全系统“主模型”，也不会覆盖 SITE_BUILDER_MODEL_*。
MODEL_DEFAULT_MODEL=deepseek-v4-flash
MODEL_TIMEOUT_MS=180000

# Site Builder 每任务紧急开关（改后须重启 API/worker）。BrandProfile 默认已由 registry 晋级为
# Terra→Sonnet；设 true 可回到冻结的 DeepSeek Pro→GLM 旧路由。MODEL/FALLBACKS 紧急覆盖优先级更高。
# SITE_BUILDER_MODEL_ROLLBACK_BRAND_PROFILE=false
# SITE_BUILDER_MODEL_BRAND_PROFILE=gpt-5.6-terra
# SITE_BUILDER_FALLBACKS_BRAND_PROFILE=claude-sonnet-5

# ── 采集（Crawl4AI / SearXNG / Overpass）──
CRAWLER_URL=http://localhost:11235
CRAWLER_TOKEN=global-local-crawl-token
SEARXNG_URL=http://localhost:8081
# OVERPASS_URL=            # 生产建议自托管 Overpass 以获稳定配额
# GLEIF_API_URL=https://api.gleif.org/api/v1   # LEI 富集源（默认公共端点，免注册 CC0）

# ── 鉴权（身份归外部 SaaS 平台，我方只校验其签发的 token）──
# 生产必填：配了这两个才启用真验签（JWKS）；否则生产启动失败（禁 dev stub 越权）。
# ⚠️ 上线前与 SaaS 平台书面确认：JWKS 端点、iss、aud、workspace/roles 的确切 claim 名、多 workspace 传法。
# AUTH_JWKS_URI=https://saas-platform/.well-known/jwks.json
# AUTH_ISSUER=https://saas-platform/
# AUTH_AUDIENCE=global-backend
# AUTH_CLOCK_SKEW_S=60
# AUTH_WORKSPACE_CLAIM=workspace_id
# AUTH_ROLES_CLAIM=roles
# AUTH_ALLOW_DEV_TOKENS=false   # 仅在明知的情况下于生产放行 base64 dev token

# ── 前端护栏 ──
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=300

# ── 合规（收口⑥ 存储权利判定）──
# 本实例数据处理所在地法域（EU | UK | US | CN | OTHER）。决定 LeadQualified 快照的 storage_rights_decision，
# 且是 EU/UK 主体→CN 处理地跨境人审规则的唯一开关。⚠️ 出海中企若后端部署在中国务必设 CN——
# 否则 EU/UK 决策人跨境存储会被误判 ALLOW（应 REQUIRE_APPROVAL）。生产未设会告警并缺省 EU；非法值启动即抛。
# DATA_PROCESSOR_JURISDICTION=EU
# 32 字节 hex/base64；生产 PII 写入缺 key 会 fail-closed。只填部署 secret，绝不提交真实值。
PII_ENCRYPTION_KEY=

# ── Companies House（当前活跃的 contact-discovery provider）──
# 英国 Companies House API key。空值时该 provider 对需要 key 的调用 fail-safe，不会向外发送请求。
COMPANIES_HOUSE_API_KEY=

# ── 待办 3 · BigQuery Google Patents 发明人源（默认 DISABLED，替代被封 EPO OPS）──
# 服务账号 key 文件路径（🔴 gitignored，绝不入库；建议放仓库外，如 ~/.config/gcloud/google-patents-sa-key.json）
# + 计费/配额 GCP project id。二者缺任一 → provider 天然 no-op（返空，同 EPO 无 key）。
# maximumBytesBilled 成本护栏默认 200GB/查询（BigQuery 若预估扫描超顶即拒，护 1TB/月免费额度），可调。
# GOOGLE_PATENTS_SA_JSON=/absolute/path/to/google-patents-sa-key.json
# GOOGLE_PATENTS_PROJECT=your-gcp-project-id
# GOOGLE_PATENTS_MAX_GB=200

# ── 对象存储（MinIO/S3 兼容；site-builder 素材与构建产物，键 ws/{workspace_id}/… 前缀隔离）──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=global
S3_SECRET_KEY=global-minio-dev
S3_BUCKET=global-site-builder
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
# 仅本地开发/单一 IaC owner 可设 true；生产 API replicas 默认 validate-only，缺 TTL rule 即阻止启动。
S3_MANAGE_VARIANT_ATTEMPT_LIFECYCLE=true

# ── 知识库 embedding（BGE-M3 自托管，经统一 new-api；模型数据不出域）──
EMBEDDINGS_URL=http://localhost:3001/v1
EMBEDDINGS_API_KEY=          # 必填：仅允许 site-builder-bge-m3-local 的专用令牌；禁止复用通用 key
EMBEDDINGS_MODEL=site-builder-bge-m3-local # 固定安全别名；网关映射到本机 Ollama bge-m3
EMBEDDINGS_DIM=1024

# ── 知识库文档解析（Docling 容器，site-builder 02 §12；PDF/DOCX→markdown 全本地）──
DOCLING_URL=http://localhost:5001

# ── 站点预览（M0 本地雏形；平台域名到位后切 {slug}.preview.<域>，05 §1）──
# PREVIEW_DIR=/absolute/path/.preview/sites      # 构建产物根目录（缺省 apps/api/.preview/sites）
# PREVIEW_URL_PATTERN=http://localhost:3000/preview/{slug}/

# ── Google Maps（Site Builder D16 未来预留；当前无代码消费者，勿删除）──
# 前端 Maps Embed key 未来应施加 referrer 限制；当前尚未由 Site Builder 注入或消费。
GOOGLE_MAPS_API_KEY=
# 后端 Geocoding key 未来应施加 IP 限制；当前尚无建站期 Geocoding 调用链。
GOOGLE_MAPS_GEOCODING_KEY=

# ── Readdy（设计研究/未来用途；当前无代码消费者，勿删除）──
# 仅保留研究或未来已获批准的集成所需配置；不得把 key 用于逆向或未授权接口。
READDY_API_KEY=

# ── 发现 ──
# DISCOVERY_ALLOW_SANDBOX=true   # 仅离线测试用合成源
